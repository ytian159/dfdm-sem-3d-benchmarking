+// Project the parasitic family-1 null component out of the displacement hat
+// state along one axis. Runs after advance_leapfrog (which copies prev1 =
+// now), so each filtered line is written back into both the current and the
+// history array to keep the leapfrog state consistent; the previous history
+// level was filtered last step. Strain along the axis is unchanged exactly
+// (the basis spans null of the family-1 gradient chain). Contains orphaned
+// OpenMP worksharing: distributes when called inside a parallel region and
+// runs sequentially otherwise.
+void apply_r2_null_filter_axis_pass(SerialPhase1Domain3D& domain, Axis3D axis) {
+    const R2NullFilterAxis3D& fa = domain.r2_filter.axes[static_cast<size_t>(axis)];
+    if (fa.basis.cols() == 0) {
+        return;
+    }
+    const Solver3DConfig& cfg = domain.cfg;
+    const int E = fa.chain_elements;
+    const int n1 = fa.line_points;
+    const size_t len = static_cast<size_t>(E) * static_cast<size_t>(n1);
+    const size_t dim = fa.basis.cols();
+    const double* basis = fa.basis.data();  // column-major (len x dim)
+
+    int transverse_a = 0;
+    int transverse_b = 0;
+    switch (axis) {
+    case Axis3D::X: transverse_a = cfg.ney; transverse_b = cfg.nez; break;
+    case Axis3D::Y: transverse_a = cfg.nex; transverse_b = cfg.nez; break;
+    case Axis3D::Z: transverse_a = cfg.nex; transverse_b = cfg.ney; break;
+    }
+
+    #pragma omp for collapse(2) schedule(static)
+    for (int ta = 1; ta <= transverse_a; ++ta) {
+        for (int tb = 1; tb <= transverse_b; ++tb) {
+            std::vector<double> line(len, 0.0);
+            std::vector<double> coeffs(dim, 0.0);
+            std::vector<size_t> chain_indices(static_cast<size_t>(E), 0);
+            for (int e = 0; e < E; ++e) {
+                int ex = ta, ey = ta, ez = tb;
+                switch (axis) {
+                case Axis3D::X: ex = e + 1; ey = ta; ez = tb; break;
+                case Axis3D::Y: ex = ta; ey = e + 1; ez = tb; break;
+                case Axis3D::Z: ex = ta; ey = tb; ez = e + 1; break;
+                }
+                chain_indices[static_cast<size_t>(e)] =
+                    element_linear_index(cfg, 0, ex, ey, ez);
+            }
+
+            TaggedFields3D ElasticState3D::* const now_members[3] = {
+                &ElasticState3D::ux, &ElasticState3D::uy, &ElasticState3D::uz};
+            TaggedFields3D ElasticState3D::* const hist_members[3] = {
+                &ElasticState3D::ux_1, &ElasticState3D::uy_1, &ElasticState3D::uz_1};
+            TaggedFields3D ElasticState3D::* const hist0_members[3] = {
+                &ElasticState3D::ux_0, &ElasticState3D::uy_0, &ElasticState3D::uz_0};
+            // At interval == 1 prev0 equals the previous step's filtered
+            // prev1 and stays in range of the projector by induction. At
+            // interval > 1 prev0 carries unfiltered history whose null
+            // component would re-enter through 2*prev1 - prev0 as an
+            // impulsive kick, so it must be projected with its own
+            // coefficients.
+            const bool filter_prev0 = domain.r2_filter.interval > 1;
+
+            for (GridTag tag : kDisplacementGridTags) {
+                if (grid_basis_digit(tag, axis) != 1) {
+                    continue;
+                }
+                const GridShape3D shape = shape_for_grid(tag, cfg.nx, cfg.ny, cfg.nz);
+                int points_a = 0;
+                int points_b = 0;
+                switch (axis) {
+                case Axis3D::X: points_a = shape.ny; points_b = shape.nz; break;
+                case Axis3D::Y: points_a = shape.nx; points_b = shape.nz; break;
+                case Axis3D::Z: points_a = shape.nx; points_b = shape.ny; break;
+                }
+
+                auto project_lines = [&](TaggedFields3D ElasticState3D::* gather_member,
+                                         TaggedFields3D ElasticState3D::* dst_a_member,
+                                         TaggedFields3D ElasticState3D::* dst_b_member) {
+                    for (int pb = 0; pb < points_b; ++pb) {
+                        for (int pa = 0; pa < points_a; ++pa) {
+                            for (int e = 0; e < E; ++e) {
+                                const Array3D& src =
+                                    (domain.elements[chain_indices[static_cast<size_t>(e)]]
+                                         .*gather_member).at(tag);
+                                const size_t base = static_cast<size_t>(e)
+                                                  * static_cast<size_t>(n1);
+                                for (int i = 0; i < n1; ++i) {
+                                    double value = 0.0;
+                                    switch (axis) {
+                                    case Axis3D::X:
+                                        value = src(static_cast<size_t>(i),
+                                                    static_cast<size_t>(pa),
+                                                    static_cast<size_t>(pb));
+                                        break;
+                                    case Axis3D::Y:
+                                        value = src(static_cast<size_t>(pa),
+                                                    static_cast<size_t>(i),
+                                                    static_cast<size_t>(pb));
+                                        break;
+                                    case Axis3D::Z:
+                                        value = src(static_cast<size_t>(pa),
+                                                    static_cast<size_t>(pb),
+                                                    static_cast<size_t>(i));
+                                        break;
+                                    }
+                                    line[base + static_cast<size_t>(i)] = value;
+                                }
+                            }
+
+                            for (size_t c = 0; c < dim; ++c) {
+                                const double* column = basis + c * len;
+                                double dot = 0.0;
+                                for (size_t t = 0; t < len; ++t) {
+                                    dot += column[t] * line[t];
+                                }
+                                coeffs[c] = dot;
+                            }
+                            for (size_t c = 0; c < dim; ++c) {
+                                const double* column = basis + c * len;
+                                const double scale = coeffs[c];
+                                for (size_t t = 0; t < len; ++t) {
+                                    line[t] -= scale * column[t];
+                                }
+                            }
+
+                            for (int e = 0; e < E; ++e) {
+                                ElasticState3D& element =
+                                    domain.elements[chain_indices[static_cast<size_t>(e)]];
+                                Array3D& dst_a = (element.*dst_a_member).at(tag);
+                                Array3D* dst_b = (dst_b_member != nullptr)
+                                    ? &(element.*dst_b_member).at(tag)
+                                    : nullptr;
+                                const size_t base = static_cast<size_t>(e)
+                                                  * static_cast<size_t>(n1);
+                                for (int i = 0; i < n1; ++i) {
+                                    const double value = line[base + static_cast<size_t>(i)];
+                                    switch (axis) {
+                                    case Axis3D::X:
+                                        dst_a(static_cast<size_t>(i),
+                                              static_cast<size_t>(pa),
+                                              static_cast<size_t>(pb)) = value;
+                                        if (dst_b != nullptr) {
+                                            (*dst_b)(static_cast<size_t>(i),
+                                                     static_cast<size_t>(pa),
+                                                     static_cast<size_t>(pb)) = value;
+                                        }
+                                        break;
+                                    case Axis3D::Y:
+                                        dst_a(static_cast<size_t>(pa),
+                                              static_cast<size_t>(i),
+                                              static_cast<size_t>(pb)) = value;
+                                        if (dst_b != nullptr) {
+                                            (*dst_b)(static_cast<size_t>(pa),
+                                                     static_cast<size_t>(i),
+                                                     static_cast<size_t>(pb)) = value;
+                                        }
+                                        break;
+                                    case Axis3D::Z:
+                                        dst_a(static_cast<size_t>(pa),
+                                              static_cast<size_t>(pb),
+                                              static_cast<size_t>(i)) = value;
+                                        if (dst_b != nullptr) {
+                                            (*dst_b)(static_cast<size_t>(pa),
+                                                     static_cast<size_t>(pb),
+                                                     static_cast<size_t>(i)) = value;
+                                        }
+                                        break;
+                                    }
+                                }
+                            }
+                        }
+                    }
+                };
+
+                for (int comp = 0; comp < 3; ++comp) {
+                    // u and u_1 are identical after advance_leapfrog: gather
+                    // once, scatter to both.
+                    project_lines(now_members[comp], now_members[comp], hist_members[comp]);
+                    if (filter_prev0) {
+                        project_lines(hist0_members[comp], hist0_members[comp], nullptr);
+                    }
+                }
+            }
+        }
+    }
+}
