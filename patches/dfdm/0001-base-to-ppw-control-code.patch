+
+const ElasticMatrix& sel_l_t(const AxisOperators1D& o, int fam) {
+    return fam == 1 ? o.l11_t : o.l22_t;
+}
+const ElasticMatrix& sel_invl_t(const AxisOperators1D& o, int fam) {
+    return fam == 1 ? o.invl11_t : o.invl22_t;
+}
+const ElasticMatrix& sel_eval_t(const AxisOperators1D& o, int fam) {
+    return fam == 1 ? o.b1_eval_t : o.b2_eval_t;
+}
+
+std::vector<double> matvec(const ElasticMatrix& A, const std::vector<double>& v) {
+    if (A.cols() != v.size()) throw std::runtime_error("matvec shape mismatch");
+    std::vector<double> r(A.rows(), 0.0);
+    for (size_t j = 0; j < A.cols(); ++j)
+        for (size_t i = 0; i < A.rows(); ++i)
+            r[i] += A(i, j) * v[j];
+    return r;
+}
+
+std::vector<double> solve_square(ElasticMatrix A, std::vector<double> rhs) {
+    const lapack_int n = static_cast<lapack_int>(A.rows());
+    std::vector<lapack_int> ipiv(n);
+    const lapack_int info = LAPACKE_dgesv(LAPACK_COL_MAJOR, n, 1, A.data(), n,
+                                          ipiv.data(), rhs.data(), n);
+    if (info != 0) throw std::runtime_error("dgesv failed");
+    return rhs;
+}
+
+std::vector<double> basis_coefficients(const AxisOperators1D& ops, int fam,
+                                       const std::function<double(double)>& g) {
+    BasisParameters b = (fam == 1) ? ops.b1 : ops.b2;
+    const std::vector<double> pts = b.x;
+    ElasticMatrix A = eval_all_basis(b, 0, pts);
+    std::vector<double> rhs(pts.size());
+    for (size_t i = 0; i < pts.size(); ++i) rhs[i] = g(pts[i]);
+    return solve_square(A, rhs);
+}
+
+struct Ops3 {
+    const AxisOperators1D* x;
+    const AxisOperators1D* y;
+    const AxisOperators1D* z;
+};
+
+Array3D hat_field_from_x_function(GridTag tag, const Ops3& ops,
+                                  const std::function<double(double)>& g) {
+    const GridShape3D shape = shape_for_grid(tag, ops.x->n1, ops.y->n1, ops.z->n1);
+    const int fx = grid_digit(tag, Axis3D::X);
+    const std::vector<double> cx = basis_coefficients(*ops.x, fx, g);
+    Array3D field(shape.nx, shape.ny, shape.nz);
+    for (size_t k = 0; k < field.nz(); ++k)
+        for (size_t j = 0; j < field.ny(); ++j)
+            for (size_t i = 0; i < field.nx(); ++i)
+                field(i, j, k) = cx[i];
+    field = apply_matrix_x(sel_l_t(*ops.x, fx), field);
+    field = apply_matrix_y(sel_l_t(*ops.y, grid_digit(tag, Axis3D::Y)), field);
+    field = apply_matrix_z(sel_l_t(*ops.z, grid_digit(tag, Axis3D::Z)), field);
+    return field;
+}
+
+Solver3DConfig make_cfg(int n1, int E, int porder, double h) {
+    Solver3DConfig cfg;
+    cfg.nx = n1; cfg.ny = n1; cfg.nz = n1;
+    cfg.nex = E; cfg.ney = 1; cfg.nez = 1;
+    cfg.porder = porder;
+    cfg.lx_m = h * E; cfg.ly_m = h; cfg.lz_m = h;
+    cfg.geometry_kind = "cartesian";
+    cfg.vp = 5000.0; cfg.vs = 2750.0; cfg.rho = 2000.0;
+    cfg.free_surface_top = true;
+    cfg.mass_factorization = "schur_sqrt";
+    cfg.axis_kernel_mode = "precomposed";
+    return cfg;
+}
+
+ReferenceDerivativeStage3D run_stage(bool displacement, GridTag src_tag,
+                                     const AxisOperators1D& xops,
+                                     const Array3D& hat, const SatFaceData3D& sat) {
+    return displacement
+        ? compute_displacement_reference_derivative(Axis3D::X, src_tag, xops, hat, sat)
+        : compute_stress_reference_divergence(Axis3D::X, src_tag, xops, hat, sat);
+}
+
+// Global stage matrix over a chain of E elements; periodic or bounded.
+ElasticMatrix build_chain_stage_matrix(bool displacement, GridTag src_tag,
+                                       const Solver3DConfig& cfg, const Ops3& ops,
+                                       int E, double alpha_in, double alpha_bd,
+                                       bool periodic) {
+    const GridShape3D sshape = shape_for_grid(src_tag, cfg.nx, cfg.ny, cfg.nz);
+    const GridTag tgt_tag = toggle_grid_tag(src_tag, Axis3D::X);
+    const GridShape3D tshape = shape_for_grid(tgt_tag, cfg.nx, cfg.ny, cfg.nz);
+    const int n_src = sshape.nx, n_tgt = tshape.nx;
+
+    std::vector<TaggedFields3D> fields(E);
+    for (int e = 0; e < E; ++e)
+        fields[e].at(src_tag).resize(sshape.nx, sshape.ny, sshape.nz);
+
+    const std::array<GridTag, 4> tags4 = {src_tag, src_tag, src_tag, src_tag};
+
+    ElasticMatrix D(size_t(E) * n_tgt, size_t(E) * n_src);
+    for (int es = 0; es < E; ++es) {
+        Array3D& f = fields[es].at(src_tag);
+        for (int i = 0; i < n_src; ++i) {
+            f.fill(0.0);
+            for (size_t k = 0; k < f.nz(); ++k)
+                for (size_t j = 0; j < f.ny(); ++j)
+                    f(i, j, k) = 1.0;
+            for (int dm = -1; dm <= 1; ++dm) {
+                int em = es + dm;
+                if (periodic) em = (em + E) % E;
+                else if (em < 0 || em >= E) continue;
+                const TaggedFields3D* mn = nullptr;
+                const TaggedFields3D* pl = nullptr;
+                if (periodic) {
+                    mn = &fields[(em - 1 + E) % E];
+                    pl = &fields[(em + 1) % E];
+                } else {
+                    if (em > 0) mn = &fields[em - 1];
+                    if (em < E - 1) pl = &fields[em + 1];
+                }
+                // SAT alphas: interior element index 2 for periodic; the real
+                // element index (1-based) for bounded so end elements pick up
+                // alpha_bd exactly like the production domain builder.
+                AxisSatSet3D sat = build_domain_zero_outer_sat_faces(
+                    cfg, periodic ? 2 : em + 1, 1, 1, alpha_in, alpha_bd);
+                populate_serial_neighbor_outer_faces(Axis3D::X, *ops.x, mn, pl, tags4, sat.x);
+                const ReferenceDerivativeStage3D st = run_stage(
+                    displacement, src_tag, *ops.x, fields[em].at(src_tag), sat.x.at(src_tag));
+                for (int t = 0; t < n_tgt; ++t)
+                    D(size_t(em) * n_tgt + t, size_t(es) * n_src + i) =
+                        st.derivative_hat(t, 0, 0);
+            }
+        }
+        f.fill(0.0);
+    }
+    return D;
+}
+
+// SVD helpers ---------------------------------------------------------------
+
+struct Svd {
+    std::vector<double> s;
+    ElasticMatrix U;   // m x min(m,n)
+    ElasticMatrix VT;  // min(m,n)... full n x n here
+};
+
+Svd svd_full(const ElasticMatrix& M) {
+    const lapack_int m = static_cast<lapack_int>(M.rows());
+    const lapack_int n = static_cast<lapack_int>(M.cols());
+    ElasticMatrix A = M;
+    Svd out;
+    out.s.assign(std::min(m, n), 0.0);
+    out.U = ElasticMatrix(size_t(m), size_t(m));
+    out.VT = ElasticMatrix(size_t(n), size_t(n));
+    std::vector<double> superb(std::min(m, n));
+    const lapack_int info = LAPACKE_dgesvd(LAPACK_COL_MAJOR, 'A', 'A', m, n,
+                                           A.data(), m, out.s.data(), out.U.data(), m,
+                                           out.VT.data(), n, superb.data());
+    if (info != 0) throw std::runtime_error("dgesvd failed");
+    return out;
+}
+
+// orthonormal columns spanning {columns of B} via SVD, keep sv > tol
+ElasticMatrix orth(const ElasticMatrix& B, double tol_rel = 1e-10) {
+    Svd s = svd_full(B);
+    const double smax = s.s.empty() ? 0.0 : s.s[0];
+    size_t r = 0;
+    for (size_t i = 0; i < s.s.size(); ++i)
+        if (s.s[i] > tol_rel * smax) ++r;
+    ElasticMatrix Q(B.rows(), r);
+    for (size_t j = 0; j < r; ++j)
+        for (size_t i = 0; i < B.rows(); ++i)
+            Q(i, j) = s.U(i, j);
+    return Q;
+}
+
+ElasticMatrix mat_mul_t_left(const ElasticMatrix& A, const ElasticMatrix& B) {
+    // A^T * B
+    ElasticMatrix C(A.cols(), B.cols());
+    for (size_t j = 0; j < B.cols(); ++j)
+        for (size_t k = 0; k < A.rows(); ++k)
+            for (size_t i = 0; i < A.cols(); ++i)
+                C(i, j) += A(k, i) * B(k, j);
+    return C;
+}
+
+double fro_norm(const ElasticMatrix& A) {
+    double s = 0;
+    for (size_t j = 0; j < A.cols(); ++j)
+        for (size_t i = 0; i < A.rows(); ++i) s += A(i, j) * A(i, j);
+    return std::sqrt(s);
+}
+
+double vec_norm(const std::vector<double>& v) {
+    double s = 0;
+    for (double x : v) s += x * x;
+    return std::sqrt(s);
+}
+
+std::string fmt(double v) {
+    char b[32];
+    std::snprintf(b, sizeof(b), "%.3e", v);
+    return b;
+}
+
+}  // namespace
+
+int main() {
+    const int n1 = 6, porder = 4, E = 16;
+    const double h = 200e3;
+    const Solver3DConfig cfg = make_cfg(n1, E, porder, h);
+    const AxisOperators1D x_ops = build_axis_operators(cfg.nx, cfg.porder, 0.5,
+                                                       cfg.mass_factorization,
+                                                       cfg.axis_kernel_mode);
+    const AxisOperators1D y_ops = build_axis_operators(cfg.ny, cfg.porder, 0.5,
+                                                       cfg.mass_factorization,
+                                                       cfg.axis_kernel_mode);
+    const AxisOperators1D z_ops = build_axis_operators(cfg.nz, cfg.porder, 0.5,
+                                                       cfg.mass_factorization,
+                                                       cfg.axis_kernel_mode);
+    const Ops3 ops{&x_ops, &y_ops, &z_ops};
+
+    const int n_src = n1;        // fam1 lines (G121 x-digit 1)
+    const int N = E * n_src;     // 96
+
+    // ---- periodic fam1 gradient chain & fam2 stress (divergence) chain -----
+    const ElasticMatrix Dg = build_chain_stage_matrix(
+        true, GridTag::G121, cfg, ops, E, 0.5, 0.0, true);            // 96 x 96 -> 80-row tgt? no: tgt G221 nx=5 => 80x96
+    const ElasticMatrix Dd = build_chain_stage_matrix(
+        false, GridTag::G221, cfg, ops, E, 0.5, 0.0, true);           // 96 x 80
+
+    std::cout << "Dg: " << Dg.rows() << " x " << Dg.cols()
+              << "   Dd: " << Dd.rows() << " x " << Dd.cols() << "\n";
+
+    // ---- (1) null space of Dg -----------------------------------------------
+    Svd sg = svd_full(Dg);
+    const double smax = sg.s[0];
+    std::vector<size_t> null_idx;
+    for (size_t i = 0; i < size_t(N); ++i) {
+        const double sv = i < sg.s.size() ? sg.s[i] : 0.0;
+        if (sv < 1e-10 * smax) null_idx.push_back(i);
+    }
+    std::cout << "null dim(Dg fam1) = " << null_idx.size()
+              << "  sigma_min(non-null) = "
+              << fmt(sg.s[sg.s.size() - null_idx.size() - 1]) << "\n";
+
+    // null basis N0 (columns), from rows of VT
+    ElasticMatrix N0(size_t(N), null_idx.size());
+    for (size_t c = 0; c < null_idx.size(); ++c)
+        for (size_t i = 0; i < size_t(N); ++i)
+            N0(i, c) = sg.VT(null_idx[c], i);
+
+    // global constant hat vector
+    std::vector<double> ones(n_src, 1.0);
+    std::vector<double> hat1 = matvec(sel_l_t(x_ops, 1), ones);
+    std::vector<double> cglob(size_t(N), 0.0);
+    for (int e = 0; e < E; ++e)
+        for (int i = 0; i < n_src; ++i) cglob[size_t(e) * n_src + i] = hat1[i];
+    const double cn = vec_norm(cglob);
+    for (double& v : cglob) v /= cn;
+    std::cout << "||Dg c||/||c|| (constant in null?) = "
+              << fmt(vec_norm(matvec(Dg, cglob))) << "\n";
+
+    // parasitic basis: null minus constant direction
+    ElasticMatrix N1 = N0;
+    for (size_t c = 0; c < N1.cols(); ++c) {
+        double d = 0;
+        for (size_t i = 0; i < N1.rows(); ++i) d += cglob[i] * N1(i, c);
+        for (size_t i = 0; i < N1.rows(); ++i) N1(i, c) -= d * cglob[i];
+    }
+    ElasticMatrix Qpar = orth(N1, 1e-8);
+    std::cout << "dim parasitic (null minus constant) = " << Qpar.cols() << "\n";
+
+    // ---- (2) identity: divergence output orthogonal to parasitic null ------
+    {
+        std::mt19937 rng(12345);
+        std::normal_distribution<double> g(0.0, 1.0);
+        double worst = 0;
+        for (int trial = 0; trial < 20; ++trial) {
+            std::vector<double> w(Dd.cols());
+            for (double& v : w) v = g(rng);
+            const std::vector<double> d = matvec(Dd, w);
+            std::vector<double> proj(Qpar.cols(), 0.0);
+            for (size_t c = 0; c < Qpar.cols(); ++c)
+                for (size_t i = 0; i < Qpar.rows(); ++i)
+                    proj[c] += Qpar(i, c) * d[i];
+            worst = std::max(worst, vec_norm(proj) / vec_norm(d));
+        }
+        std::cout << "max ||Qpar^T (Dd w)|| / ||Dd w|| over 20 random w = "
+                  << fmt(worst) << "\n";
+        // constant component of Dd w
+        std::mt19937 rng2(999);
+        std::vector<double> w(Dd.cols());
+        for (double& v : w) v = g(rng2);
+        const std::vector<double> d = matvec(Dd, w);
+        double dc = 0;
+        for (size_t i = 0; i < d.size(); ++i) dc += cglob[i] * d[i];
+        std::cout << "|c^T (Dd w)| / ||Dd w|| = " << fmt(std::abs(dc) / vec_norm(d)) << "\n";
+    }
+
+    // ---- (3) decoupling of the composite M = Dd Dg --------------------------
+    {
+        ElasticMatrix M = matmul(Dd, Dg);  // 96x96
+        ElasticMatrix MQ(M.rows(), Qpar.cols());
+        for (size_t c = 0; c < Qpar.cols(); ++c) {
+            std::vector<double> q(Qpar.rows());
+            for (size_t i = 0; i < Qpar.rows(); ++i) q[i] = Qpar(i, c);
+            const std::vector<double> mq = matvec(M, q);
+            for (size_t i = 0; i < M.rows(); ++i) MQ(i, c) = mq[i];
+        }
+        ElasticMatrix QtM = mat_mul_t_left(Qpar, M);
+        std::cout << "||M Qpar||F / ||M||F = " << fmt(fro_norm(MQ) / fro_norm(M))
+                  << "   ||Qpar^T M||F / ||M||F = " << fmt(fro_norm(QtM) / fro_norm(M)) << "\n";
+    }
+
+    // ---- (4) coefficient-variation coupling --------------------------------
+    {
+        // non-null orthonormal complement Z (within constant^perp as well)
+        ElasticMatrix Zb(size_t(N), size_t(N) - Qpar.cols() - 1);
+        // build complement via projection of identity then orth
+        // P_perp = I - Qpar Qpar^T - c c^T
+        ElasticMatrix Pp{size_t(N), size_t(N)};
+        for (size_t i = 0; i < size_t(N); ++i) Pp(i, i) = 1.0;
+        for (size_t j = 0; j < size_t(N); ++j) {
+            for (size_t c = 0; c < Qpar.cols(); ++c) {
+                const double q = Qpar(j, c);
+                for (size_t i = 0; i < size_t(N); ++i) Pp(i, j) -= Qpar(i, c) * q;
+            }
+            for (size_t i = 0; i < size_t(N); ++i) Pp(i, j) -= cglob[i] * cglob[j];
+        }
+        ElasticMatrix Z = orth(Pp, 1e-8);
+        auto coupling = [&](const std::function<double(double)>& cf) {
+            // diag in hat space is not pointwise multiplication of the field,
+            // but the production code multiplies pointwise in hat space
+            // (assemble_acceleration, stress pullback), so model exactly that.
+            ElasticMatrix Dg2(size_t(N), Z.cols());
+            for (size_t c = 0; c < Z.cols(); ++c)
+                for (int e = 0; e < E; ++e)
+                    for (int i = 0; i < n_src; ++i) {
+                        const size_t idx = size_t(e) * n_src + i;
+                        const double xg = (double(e) + double(i) / (n_src - 1)) / E;
+                        Dg2(idx, c) = cf(xg) * Z(idx, c);
+                    }
+            ElasticMatrix QtCZ = mat_mul_t_left(Qpar, Dg2);
+            Svd s = svd_full(QtCZ);
+            return s.s[0];
+        };
+        std::cout << "sigma_max(Qpar^T diag(c) Z): c=1: "
+                  << fmt(coupling([](double) { return 1.0; }))
+                  << "   c=1+x (global ramp): "
+                  << fmt(coupling([](double x) { return 1.0 + x; }))
+                  << "   c=1+0.5sin(2pi x): "
+                  << fmt(coupling([](double x) { return 1.0 + 0.5 * std::sin(2 * M_PI * x); }))
+                  << "\n";
+    }
+
+    // ---- (5) locality of the parasitic space + per-element template --------
+    ElasticMatrix Qt;  // template span, used later
+    {
+        // restriction of Qpar to each element block: R_e (n_src x dim)
+        double sig1_min = 2, sig1_max = -1;
+        std::vector<double> tmpl(n_src, 0.0);
+        for (int e = 0; e < E; ++e) {
+            ElasticMatrix Re(size_t(n_src), Qpar.cols());
+            for (size_t c = 0; c < Qpar.cols(); ++c)
+                for (int i = 0; i < n_src; ++i)
+                    Re(size_t(i), c) = Qpar(size_t(e) * n_src + i, c);
+            Svd s = svd_full(Re);
+            sig1_min = std::min(sig1_min, s.s[0]);
+            sig1_max = std::max(sig1_max, s.s[0]);
+            if (e == E / 2) {
+                for (int i = 0; i < n_src; ++i) tmpl[size_t(i)] = s.U(size_t(i), 0);
+                std::cout << "second/sigma1 at middle element (1-D local rank?): "
+                          << fmt(s.s[1] / s.s[0]) << "\n";
+            }
+        }
+        std::cout << "sigma1(R_e) over elements: min = " << fmt(sig1_min)
+                  << " max = " << fmt(sig1_max)
+                  << "  (||local part|| of best per-element direction)\n";
+
+        // physical profile of the template
+        std::vector<double> bsp = matvec(sel_invl_t(x_ops, 1), tmpl);
+        std::vector<double> phys = matvec(sel_eval_t(x_ops, 1), bsp);
+        std::cout << "template hat  profile = [";
+        for (int i = 0; i < n_src; ++i) std::cout << (i ? ", " : "") << fmt(tmpl[size_t(i)]);
+        std::cout << "]\n";
+        std::cout << "template phys profile = [";
+        for (int i = 0; i < n_src; ++i) std::cout << (i ? ", " : "") << fmt(phys[size_t(i)]);
+        std::cout << "]\n";
+
+        // template purity: how much of t_e lies in the true parasitic space
+        double pur_min = 2, pur_max = -1;
+        ElasticMatrix T{size_t(N), size_t(E)};
+        for (int e = 0; e < E; ++e) {
+            std::vector<double> t(size_t(N), 0.0);
+            for (int i = 0; i < n_src; ++i) t[size_t(e) * n_src + i] = tmpl[size_t(i)];
+            const double tn = vec_norm(t);
+            std::vector<double> proj(Qpar.cols(), 0.0);
+            for (size_t c = 0; c < Qpar.cols(); ++c)
+                for (size_t i = 0; i < size_t(N); ++i) proj[c] += Qpar(i, c) * t[i];
+            const double purity = vec_norm(proj) / tn;
+            pur_min = std::min(pur_min, purity);
+            pur_max = std::max(pur_max, purity);
+            for (size_t i = 0; i < size_t(N); ++i) T(i, size_t(e)) = t[i] / tn;
+        }
+        std::cout << "template purity ||Qpar^T t_e||/||t_e||: min = " << fmt(pur_min)
+                  << " max = " << fmt(pur_max) << "\n";
+
+        // principal angles between span(T) and span(Qpar)
+        Qt = orth(T, 1e-12);
+        ElasticMatrix C = mat_mul_t_left(Qpar, Qt);
+        Svd s = svd_full(C);
+        double cap_min = 2, cap_sum = 0;
+        for (size_t i = 0; i < s.s.size(); ++i) {
+            cap_min = std::min(cap_min, s.s[i]);
+            cap_sum += s.s[i] * s.s[i];
+        }
+        std::cout << "principal cosines span(T) vs span(Qpar): dim(T)=" << Qt.cols()
+                  << " min cos = " << fmt(cap_min)
+                  << " mean cos^2 = " << fmt(cap_sum / double(s.s.size())) << "\n";
+    }
+
+    // ---- (6) null content of smooth fields ---------------------------------
+    {
+        auto null_fraction_of = [&](const std::function<double(double)>& f,
+                                    const ElasticMatrix& Q) {
+            std::vector<double> hat(size_t(N), 0.0);
+            for (int e = 0; e < E; ++e) {
+                auto ge = [&](double xp) { return f(double(e) + xp); };
+                const std::vector<double> c = basis_coefficients(x_ops, 1, ge);
+                const std::vector<double> hl = matvec(sel_l_t(x_ops, 1), c);
+                for (int i = 0; i < n_src; ++i) hat[size_t(e) * n_src + i] = hl[size_t(i)];
+            }
+            const double hn2 = vec_norm(hat);
+            std::vector<double> proj(Q.cols(), 0.0);
+            for (size_t c = 0; c < Q.cols(); ++c)
+                for (size_t i = 0; i < size_t(N); ++i) proj[c] += Q(i, c) * hat[i];
+            const double p = vec_norm(proj);
+            return (p * p) / (hn2 * hn2);
+        };
+
+        std::cout << "smooth plane-wave null-energy fraction (cos(theta*s), theta=k*h):\n";
+        std::cout << "   PPW   theta      frac(true null)  frac(template span)\n";
+        const std::vector<double> ppws = {4, 6, 8, 12, 16, 24, 32, 48, 64};
+        double prev_f = 0, prev_th = 0;
+        for (double ppw : ppws) {
+            const double theta = 2.0 * M_PI * double(n1) / ppw;
+            auto f = [theta](double s) { return std::cos(theta * s); };
+            const double fr = null_fraction_of(f, Qpar);
+            const double frt = null_fraction_of(f, Qt);
+            double slope = 0;
+            if (prev_th > 0) slope = std::log(fr / prev_f) / std::log(theta / prev_th);
+            char buf[160];
+            std::snprintf(buf, sizeof(buf), "  %5.1f  %7.4f   %.3e (slope %5.2f)  %.3e\n",
+                          ppw, theta, fr, slope, frt);
+            std::cout << buf;
+            prev_f = fr;
+            prev_th = theta;
+        }
+        std::cout << "monomial null-energy fraction (centered s^m over chain):\n";
+        for (int m = 0; m <= 4; ++m) {
+            auto f = [m, E](double s) { return std::pow((s - 0.5 * E) / (0.5 * E), m); };
+            std::cout << "  deg " << m << ": true " << fmt(null_fraction_of(f, Qpar))
+                      << "  template " << fmt(null_fraction_of(f, Qt)) << "\n";
+        }
+    }
+
+    // ---- (6b) windowed Wannier templates ------------------------------------
+    {
+        std::cout << "sigma_max(Dg) = " << fmt(smax) << "  (spectral separation "
+                  << fmt(sg.s[sg.s.size() - null_idx.size() - 1] / smax) << ")\n";
+
+        // most-localized null vector around e0 = E/2: w = Qpar * alpha with
+        // alpha = top right singular vector of R_{e0}
+        const int e0 = E / 2;
+        ElasticMatrix Re(size_t(n_src), Qpar.cols());
+        for (size_t c = 0; c < Qpar.cols(); ++c)
+            for (int i = 0; i < n_src; ++i)
+                Re(size_t(i), c) = Qpar(size_t(e0) * n_src + i, c);
+        Svd sre = svd_full(Re);
+        std::vector<double> alpha(Qpar.cols());
+        for (size_t c = 0; c < Qpar.cols(); ++c) alpha[c] = sre.VT(0, c);
+        std::vector<double> wloc(size_t(N), 0.0);
+        for (size_t c = 0; c < Qpar.cols(); ++c)
+            for (size_t i = 0; i < size_t(N); ++i) wloc[i] += Qpar(i, c) * alpha[c];
+        const double wn = vec_norm(wloc);
+        for (double& v : wloc) v /= wn;
+        std::cout << "per-element energy of most-localized null vector (e0=8):\n  [";
+        for (int e = 0; e < E; ++e) {
+            double s2 = 0;
+            for (int i = 0; i < n_src; ++i) {
+                const double v = wloc[size_t(e) * n_src + i];
+                s2 += v * v;
+            }
+            std::cout << (e ? ", " : "") << fmt(s2);
+        }
+        std::cout << "]\n";
+
+        // truncated-Wannier templates: w_e = circular shift of wloc by (e-e0)
+        // elements (translation invariance of the periodic chain), truncated to
+        // a window of half-width Wh elements, renormalized.
+        for (int Wh = 0; Wh <= 4; ++Wh) {
+            ElasticMatrix T{size_t(N), size_t(E)};
+            double pur_min = 2;
+            for (int e = 0; e < E; ++e) {
+                std::vector<double> t(size_t(N), 0.0);
+                for (int de = -Wh; de <= Wh; ++de) {
+                    const int esrc = (e0 + de + E) % E;     // element in wloc
+                    const int edst = (e + de + E) % E;      // element in t
+                    for (int i = 0; i < n_src; ++i)
+                        t[size_t(edst) * n_src + i] = wloc[size_t(esrc) * n_src + i];
+                }
+                const double tn = vec_norm(t);
+                std::vector<double> proj(Qpar.cols(), 0.0);
+                for (size_t c = 0; c < Qpar.cols(); ++c)
+                    for (size_t i = 0; i < size_t(N); ++i) proj[c] += Qpar(i, c) * t[i];
+                pur_min = std::min(pur_min, vec_norm(proj) / tn);
+                for (size_t i = 0; i < size_t(N); ++i) T(i, size_t(e)) = t[i] / tn;
+            }
+            ElasticMatrix Qw = orth(T, 1e-12);
+            ElasticMatrix C = mat_mul_t_left(Qpar, Qw);
+            Svd s = svd_full(C);
+            double cmin = 2, csum = 0;
+            for (size_t i = 0; i < s.s.size(); ++i) {
+                cmin = std::min(cmin, s.s[i]);
+                csum += s.s[i] * s.s[i];
+            }
+            std::cout << "window half-width " << Wh << " (support " << (2 * Wh + 1)
+                      << " elems): 1-purity_min^2 = " << fmt(1.0 - pur_min * pur_min)
+                      << "  capture min cos = " << fmt(cmin)
+                      << "  mean cos^2 = " << fmt(csum / double(s.s.size()))
+                      << "\n";
+        }
+
+        // ---- missed-direction diagnostics (Wh = 4 span) ---------------------
+        {
+            const int Wh = 4;
+            ElasticMatrix T{size_t(N), size_t(E)};
+            for (int e = 0; e < E; ++e) {
+                std::vector<double> t(size_t(N), 0.0);
+                for (int de = -Wh; de <= Wh; ++de) {
+                    const int esrc = (e0 + de + E) % E;
+                    const int edst = (e + de + E) % E;
+                    for (int i = 0; i < n_src; ++i)
+                        t[size_t(edst) * n_src + i] = wloc[size_t(esrc) * n_src + i];
+                }
+                const double tn = vec_norm(t);
+                for (size_t i = 0; i < size_t(N); ++i) T(i, size_t(e)) = t[i] / tn;
+            }
+            ElasticMatrix Qw = orth(T, 1e-12);
+            ElasticMatrix C = mat_mul_t_left(Qpar, Qw);
+            Svd s = svd_full(C);
+            // smallest singular triple -> missed direction d = Qpar * u_min
+            const size_t last = s.s.size() - 1;
+            std::vector<double> d(size_t(N), 0.0);
+            for (size_t c = 0; c < Qpar.cols(); ++c)
+                for (size_t i = 0; i < size_t(N); ++i)
+                    d[i] += Qpar(i, c) * s.U(c, last);
+            std::cout << "missed direction (cos = " << fmt(s.s[last])
+                      << "): per-element energy = [";
+            for (int e = 0; e < E; ++e) {
+                double s2 = 0;
+                for (int i = 0; i < n_src; ++i) {
+                    const double v = d[size_t(e) * n_src + i];
+                    s2 += v * v;
+                }
+                std::cout << (e ? ", " : "") << fmt(s2);
+            }
+            std::cout << "]\n";
+            // alternating structure? correlate block e with block e+1
+            double dot01 = 0, n0 = 0, n1b = 0;
+            for (int i = 0; i < n_src; ++i) {
+                const double a = d[size_t(e0) * n_src + i];
+                const double b = d[size_t(e0 + 1) * n_src + i];
+                dot01 += a * b;
+                n0 += a * a;
+                n1b += b * b;
+            }
+            std::cout << "  neighbor-block correlation = " << fmt(dot01 / std::sqrt(n0 * n1b))
+                      << " (-1 => theta=pi alternating Bloch mode)\n";
+            // source deposit into the missed direction (matlab_hat source line)
+            std::vector<double> sl = matvec(x_ops.invl11, x_ops.source_basis1);
+            std::vector<double> svec(size_t(N), 0.0);
+            for (int i = 0; i < n_src; ++i) svec[size_t(e0) * n_src + i] = sl[size_t(i)];
+            const double sn2 = vec_norm(svec) * vec_norm(svec);
+            double sd = 0;
+            for (size_t i = 0; i < size_t(N); ++i) sd += d[i] * svec[i];
+            std::vector<double> spr(Qpar.cols(), 0.0);
+            for (size_t c = 0; c < Qpar.cols(); ++c)
+                for (size_t i = 0; i < size_t(N); ++i) spr[c] += Qpar(i, c) * svec[i];
+            const double tot = vec_norm(spr) * vec_norm(spr);
+            std::cout << "  source null-energy: total = " << fmt(tot / sn2)
+                      << "  in missed direction = " << fmt(sd * sd / sn2) << "\n";
+        }
+
+        // ---- rank-2-per-element truncated band-projector templates ----------
+        for (int Wh = 1; Wh <= 3; ++Wh) {
+            // local directions: project the 6 unit impulses of element e0 onto
+            // the null space, svd, keep top 2 left vectors (global), truncate.
+            ElasticMatrix Pe{size_t(N), size_t(n_src)};
+            for (int i = 0; i < n_src; ++i) {
+                std::vector<double> g(size_t(N), 0.0);
+                g[size_t(e0) * n_src + i] = 1.0;
+                for (size_t c = 0; c < Qpar.cols(); ++c) {
+                    double pc = 0;
+                    for (size_t r = 0; r < size_t(N); ++r) pc += Qpar(r, c) * g[r];
+                    for (size_t r = 0; r < size_t(N); ++r) Pe(r, size_t(i)) += Qpar(r, c) * pc;
+                }
+            }
+            Svd sp = svd_full(Pe);
+            const int rank_keep = 2;
+            ElasticMatrix T{size_t(N), size_t(E) * rank_keep};
+            double pur_min = 2;
+            for (int rk = 0; rk < rank_keep; ++rk) {
+                std::vector<double> w2(static_cast<size_t>(N), 0.0);
+                for (size_t i = 0; i < size_t(N); ++i) w2[i] = sp.U(i, size_t(rk));
+                for (int e = 0; e < E; ++e) {
+                    std::vector<double> t(size_t(N), 0.0);
+                    for (int de = -Wh; de <= Wh; ++de) {
+                        const int esrc = (e0 + de + E) % E;
+                        const int edst = (e + de + E) % E;
+                        for (int i = 0; i < n_src; ++i)
+                            t[size_t(edst) * n_src + i] = w2[size_t(esrc) * n_src + i];
+                    }
+                    const double tn = vec_norm(t);
+                    std::vector<double> proj(Qpar.cols(), 0.0);
+                    for (size_t c = 0; c < Qpar.cols(); ++c)
+                        for (size_t i = 0; i < size_t(N); ++i) proj[c] += Qpar(i, c) * t[i];
+                    pur_min = std::min(pur_min, vec_norm(proj) / tn);
+                    for (size_t i = 0; i < size_t(N); ++i)
+                        T(i, size_t(rk) * E + size_t(e)) = t[i] / tn;
+                }
+            }
+            ElasticMatrix Qw = orth(T, 1e-9);
+            ElasticMatrix C = mat_mul_t_left(Qpar, Qw);
+            Svd s = svd_full(C);
+            double cmin = 2, csum = 0;
+            size_t ncos = std::min(s.s.size(), Qpar.cols());
+            for (size_t i = 0; i < ncos; ++i) {
+                cmin = std::min(cmin, s.s[i]);
+                csum += s.s[i] * s.s[i];
+            }
+            std::cout << "rank-2 templates, Wh=" << Wh << ": span dim = " << Qw.cols()
+                      << "  1-purity_min^2 = " << fmt(1.0 - pur_min * pur_min)
+                      << "  capture min cos = " << fmt(cmin)
+                      << "  mean cos^2 = " << fmt(csum / double(ncos)) << "\n";
+        }
+    }
+
+    // ---- (6c) banded truncation of the exact band projector ----------------
+    ElasticMatrix Pband{size_t(N), size_t(N)};
+    for (size_t c = 0; c < Qpar.cols(); ++c)
+        for (size_t j = 0; j < size_t(N); ++j) {
+            const double q = Qpar(j, c);
+            for (size_t i = 0; i < size_t(N); ++i) Pband(i, j) += Qpar(i, c) * q;
+        }
+    {
+        // source vector for the removal test
+        std::vector<double> sl = matvec(x_ops.invl11, x_ops.source_basis1);
+        std::vector<double> svec(size_t(N), 0.0);
+        for (int i = 0; i < n_src; ++i) svec[size_t(E / 2) * n_src + i] = sl[size_t(i)];
+        const std::vector<double> Ps = matvec(Pband, svec);
+
+        for (int Wh = 0; Wh <= 4; ++Wh) {
+            ElasticMatrix B = Pband;
+            for (size_t j = 0; j < size_t(N); ++j)
+                for (size_t i = 0; i < size_t(N); ++i) {
+                    const int ei = int(i) / n_src, ej = int(j) / n_src;
+                    const int dc = std::min((ei - ej + E) % E, (ej - ei + E) % E);
+                    if (dc > Wh) B(i, j) = 0.0;
+                }
+            ElasticMatrix Diff = B;
+            for (size_t j = 0; j < size_t(N); ++j)
+                for (size_t i = 0; i < size_t(N); ++i) Diff(i, j) -= Pband(i, j);
+            Svd sd2 = svd_full(Diff);
+            const std::vector<double> Bs = matvec(B, svec);
+            double rs = 0, pn = 0;
+            for (size_t i = 0; i < size_t(N); ++i) {
+                const double dv = Bs[i] - Ps[i];
+                rs += dv * dv;
+                pn += Ps[i] * Ps[i];
+            }
+            std::cout << "banded projector Wh=" << Wh
+                      << ": ||B - P||_2 = " << fmt(sd2.s[0])
+                      << "   source-deposit removal residual = " << fmt(std::sqrt(rs / pn))
+                      << "\n";
+        }
+    }
+
+    // ---- (7) bounded chain --------------------------------------------------
+    {
+        const ElasticMatrix Dgb = build_chain_stage_matrix(
+            true, GridTag::G121, cfg, ops, E, 0.5, 0.0, false);
+        Svd s = svd_full(Dgb);
+        const double sm = s.s[0];
+        std::vector<size_t> nidx;
+        for (size_t i = 0; i < size_t(N); ++i) {
+            const double sv = i < s.s.size() ? s.s[i] : 0.0;
+            if (sv < 1e-10 * sm) nidx.push_back(i);
+        }
+        std::cout << "bounded chain (alpha_bd=0): null dim(Dg fam1) = " << nidx.size()
+                  << "  sigma_min(non-null) = "
+                  << fmt(s.s[s.s.size() - nidx.size() - 1]) << "\n";
+        // is the constant in the bounded null space?
+        std::vector<double> cg(cglob);
+        std::cout << "  ||Dg_b c||/||c|| = " << fmt(vec_norm(matvec(Dgb, cg))) << "\n";
+        ElasticMatrix Nb(size_t(N), nidx.size());
+        for (size_t c = 0; c < nidx.size(); ++c)
+            for (size_t i = 0; i < size_t(N); ++i)
+                Nb(i, c) = s.VT(nidx[c], i);
+        // remove constant if present
+        for (size_t c = 0; c < Nb.cols(); ++c) {
+            double d = 0;
+            for (size_t i = 0; i < Nb.rows(); ++i) d += cg[i] * Nb(i, c);
+            for (size_t i = 0; i < Nb.rows(); ++i) Nb(i, c) -= d * cg[i];
+        }
+        ElasticMatrix Qb = orth(Nb, 1e-8);
+        std::cout << "  dim parasitic (bounded, minus constant) = " << Qb.cols() << "\n";
+        // capture of the bounded parasitic space by the interior-template span
+        ElasticMatrix C = mat_mul_t_left(Qb, Qt);
+        Svd sc = svd_full(C);
+        double cmin = 2, csum = 0;
+        for (size_t i = 0; i < sc.s.size(); ++i) {
+            cmin = std::min(cmin, sc.s[i]);
+            csum += sc.s[i] * sc.s[i];
+        }
+        std::cout << "  principal cosines (bounded null vs interior-template span): min = "
+                  << fmt(cmin) << " mean cos^2 = " << fmt(csum / double(sc.s.size())) << "\n";
+        // per-element sigma1 incl. boundary elements
+        double sig_first = 0, sig_last = 0, sig_mid = 0;
+        for (int e : {0, E / 2, E - 1}) {
+            ElasticMatrix Re(size_t(n_src), Qb.cols());
+            for (size_t c = 0; c < Qb.cols(); ++c)
+                for (int i = 0; i < n_src; ++i)
+                    Re(size_t(i), c) = Qb(size_t(e) * n_src + i, c);
+            Svd sr = svd_full(Re);
+            if (e == 0) sig_first = sr.s[0];
+            else if (e == E / 2) sig_mid = sr.s[0];
+            else sig_last = sr.s[0];
+        }
+        std::cout << "  sigma1(R_e) bounded: e=0: " << fmt(sig_first)
+                  << "  e=mid: " << fmt(sig_mid) << "  e=last: " << fmt(sig_last) << "\n";
+        // identity on bounded chain too
+        const ElasticMatrix Ddb = build_chain_stage_matrix(
+            false, GridTag::G221, cfg, ops, E, 0.5, 0.0, false);
+        std::mt19937 rng(777);
+        std::normal_distribution<double> g(0.0, 1.0);
+        double worst = 0;
+        for (int trial = 0; trial < 20; ++trial) {
+            std::vector<double> w(Ddb.cols());
+            for (double& v : w) v = g(rng);
+            const std::vector<double> d = matvec(Ddb, w);
+            std::vector<double> proj(Qb.cols(), 0.0);
+            for (size_t c = 0; c < Qb.cols(); ++c)
+                for (size_t i = 0; i < Qb.rows(); ++i) proj[c] += Qb(i, c) * d[i];
+            worst = std::max(worst, vec_norm(proj) / vec_norm(d));
+        }
+        std::cout << "  bounded: max ||Qb^T (Dd_b w)||/||Dd_b w|| = " << fmt(worst) << "\n";
+
+        // bounded band projector vs periodic one: interior + boundary deviation
+        ElasticMatrix Pb{size_t(N), size_t(N)};
+        for (size_t c = 0; c < Qb.cols(); ++c)
+            for (size_t j = 0; j < size_t(N); ++j) {
+                const double q = Qb(j, c);
+                for (size_t i = 0; i < size_t(N); ++i) Pb(i, j) += Qb(i, c) * q;
+            }
+        double dev_int = 0, dev_bd = 0;
+        for (size_t j = 0; j < size_t(N); ++j)
+            for (size_t i = 0; i < size_t(N); ++i) {
+                const int ei = int(i) / n_src, ej = int(j) / n_src;
+                const double dv = std::abs(Pb(i, j) - Pband(i, j));
+                if (ei >= 4 && ei <= 11 && ej >= 4 && ej <= 11) dev_int = std::max(dev_int, dv);
+                if (ei <= 1 || ei >= E - 2 || ej <= 1 || ej >= E - 2) dev_bd = std::max(dev_bd, dv);
+            }
+        std::cout << "  |P_bounded - P_periodic| max entry: interior(e 4..11) = "
+                  << fmt(dev_int) << "   boundary(e 0,1,14,15) = " << fmt(dev_bd) << "\n";
+    }
+
+    return 0;
+}
