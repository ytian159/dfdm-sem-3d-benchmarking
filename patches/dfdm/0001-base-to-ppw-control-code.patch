+bool fixed_axis_triplet_available(Axis3D axis,
+                                  const PrecomposedAxisKernel1D& kernel,
+                                  bool additive) {
+    if (axis == Axis3D::X) {
+        return additive ? kernel.fns.xline_triplet_add != nullptr
