+// Boundary-face extraction dots (SAT populate / MPI face pack), keyed on the
+// source line length. Same canonical FP order; same null-fns fallback.
+struct FixedFaceKernelFns {
+    using XdotFn = void (*)(const double* row, const double* in, double* out,
+                            std::size_t n_lines);
+    using BundleFn = void (*)(const double* row, const double* in, double* out,
+                              std::size_t bundle, std::size_t in_cs,
+                              std::size_t n_slices, std::size_t in_ss,
+                              std::size_t out_ss);
+    XdotFn xdot = nullptr;
+    BundleFn bundle = nullptr;
+};
+
+FixedFaceKernelFns lookup_fixed_face_kernels(int n_src);
+
+}  // namespace axis_kernels_fixed
