@@ -0,0 +1,71 @@
+#include "axis_kernels_fixed.h"
+
+namespace axis_kernels_fixed {
+
+namespace {
+
+template <int NS, int NT>
+FixedAxisKernelFns make_fns() {
+    FixedAxisKernelFns fns;
+    fns.xline = &apply_xline<NS, NT>;
+    fns.bundle = &apply_bundle<NS, NT>;
+    fns.xline_add = &apply_xline_add<NS, NT>;
+    fns.bundle_add = &apply_bundle_add<NS, NT>;
+    fns.bundle_pairt = &apply_bundle_pairt<NS, NT>;
+    fns.bundle_add_pairt = &apply_bundle_add_pairt<NS, NT>;
+    fns.xline_triplet = &apply_xline_triplet<NS, NT>;
+    fns.bundle_triplet = &apply_bundle_triplet<NS, NT>;
+    fns.xline_triplet_add = &apply_xline_triplet_add<NS, NT>;
+    fns.bundle_triplet_add = &apply_bundle_triplet_add<NS, NT>;
+    fns.xline_sat = &apply_xline_sat<NS, NT>;
+    fns.bundle_sat = &apply_bundle_sat<NS, NT>;
+    fns.xline_triplet_sat = &apply_xline_triplet_sat<NS, NT>;
+    fns.bundle_triplet_sat = &apply_bundle_triplet_sat<NS, NT>;
+    return fns;
+}
+
+template <int NS>
+FixedFaceKernelFns make_face_fns() {
+    FixedFaceKernelFns fns;
+    fns.xdot = &extract_face_xdot<NS>;
+    fns.bundle = &extract_face_bundle<NS>;
+    return fns;
+}
+
+}  // namespace
+
+FixedAxisKernelFns lookup_fixed_axis_kernels(int n_src, int n_tgt) {
+    switch (n_src * 100 + n_tgt) {
+    case 506: return make_fns<5, 6>();
+    case 605: return make_fns<6, 5>();
+    case 607: return make_fns<6, 7>();
+    case 706: return make_fns<7, 6>();
+    case 708: return make_fns<7, 8>();
+    case 807: return make_fns<8, 7>();
+    case 809: return make_fns<8, 9>();
+    case 908: return make_fns<9, 8>();
+    case 910: return make_fns<9, 10>();
+    case 1009: return make_fns<10, 9>();
+    case 1011: return make_fns<10, 11>();
+    case 1110: return make_fns<11, 10>();
+    case 1112: return make_fns<11, 12>();
+    case 1211: return make_fns<12, 11>();
+    default: return FixedAxisKernelFns{};
+    }
+}
+
+FixedFaceKernelFns lookup_fixed_face_kernels(int n_src) {
+    switch (n_src) {
+    case 5: return make_face_fns<5>();
+    case 6: return make_face_fns<6>();
+    case 7: return make_face_fns<7>();
+    case 8: return make_face_fns<8>();
+    case 9: return make_face_fns<9>();
+    case 10: return make_face_fns<10>();
+    case 11: return make_face_fns<11>();
+    case 12: return make_face_fns<12>();
+    default: return FixedFaceKernelFns{};
+    }
+}
+
+}  // namespace axis_kernels_fixed
diff --git a/src/axis_kernels_fixed.h b/src/axis_kernels_fixed.h
new file mode 100644
index 0000000..1c6870a
--- /dev/null
+++ b/src/axis_kernels_fixed.h
@@ -0,0 +1,1025 @@
+#pragma once
+
+// Fixed-size (compile-time NS x NT) axis kernels for the precomposed
+// reference-derivative khat application (docs/kernel_throughput_designs_2026-06.md, K2).
+//
+// Canonical FP order (identical in every form, and the contract for all
+// later phases): for each output value, one accumulator, source index s
+// ascending, first term a plain multiply, every later term a fused
+// multiply-add (-ffp-contract is pinned in CMakeLists.txt so contraction is
+// build-stable). Vectorization happens only ACROSS independent outputs
+// (the t dimension in the X-line form, the contiguous bundle dimension in
+// the Y/Z bundle form), never inside a single dot product, so results are
+// invariant to thread count and rank decomposition by construction.
+//
+// K is the column-major NT x NS khat matrix (ElasticMatrix layout).
+
+#include <cstddef>
+
+namespace axis_kernels_fixed {
+
+// X-line form: the operated axis is the contiguous (x) dimension.
+// in  = n_lines lines of NS contiguous values
+// out = n_lines lines of NT contiguous values
+template <int NS, int NT>
+void apply_xline(const double* __restrict K,
+                 const double* __restrict in,
+                 double* __restrict out,
+                 std::size_t n_lines) {
+    for (std::size_t l = 0; l < n_lines; ++l) {
+        const double* __restrict s = in + l * static_cast<std::size_t>(NS);
+        double* __restrict d = out + l * static_cast<std::size_t>(NT);
+        double acc[NT];
+        const double s0 = s[0];
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            acc[t] = K[t] * s0;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double sv = s[c];
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                acc[t] += K[t + c * NT] * sv;
+            }
+        }
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            d[t] = acc[t];
+        }
+    }
+}
+
+// Bundle form (Y and Z axes): the operated axis is strided; vectorize across
+// the contiguous bundle (x for Y-axis, x*y for Z-axis).
+//   out[i + t*out_cs + z*out_ss] =
+//       sum_s K[t + s*NT] * in[i + s*in_cs + z*in_ss],  i in [0, bundle)
+// Y axis: bundle = nx, in_cs = out_cs = nx, n_slices = nz,
+//         in_ss = nx*NS, out_ss = nx*NT.
+// Z axis: bundle = nx*ny, in_cs = out_cs = nx*ny, n_slices = 1.
+template <int NS, int NT>
+void apply_bundle(const double* __restrict K,
+                  const double* __restrict in,
+                  double* __restrict out,
+                  std::size_t bundle,
+                  std::size_t in_cs,
+                  std::size_t out_cs,
+                  std::size_t n_slices,
+                  std::size_t in_ss,
+                  std::size_t out_ss) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict ins = in + z * in_ss;
+        double* __restrict outs = out + z * out_ss;
+        for (int t = 0; t < NT; ++t) {
+            double* __restrict d = outs + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            const double* __restrict s0 = ins;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d[i] = k0 * s0[i];
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double kv = K[t + s * NT];
+                const double* __restrict src = ins + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d[i] += kv * src[i];
+                }
+            }
+        }
+    }
+}
+
+
+template <int NS, int NT>
+void apply_xline_add(const double* __restrict K,
+                     const double* __restrict in,
+                     double* __restrict out,
+                     std::size_t n_lines) {
+    for (std::size_t l = 0; l < n_lines; ++l) {
+        const double* __restrict s = in + l * static_cast<std::size_t>(NS);
+        double* __restrict d = out + l * static_cast<std::size_t>(NT);
+        double acc[NT];
+        const double s0 = s[0];
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            acc[t] = K[t] * s0;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double sv = s[c];
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                acc[t] += K[t + c * NT] * sv;
+            }
+        }
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            d[t] += acc[t];
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_bundle_add(const double* __restrict K,
+                      const double* __restrict in,
+                      double* __restrict out,
+                      std::size_t bundle,
+                      std::size_t in_cs,
+                      std::size_t out_cs,
+                      std::size_t n_slices,
+                      std::size_t in_ss,
+                      std::size_t out_ss) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict ins = in + z * in_ss;
+        double* __restrict outs = out + z * out_ss;
+        for (int t = 0; t < NT; ++t) {
+            double* __restrict d = outs + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            const double* __restrict s0 = ins;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d[i] += k0 * s0[i];
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double kv = K[t + s * NT];
+                const double* __restrict src = ins + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d[i] += kv * src[i];
+                }
+            }
+        }
+    }
+}
+
+
+template <int NS, int NT>
+void apply_bundle_pairt(const double* __restrict K,
+                        const double* __restrict in,
+                        double* __restrict out,
+                        std::size_t bundle,
+                        std::size_t in_cs,
+                        std::size_t out_cs,
+                        std::size_t n_slices,
+                        std::size_t in_ss,
+                        std::size_t out_ss) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict ins = in + z * in_ss;
+        double* __restrict outs = out + z * out_ss;
+        int t = 0;
+        for (; t + 1 < NT; t += 2) {
+            double* __restrict d0 = outs + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d1 = outs + static_cast<std::size_t>(t + 1) * out_cs;
+            const double k00 = K[t];
+            const double k10 = K[t + 1];
+            const double* __restrict s0 = ins;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                const double v = s0[i];
+                d0[i] = k00 * v;
+                d1[i] = k10 * v;
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double k0 = K[t + s * NT];
+                const double k1 = K[t + 1 + s * NT];
+                const double* __restrict src = ins + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    const double v = src[i];
+                    d0[i] += k0 * v;
+                    d1[i] += k1 * v;
+                }
+            }
+        }
+        if (t < NT) {
+            double* __restrict d = outs + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            const double* __restrict s0 = ins;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d[i] = k0 * s0[i];
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double kv = K[t + s * NT];
+                const double* __restrict src = ins + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d[i] += kv * src[i];
+                }
+            }
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_bundle_add_pairt(const double* __restrict K,
+                            const double* __restrict in,
+                            double* __restrict out,
+                            std::size_t bundle,
+                            std::size_t in_cs,
+                            std::size_t out_cs,
+                            std::size_t n_slices,
+                            std::size_t in_ss,
+                            std::size_t out_ss) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict ins = in + z * in_ss;
+        double* __restrict outs = out + z * out_ss;
+        int t = 0;
+        for (; t + 1 < NT; t += 2) {
+            double* __restrict d0 = outs + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d1 = outs + static_cast<std::size_t>(t + 1) * out_cs;
+            const double k00 = K[t];
+            const double k10 = K[t + 1];
+            const double* __restrict s0 = ins;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                const double v = s0[i];
+                d0[i] += k00 * v;
+                d1[i] += k10 * v;
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double k0 = K[t + s * NT];
+                const double k1 = K[t + 1 + s * NT];
+                const double* __restrict src = ins + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    const double v = src[i];
+                    d0[i] += k0 * v;
+                    d1[i] += k1 * v;
+                }
+            }
+        }
+        if (t < NT) {
+            double* __restrict d = outs + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            const double* __restrict s0 = ins;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d[i] += k0 * s0[i];
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double kv = K[t + s * NT];
+                const double* __restrict src = ins + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d[i] += kv * src[i];
+                }
+            }
+        }
+    }
+}
+
+
+template <int NS, int NT>
+void apply_xline_triplet(const double* __restrict K,
+                         const double* __restrict in0,
+                         const double* __restrict in1,
+                         const double* __restrict in2,
+                         double* __restrict out0,
+                         double* __restrict out1,
+                         double* __restrict out2,
+                         std::size_t n_lines) {
+    for (std::size_t l = 0; l < n_lines; ++l) {
+        const double* __restrict s0 = in0 + l * static_cast<std::size_t>(NS);
+        const double* __restrict s1 = in1 + l * static_cast<std::size_t>(NS);
+        const double* __restrict s2 = in2 + l * static_cast<std::size_t>(NS);
+        double* __restrict d0 = out0 + l * static_cast<std::size_t>(NT);
+        double* __restrict d1 = out1 + l * static_cast<std::size_t>(NT);
+        double* __restrict d2 = out2 + l * static_cast<std::size_t>(NT);
+        double acc0[NT];
+        double acc1[NT];
+        double acc2[NT];
+        const double v00 = s0[0];
+        const double v10 = s1[0];
+        const double v20 = s2[0];
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            const double kt = K[t];
+            acc0[t] = kt * v00;
+            acc1[t] = kt * v10;
+            acc2[t] = kt * v20;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double v0 = s0[c];
+            const double v1 = s1[c];
+            const double v2 = s2[c];
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                const double kt = K[t + c * NT];
+                acc0[t] += kt * v0;
+                acc1[t] += kt * v1;
+                acc2[t] += kt * v2;
+            }
+        }
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            d0[t] = acc0[t];
+            d1[t] = acc1[t];
+            d2[t] = acc2[t];
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_bundle_triplet(const double* __restrict K,
+                          const double* __restrict in0,
+                          const double* __restrict in1,
+                          const double* __restrict in2,
+                          double* __restrict out0,
+                          double* __restrict out1,
+                          double* __restrict out2,
+                          std::size_t bundle,
+                          std::size_t in_cs,
+                          std::size_t out_cs,
+                          std::size_t n_slices,
+                          std::size_t in_ss,
+                          std::size_t out_ss) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict in0s = in0 + z * in_ss;
+        const double* __restrict in1s = in1 + z * in_ss;
+        const double* __restrict in2s = in2 + z * in_ss;
+        double* __restrict out0s = out0 + z * out_ss;
+        double* __restrict out1s = out1 + z * out_ss;
+        double* __restrict out2s = out2 + z * out_ss;
+        for (int t = 0; t < NT; ++t) {
+            double* __restrict d0 = out0s + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d1 = out1s + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d2 = out2s + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            const double* __restrict s00 = in0s;
+            const double* __restrict s10 = in1s;
+            const double* __restrict s20 = in2s;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d0[i] = k0 * s00[i];
+                d1[i] = k0 * s10[i];
+                d2[i] = k0 * s20[i];
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double kv = K[t + s * NT];
+                const double* __restrict src0 = in0s + static_cast<std::size_t>(s) * in_cs;
+                const double* __restrict src1 = in1s + static_cast<std::size_t>(s) * in_cs;
+                const double* __restrict src2 = in2s + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d0[i] += kv * src0[i];
+                    d1[i] += kv * src1[i];
+                    d2[i] += kv * src2[i];
+                }
+            }
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_xline_triplet_add(const double* __restrict K,
+                             const double* __restrict in0,
+                             const double* __restrict in1,
+                             const double* __restrict in2,
+                             double* __restrict out0,
+                             double* __restrict out1,
+                             double* __restrict out2,
+                             std::size_t n_lines) {
+    for (std::size_t l = 0; l < n_lines; ++l) {
+        const double* __restrict s0 = in0 + l * static_cast<std::size_t>(NS);
+        const double* __restrict s1 = in1 + l * static_cast<std::size_t>(NS);
+        const double* __restrict s2 = in2 + l * static_cast<std::size_t>(NS);
+        double* __restrict d0 = out0 + l * static_cast<std::size_t>(NT);
+        double* __restrict d1 = out1 + l * static_cast<std::size_t>(NT);
+        double* __restrict d2 = out2 + l * static_cast<std::size_t>(NT);
+        double acc0[NT];
+        double acc1[NT];
+        double acc2[NT];
+        const double v00 = s0[0];
+        const double v10 = s1[0];
+        const double v20 = s2[0];
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            const double kt = K[t];
+            acc0[t] = kt * v00;
+            acc1[t] = kt * v10;
+            acc2[t] = kt * v20;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double v0 = s0[c];
+            const double v1 = s1[c];
+            const double v2 = s2[c];
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                const double kt = K[t + c * NT];
+                acc0[t] += kt * v0;
+                acc1[t] += kt * v1;
+                acc2[t] += kt * v2;
+            }
+        }
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            d0[t] += acc0[t];
+            d1[t] += acc1[t];
+            d2[t] += acc2[t];
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_bundle_triplet_add(const double* __restrict K,
+                              const double* __restrict in0,
+                              const double* __restrict in1,
+                              const double* __restrict in2,
+                              double* __restrict out0,
+                              double* __restrict out1,
+                              double* __restrict out2,
+                              std::size_t bundle,
+                              std::size_t in_cs,
+                              std::size_t out_cs,
+                              std::size_t n_slices,
+                              std::size_t in_ss,
+                              std::size_t out_ss) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict in0s = in0 + z * in_ss;
+        const double* __restrict in1s = in1 + z * in_ss;
+        const double* __restrict in2s = in2 + z * in_ss;
+        double* __restrict out0s = out0 + z * out_ss;
+        double* __restrict out1s = out1 + z * out_ss;
+        double* __restrict out2s = out2 + z * out_ss;
+        for (int t = 0; t < NT; ++t) {
+            double* __restrict d0 = out0s + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d1 = out1s + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d2 = out2s + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            const double* __restrict s00 = in0s;
+            const double* __restrict s10 = in1s;
+            const double* __restrict s20 = in2s;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d0[i] += k0 * s00[i];
+                d1[i] += k0 * s10[i];
+                d2[i] += k0 * s20[i];
+            }
+            for (int s = 1; s < NS; ++s) {
+                const double kv = K[t + s * NT];
+                const double* __restrict src0 = in0s + static_cast<std::size_t>(s) * in_cs;
+                const double* __restrict src1 = in1s + static_cast<std::size_t>(s) * in_cs;
+                const double* __restrict src2 = in2s + static_cast<std::size_t>(s) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d0[i] += kv * src0[i];
+                    d1[i] += kv * src1[i];
+                    d2[i] += kv * src2[i];
+                }
+            }
+        }
+    }
+}
