+// Full filter pass over all three axes. The per-axis omp-for barriers order
+// the passes; axis projectors act on disjoint tensor slots and commute, so
+// the application order does not matter.
+void apply_r2_null_filter_pass(SerialPhase1Domain3D& domain) {
+    apply_r2_null_filter_axis_pass(domain, Axis3D::X);
+    apply_r2_null_filter_axis_pass(domain, Axis3D::Y);
+    apply_r2_null_filter_axis_pass(domain, Axis3D::Z);
+}
+
+bool r2_null_filter_due(const R2NullFilter3D& filter, int it) {
+    return filter.enabled && ((it + 1) % filter.interval == 0);
+}
