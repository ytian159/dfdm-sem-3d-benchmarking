+// k1_axis_kernel_bench.cpp
+//
+// TASK K1: measure the cost structure of the production n=6/porder=4
+// precomposed axis-kernel path.
+//
+//  (a) current apply path: LibSci cblas_dgemm with the exact call shapes of
+//      apply_matrix_{x,y,z}_into (X: one NoTrans/NoTrans gemm; Y: one
+//      NoTrans/Trans gemm PER Z-SLICE; Z: one NoTrans/Trans gemm), plus the
+//      production rank-1 SAT face corrections.
+//  (b) hand-rolled fixed-size kernels (compile-time dims, restrict +
+//      omp simd), same layouts including the strided y/z cases.
+//  (c) fused full-component sweep (12 applications per displacement
+//      component, no per-call dispatch), with and without SAT.
+//  Plus: the SAT-populate face-extraction probe (m=1 dgemm vs fixed dot).
+//
+// Regimes: HOT (single element, cache resident) and STREAM (large element
+// pool, DRAM streaming). Single thread by default; honors OMP_NUM_THREADS=1.
+//
+// Build (login node, PrgEnv-gnu; LibSci linked by the CC wrapper):
+//   CC -O3 -DNDEBUG -fopenmp -march=znver3 -Isrc -Itoml11 \
+//      src/tools/k1_axis_kernel_bench.cpp src/elastic3d.cpp \
+//      src/config_toml3d.cpp src/cds_matrix.cpp src/bspline.cpp src/basis.cpp \
+//      src/inner_product.cpp src/matrix_util.cpp src/setup_bases.cpp \
+//      src/elastic_matrix.cpp -o build_audit/k1_axis_kernel_bench
+
+#include <cblas.h>
+
+#include "elastic3d.h"
+
+#include <chrono>
+#include <cmath>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <random>
+#include <string>
+#include <vector>
+
+namespace {
+
+using Clock = std::chrono::steady_clock;
+
+double now_s() {
+    return std::chrono::duration<double>(Clock::now().time_since_epoch()).count();
+}
+
+// ---------------------------------------------------------------------------
+// Shape table: the 12 applications of one stage-1 component sweep at n=6.
+// (stage-2 has the identical shape multiset, so all per-sweep numbers x6
+// give the full element-step: 3 components + 3 equations.)
+// Source tags: G211(5,6,6) G121(6,5,6) G112(6,6,5) G222(5,5,5).
+// axis: 0=x,1=y,2=z. family = digit of source tag along axis.
+struct AppShape {
+    const char* name;
+    int axis;        // 0,1,2
+    int family;      // source family (1 -> khat is 5x6, 2 -> khat is 6x5)
+    int sx, sy, sz;  // source dims
+    int tx, ty, tz;  // target dims
+};
+
+constexpr AppShape kSweep[12] = {
+    // tag G211 (5,6,6)
+    {"G211.x 6x5@36", 0, 2, 5, 6, 6, 6, 6, 6},
+    {"G211.y 5x6@30", 1, 1, 5, 6, 6, 5, 5, 6},
+    {"G211.z 5x6@30", 2, 1, 5, 6, 6, 5, 6, 5},
+    // tag G121 (6,5,6)
+    {"G121.x 5x6@30", 0, 1, 6, 5, 6, 5, 5, 6},
+    {"G121.y 6x5@36", 1, 2, 6, 5, 6, 6, 6, 6},
+    {"G121.z 5x6@30", 2, 1, 6, 5, 6, 6, 5, 5},
+    // tag G112 (6,6,5)
+    {"G112.x 5x6@30", 0, 1, 6, 6, 5, 5, 6, 5},
+    {"G112.y 5x6@30", 1, 1, 6, 6, 5, 6, 5, 5},
+    {"G112.z 6x5@36", 2, 2, 6, 6, 5, 6, 6, 6},
+    // tag G222 (5,5,5)
+    {"G222.x 6x5@25", 0, 2, 5, 5, 5, 6, 5, 5},
+    {"G222.y 6x5@25", 1, 2, 5, 5, 5, 5, 6, 5},
+    {"G222.z 6x5@25", 2, 2, 5, 5, 5, 5, 5, 6},
+};
+
+int lines_of(const AppShape& s) {
+    if (s.axis == 0) return s.sy * s.sz;
+    if (s.axis == 1) return s.sx * s.sz;
+    return s.sx * s.sy;
+}
+int nsrc_of(const AppShape& s) { return s.axis == 0 ? s.sx : (s.axis == 1 ? s.sy : s.sz); }
+int ntgt_of(const AppShape& s) { return s.axis == 0 ? s.tx : (s.axis == 1 ? s.ty : s.tz); }
+int src_size(const AppShape& s) { return s.sx * s.sy * s.sz; }
+int tgt_size(const AppShape& s) { return s.tx * s.ty * s.tz; }
+
+// ---------------------------------------------------------------------------
+// (a) dgemm replicas of apply_matrix_{x,y,z}_into (exact BLAS shapes).
+
+void dgemm_x(const double* K, int nt, int ns, const double* in, double* out, int nlines) {
+    cblas_dgemm(CblasColMajor, CblasNoTrans, CblasNoTrans,
+                nt, nlines, ns, 1.0, K, nt, in, ns, 0.0, out, nt);
+}
+void dgemm_y(const double* K, int nt, int ns, const double* in, double* out, int nx, int nz) {
+    for (int k = 0; k < nz; ++k) {
+        cblas_dgemm(CblasColMajor, CblasNoTrans, CblasTrans,
+                    nx, nt, ns, 1.0,
+                    in + static_cast<size_t>(k) * nx * ns, nx,
+                    K, nt, 0.0,
+                    out + static_cast<size_t>(k) * nx * nt, nx);
+    }
+}
+void dgemm_z(const double* K, int nt, int ns, const double* in, double* out, int nplane) {
+    cblas_dgemm(CblasColMajor, CblasNoTrans, CblasTrans,
+                nplane, nt, ns, 1.0, in, nplane, K, nt, 0.0, out, nplane);
+}
+
+void dgemm_apply(const AppShape& s, const double* K, const double* in, double* out) {
+    const int nt = ntgt_of(s), ns = nsrc_of(s);
+    if (s.axis == 0) dgemm_x(K, nt, ns, in, out, s.sy * s.sz);
+    else if (s.axis == 1) dgemm_y(K, nt, ns, in, out, s.sx, s.sz);
+    else dgemm_z(K, nt, ns, in, out, s.sx * s.sy);
+}
+
+// ---------------------------------------------------------------------------
+// (b) fixed-size hand-rolled kernels (compile-time dims, restrict + omp simd)
+
+template <int NT, int NS>
+inline void kx_fixed(const double* __restrict K, const double* __restrict in,
+                     double* __restrict out, int nlines) {
+    for (int l = 0; l < nlines; ++l) {
+        const double* __restrict s = in + static_cast<size_t>(l) * NS;
+        double* __restrict d = out + static_cast<size_t>(l) * NT;
+        double acc[NT];
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) acc[t] = K[t] * s[0];
+        for (int c = 1; c < NS; ++c) {
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) acc[t] += K[t + c * NT] * s[c];
+        }
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) d[t] = acc[t];
+    }
+}
+
+template <int NT, int NS, int NX>
+inline void ky_fixed(const double* __restrict K, const double* __restrict in,
+                     double* __restrict out, int nz) {
+    for (int k = 0; k < nz; ++k) {
+        const double* __restrict ins = in + static_cast<size_t>(k) * NX * NS;
+        double* __restrict outs = out + static_cast<size_t>(k) * NX * NT;
+        for (int t = 0; t < NT; ++t) {
+            double* __restrict d = outs + static_cast<size_t>(t) * NX;
+            const double k0 = K[t];
+            #pragma omp simd
+            for (int i = 0; i < NX; ++i) d[i] = k0 * ins[i];
+            for (int s = 1; s < NS; ++s) {
+                const double kv = K[t + s * NT];
+                const double* __restrict src = ins + static_cast<size_t>(s) * NX;
+                #pragma omp simd
+                for (int i = 0; i < NX; ++i) d[i] += kv * src[i];
+            }
+        }
+    }
+}
+
+template <int NT, int NS, int NPLANE>
+inline void kz_fixed(const double* __restrict K, const double* __restrict in,
+                     double* __restrict out) {
+    for (int t = 0; t < NT; ++t) {
+        double* __restrict d = out + static_cast<size_t>(t) * NPLANE;
+        const double k0 = K[t];
+        const double* __restrict s0 = in;
+        #pragma omp simd
+        for (int i = 0; i < NPLANE; ++i) d[i] = k0 * s0[i];
+        for (int s = 1; s < NS; ++s) {
+            const double kv = K[t + s * NT];
+            const double* __restrict src = in + static_cast<size_t>(s) * NPLANE;
+            #pragma omp simd
+            for (int i = 0; i < NPLANE; ++i) d[i] += kv * src[i];
+        }
+    }
+}
+
+// dispatch into the right instantiation for one AppShape
+void fixed_apply(int app_index, const double* K, const double* in, double* out) {
+    switch (app_index) {
+    case 0: kx_fixed<6, 5>(K, in, out, 36); return;                 // G211.x
+    case 1: ky_fixed<5, 6, 5>(K, in, out, 6); return;               // G211.y
+    case 2: kz_fixed<5, 6, 30>(K, in, out); return;                 // G211.z
+    case 3: kx_fixed<5, 6>(K, in, out, 30); return;                 // G121.x
+    case 4: ky_fixed<6, 5, 6>(K, in, out, 6); return;               // G121.y
+    case 5: kz_fixed<5, 6, 30>(K, in, out); return;                 // G121.z
+    case 6: kx_fixed<5, 6>(K, in, out, 30); return;                 // G112.x
+    case 7: ky_fixed<5, 6, 6>(K, in, out, 5); return;               // G112.y
+    case 8: kz_fixed<6, 5, 36>(K, in, out); return;                 // G112.z
+    case 9: kx_fixed<6, 5>(K, in, out, 25); return;                 // G222.x
+    case 10: ky_fixed<6, 5, 5>(K, in, out, 5); return;              // G222.y
+    case 11: kz_fixed<6, 5, 25>(K, in, out); return;                // G222.z
+    }
+}
+
+// ---------------------------------------------------------------------------
+// production SAT face correction (copy of apply_precomposed_face_correction,
+// raw-pointer form, identical arithmetic; the require_true checks dropped)
+
+void sat_correction(const AppShape& s,
+                    double* __restrict out, const double* __restrict in,
+                    bool plus_face,
+                    const double* __restrict src_row, int n_src,
+                    const double* __restrict tgt_col, int n_tgt,
+                    const double* __restrict outer, const double* __restrict alpha,
+                    bool outer_weighted, double sign) {
+    size_t line_count = 0, src_stride = 0, tgt_stride = 0;
+    size_t src_block = 0, tgt_block = 0, block_lines = 0;
+    (void)plus_face;
+    if (s.axis == 0) {
+        line_count = static_cast<size_t>(s.sy) * s.sz;
+        src_stride = 1; tgt_stride = 1; block_lines = line_count;
+    } else if (s.axis == 1) {
+        line_count = static_cast<size_t>(s.sx) * s.sz;
+        src_stride = s.sx; tgt_stride = s.tx;
+        block_lines = s.sx;
+        src_block = static_cast<size_t>(s.sx) * s.sy;
+        tgt_block = static_cast<size_t>(s.tx) * s.ty;
+    } else {
+        line_count = static_cast<size_t>(s.sx) * s.sy;
+        src_stride = static_cast<size_t>(s.sx) * s.sy;
+        tgt_stride = static_cast<size_t>(s.tx) * s.ty;
+        block_lines = line_count;
+    }
+    for (size_t line = 0; line < line_count; ++line) {
+        size_t src_base = line, tgt_base = line;
+        if (s.axis == 0) {
+            src_base = line * n_src;
+            tgt_base = line * n_tgt;
+        } else if (s.axis == 1) {
+            const size_t slice = line / block_lines;
+            const size_t inner_index = line % block_lines;
+            src_base = slice * src_block + inner_index;
+            tgt_base = slice * tgt_block + inner_index;
+        }
+        const double* src_line = in + src_base;
+        double inner = 0.0;
+        for (int q = 0; q < n_src; ++q) inner += src_row[q] * src_line[q * src_stride];
+        const double a = alpha[line];
+        const double blended = outer_weighted ? (1.0 - a) * inner + a * outer[line]
+                                              : a * inner + (1.0 - a) * outer[line];
+        const double scaled = sign * blended;
+        double* tgt_line = out + tgt_base;
+        for (int t = 0; t < n_tgt; ++t) tgt_line[t * tgt_stride] += tgt_col[t] * scaled;
+    }
+}
+
+// ---------------------------------------------------------------------------
+// element pool
+
+struct KernelSet {
+    // [family-1]: khat col-major (n_tgt x n_src), SAT vectors
+    std::vector<double> khat[2];
+    std::vector<double> row_minus[2], row_plus[2], col_minus[2], col_plus[2];
+    int nt[2], ns[2];
+};
+
+struct Pool {
+    int ne = 0;
+    size_t src_elem = 0, dst_elem = 0, sat_elem = 0;
+    std::vector<double> src, dst, sat;  // sat: per app, 4 faces of `lines` doubles
+    std::vector<size_t> src_off, dst_off, sat_off;  // per app within element
+};
+
+Pool make_pool(int ne, unsigned seed) {
+    Pool p;
+    p.ne = ne;
+    p.src_off.resize(12); p.dst_off.resize(12); p.sat_off.resize(12);
+    // unique source arrays per tag (apps sharing a tag share the source)
+    size_t soff[4] = {0, 0, 0, 0};
+    size_t s = 0;
+    for (int tag = 0; tag < 4; ++tag) {
+        soff[tag] = s;
+        s += static_cast<size_t>(src_size(kSweep[tag * 3]));
+    }
+    p.src_elem = s;  // 665
+    size_t d = 0, f = 0;
+    for (int a = 0; a < 12; ++a) {
+        p.src_off[a] = soff[a / 3];
+        p.dst_off[a] = d;
+        d += static_cast<size_t>(tgt_size(kSweep[a]));
+        p.sat_off[a] = f;
+        f += 4u * static_cast<size_t>(lines_of(kSweep[a]));
+    }
+    p.dst_elem = d;  // 1998
+    p.sat_elem = f;
+    p.src.assign(p.src_elem * ne, 0.0);
+    p.dst.assign(p.dst_elem * ne, 0.0);
+    p.sat.assign(p.sat_elem * ne, 0.0);
+    std::mt19937 rng(seed);
+    std::uniform_real_distribution<double> u(-1.0, 1.0);
+    for (auto& v : p.src) v = u(rng);
+    for (auto& v : p.sat) v = 0.25 + 0.5 * std::abs(u(rng));  // alpha-ish + outer
+    return p;
+}
+
+// ---------------------------------------------------------------------------
+
+struct BenchResult {
+    double ns_per_elem_sweep;  // one component sweep = 12 apps
+    double checksum;
+};
+
+template <typename F>
+BenchResult run_bench(const Pool& p, int reps, F&& sweep_fn) {
+    // warmup
+    volatile double sink = 0.0;
+    double cs = 0.0;
+    for (int e = 0; e < p.ne; ++e) cs += sweep_fn(e);
+    double best = 1e30;
+    for (int r = 0; r < reps; ++r) {
+        const double t0 = now_s();
+        double local = 0.0;
+        for (int e = 0; e < p.ne; ++e) local += sweep_fn(e);
+        const double t1 = now_s();
+        sink = local;
+        best = std::min(best, (t1 - t0) / p.ne);
+    }
+    (void)sink;
+    return {best * 1e9, cs};
+}
+
+double flops_sweep() {
+    double f = 0;
+    for (const auto& s : kSweep) f += 2.0 * ntgt_of(s) * nsrc_of(s) * lines_of(s);
+    return f;  // gemm flops of 12 apps
+}
+double bytes_sweep_unique() {
+    // unique source (4 tags read) + dst written once
+    double b = 0;
+    for (int tag = 0; tag < 4; ++tag) b += 8.0 * src_size(kSweep[tag * 3]);
+    for (const auto& s : kSweep) b += 8.0 * tgt_size(s);
+    return b;
+}
+double bytes_sweep_logical() {
+    // each source read 3x (once per axis), dst written once
+    double b = 0;
+    for (const auto& s : kSweep) b += 8.0 * (src_size(s) + tgt_size(s));
+    return b;
+}
+
+}  // namespace
+
+int main(int argc, char** argv) {
+    int ne_stream = 4096;
+    int reps = 7;
+    if (argc > 1) ne_stream = std::atoi(argv[1]);
+    if (argc > 2) reps = std::atoi(argv[2]);
+
+    // real production kernels
+    const AxisOperators1D ops = build_axis_operators(6, 4, 0.5, "schur_sqrt", "precomposed");
+    KernelSet ks;
+    for (int fam = 1; fam <= 2; ++fam) {
+        const PrecomposedAxisKernel1D& k = ops.precomposed[fam - 1];
+        const int i = fam - 1;
+        ks.nt[i] = static_cast<int>(k.khat.rows());
+        ks.ns[i] = static_cast<int>(k.khat.cols());
+        ks.khat[i].assign(k.khat.data(), k.khat.data() + k.khat.rows() * k.khat.cols());
+        ks.row_minus[i] = k.src_row_minus;
+        ks.row_plus[i] = k.src_row_plus;
+        ks.col_minus[i] = k.tgt_col_minus;
+        ks.col_plus[i] = k.tgt_col_plus;
+    }
+    std::printf("khat fam1: %dx%d  fam2: %dx%d\n", ks.nt[0], ks.ns[0], ks.nt[1], ks.ns[1]);
+
+    // correctness: fixed vs dgemm on one element
+    {
+        Pool p = make_pool(1, 17);
+        std::vector<double> ref(p.dst_elem), got(p.dst_elem);
+        for (int a = 0; a < 12; ++a) {
+            const AppShape& s = kSweep[a];
+            const int fam = s.family - 1;
+            dgemm_apply(s, ks.khat[fam].data(), p.src.data() + p.src_off[a], ref.data() + p.dst_off[a]);
+            fixed_apply(a, ks.khat[fam].data(), p.src.data() + p.src_off[a], got.data() + p.dst_off[a]);
+        }
+        double md = 0;
+        for (size_t i = 0; i < ref.size(); ++i) md = std::max(md, std::abs(ref[i] - got[i]));
+        std::printf("fixed-vs-dgemm max abs diff: %.3e\n", md);
+        if (md > 1e-12) { std::printf("VALIDATION FAILED\n"); return 1; }
+    }
+
+    const double fl = flops_sweep();
+    const double by_u = bytes_sweep_unique();
+    const double by_l = bytes_sweep_logical();
+    std::printf("per component sweep (12 apps): %.0f flops, %.0f unique bytes, %.0f logical bytes\n",
+                fl, by_u, by_l);
+
+    struct Variant {
+        const char* name;
+        int with_sat;  // 0 = bare, 1 = +sat
+        int kind;      // 0 = dgemm, 1 = fixed
+    };
+    const Variant variants[] = {
+        {"dgemm      ", 0, 0},
+        {"dgemm+sat  ", 1, 0},
+        {"fixed      ", 0, 1},
+        {"fixed+sat  ", 1, 1},
+    };
+
+    for (int regime = 0; regime < 2; ++regime) {
+        const int ne = regime == 0 ? 1 : ne_stream;
+        Pool p = make_pool(ne, 23);
+        const double pool_mb = 8.0 * (p.src.size() + p.dst.size() + p.sat.size()) / 1048576.0;
+        std::printf("\n=== regime %s: ne=%d (pool %.1f MB) ===\n",
+                    regime == 0 ? "HOT" : "STREAM", ne, pool_mb);
+        const int rr = regime == 0 ? reps * 3 : reps;
+
+        for (const Variant& v : variants) {
+            auto sweep = [&](int e) -> double {
+                const double* src_base = p.src.data() + static_cast<size_t>(e) * p.src_elem;
+                double* dst_base = p.dst.data() + static_cast<size_t>(e) * p.dst_elem;
+                const double* sat_base = p.sat.data() + static_cast<size_t>(e) * p.sat_elem;
+                for (int a = 0; a < 12; ++a) {
+                    const AppShape& s = kSweep[a];
+                    const int fam = s.family - 1;
+                    const double* in = src_base + p.src_off[a];
+                    double* out = dst_base + p.dst_off[a];
+                    if (v.kind == 0) dgemm_apply(s, ks.khat[fam].data(), in, out);
+                    else fixed_apply(a, ks.khat[fam].data(), in, out);
+                    if (v.with_sat) {
+                        const int L = lines_of(s);
+                        const double* fm = sat_base + p.sat_off[a];           // minus outer
+                        const double* am = fm + L;                            // minus alpha
+                        const double* fp = am + L;                            // plus outer
+                        const double* ap = fp + L;                            // plus alpha
+                        sat_correction(s, out, in, false,
+                                       ks.row_minus[fam].data(), ks.ns[fam],
+                                       ks.col_minus[fam].data(), ks.nt[fam],
+                                       fm, am, true, -1.0);
+                        sat_correction(s, out, in, true,
+                                       ks.row_plus[fam].data(), ks.ns[fam],
+                                       ks.col_plus[fam].data(), ks.nt[fam],
+                                       fp, ap, true, +1.0);
+                    }
+                }
+                return dst_base[0];
+            };
+            const BenchResult r = run_bench(p, rr, sweep);
+            std::printf("%s : %9.1f ns/sweep  %8.1f ns/app  %6.2f GF/s  "
+                        "%6.2f GB/s(unique)  %6.2f GB/s(logical)\n",
+                        v.name, r.ns_per_elem_sweep, r.ns_per_elem_sweep / 12.0,
+                        fl / r.ns_per_elem_sweep,
+                        by_u / r.ns_per_elem_sweep, by_l / r.ns_per_elem_sweep);
+        }
+
+        // per-shape dgemm vs fixed (HOT regime only, per-app timing)
+        if (regime == 0) {
+            std::printf("\nper-application (HOT, ns/call):\n");
+            for (int a = 0; a < 12; ++a) {
+                const AppShape& s = kSweep[a];
+                const int fam = s.family - 1;
+                const double* in = p.src.data() + p.src_off[a];
+                double* out = p.dst.data() + p.dst_off[a];
+                const int iters = 200000;
+                volatile double sink = 0.0;
+                double tg = 1e30, tf = 1e30;
+                for (int r = 0; r < 3; ++r) {
+                    double t0 = now_s();
+                    for (int i = 0; i < iters; ++i) dgemm_apply(s, ks.khat[fam].data(), in, out);
+                    double t1 = now_s();
+                    tg = std::min(tg, (t1 - t0) / iters);
+                    t0 = now_s();
+                    for (int i = 0; i < iters; ++i) fixed_apply(a, ks.khat[fam].data(), in, out);
+                    t1 = now_s();
+                    tf = std::min(tf, (t1 - t0) / iters);
+                    sink = out[0];
+                }
+                (void)sink;
+                const double fla = 2.0 * ntgt_of(s) * nsrc_of(s) * lines_of(s);
+                std::printf("  %-14s dgemm %8.1f ns (%5.2f GF/s)   fixed %7.1f ns (%5.2f GF/s)   ratio %5.1fx\n",
+                            s.name, tg * 1e9, fla / tg * 1e-9, tf * 1e9, fla / tf * 1e-9, tg / tf);
+            }
+
+            // SAT-populate face-extraction probe: one face dot via dgemm
+            // (extract_filtered_face_from_hat shapes) vs fixed dot.
+            std::printf("\nface extraction probe (per face, HOT):\n");
+            {
+                const int iters = 200000;
+                // X-face: m=1,n=36,k=6 dgemm on G111-like (6,6,6) source
+                std::vector<double> srcf(216), facev(36);
+                for (size_t i = 0; i < srcf.size(); ++i) srcf[i] = 0.001 * static_cast<double>(i % 97);
+                const double* row = ks.row_minus[0].data();  // 6-vector
+                volatile double sink = 0.0;
+                double tg = 1e30, tf = 1e30;
+                for (int r = 0; r < 3; ++r) {
+                    double t0 = now_s();
+                    for (int i = 0; i < iters; ++i) {
+                        cblas_dgemm(CblasColMajor, CblasNoTrans, CblasNoTrans,
+                                    1, 36, 6, 1.0, row, 1, srcf.data(), 6, 0.0, facev.data(), 1);
+                    }
+                    double t1 = now_s();
+                    tg = std::min(tg, (t1 - t0) / iters);
+                    t0 = now_s();
+                    for (int i = 0; i < iters; ++i) {
+                        for (int l = 0; l < 36; ++l) {
+                            const double* __restrict sline = srcf.data() + l * 6;
+                            double acc = 0.0;
+                            #pragma omp simd reduction(+ : acc)
+                            for (int q = 0; q < 6; ++q) acc += row[q] * sline[q];
+                            facev[static_cast<size_t>(l)] = acc;
+                        }
+                    }
+                    t1 = now_s();
+                    tf = std::min(tf, (t1 - t0) / iters);
+                    sink = facev[0];
+                }
+                (void)sink;
+                std::printf("  X-face m=1 dgemm(1x36x6): %8.1f ns   fixed dot: %7.1f ns   ratio %5.1fx\n",
+                            tg * 1e9, tf * 1e9, tg / tf);
+                // Y-face: production does nz separate dgemms with n=1 (m=6,k=6)
+                double ty = 1e30;
+                for (int r = 0; r < 3; ++r) {
+                    double t0 = now_s();
+                    for (int i = 0; i < iters; ++i) {
+                        for (int k = 0; k < 6; ++k) {
+                            cblas_dgemm(CblasColMajor, CblasNoTrans, CblasTrans,
+                                        6, 1, 6, 1.0, srcf.data() + k * 36, 6, row, 1, 0.0,
+                                        facev.data() + k * 6, 6);
+                        }
+                    }
+                    double t1 = now_s();
+                    ty = std::min(ty, (t1 - t0) / iters);
+                }
+                std::printf("  Y-face 6x dgemm(6x1x6) : %8.1f ns   (vs fixed-dot scale %.1f ns)\n",
+                            ty * 1e9, tf * 1e9);
+            }
+        }
+    }
+
+    // pure dgemm dispatch probe: vary nothing but call count, tiny no-op-ish gemm
+    {
+        const int iters = 1000000;
+        std::vector<double> a(36, 1.0), b(36, 1.0), c(36, 0.0);
+        double t = 1e30;
+        for (int r = 0; r < 3; ++r) {
+            const double t0 = now_s();
+            for (int i = 0; i < iters; ++i) {
+                cblas_dgemm(CblasColMajor, CblasNoTrans, CblasNoTrans,
+                            1, 1, 1, 1.0, a.data(), 1, b.data(), 1, 0.0, c.data(), 1);
+            }
+            const double t1 = now_s();
+            t = std::min(t, (t1 - t0) / iters);
+        }
+        std::printf("\ndgemm m=n=k=1 floor (pure dispatch): %.1f ns/call\n", t * 1e9);
+    }
+    return 0;
+}
