+// null_filter_check.cpp
+//
+// TASK A1 numerical support: quantify the family-1 x-null-space structure for
+// the projection filter design.
+//  (1) null space of the periodic fam-1 gradient chain (SVD), constant split
+//  (2) exact-orthogonality identity: Q_par^T (D_div w) = 0 for arbitrary w
+//  (3) decoupling: Q_par^T (Dd Dg) = 0 and (Dd Dg) Q_par = 0
+//  (4) coefficient-variation coupling: || Q_par^T diag(c(x)) Z || for constant
+//      vs varying c  (models heterogeneous-material in-flow into null space)
+//  (5) per-element locality of the parasitic null space, per-element template
+//      capture (principal angles) and purity
+//  (6) null content of smooth fields (plane waves vs PPW, monomials): order
+//  (7) bounded (non-periodic, alpha_bd=0) chain: null dim + locality near ends
+//
+// Build: link against the dfdm_elastic3d objects like dfdm_axis_audit.
+
+#include <lapacke.h>
+
+#include "elastic3d.h"
+#include "basis.h"
