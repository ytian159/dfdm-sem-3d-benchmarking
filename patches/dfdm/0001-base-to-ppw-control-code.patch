@@ -0,0 +1,63 @@
+# Full-Earth AK135 NEX12 benchmark slice: same element count (7 x 12^3) and
+# per-element grid as the case behind the documented DFDM-vs-SPECFEM3D_GLOBE
+# 7.73x performance anchor (porting log, 16 MPI x 8 OMP, 32714 s for 27778
+# steps). nt is shortened to a timing slice; physics settings follow the
+# anchor case (AK135 full Earth, f0 = 0.0025 Hz, dt = 0.18 s).
+[simulation]
+dt = 0.18
+nt = 500
+output_dir = "OUTPUT_FILES_3D_FULL_AK135_NEX12_BENCH"
+
+[mesh3d]
+nx = 6
+ny = 6
+nz = 6
+nex = 12
+ney = 12
+nez = 12
+porder = 4
+
+[geometry]
+kind = "earth"
+earth_radius_m = 6371000.0
+depth_top_m = 0.0
+depth_bottom_m = 6371000.0
+
+[earth]
+mode = "full"
+chunk_count = 6
+outer_radius_m = 6371000.0
+central_cube_radius_m = 950000.0
+inner_core_radius_m = 1221500.0
+outer_core_radius_m = 3480000.0
+
+[material]
+model = "1D_ak135f_no_mud"
+
+[source]
+type = "force"
+frequency = 0.0025
+amplitude = 10000000000.0
+time_function = "specfem_ricker"
+time_shift = 480.0
+latitude_deg = 6.0
+longitude_deg = 12.0
+depth_m = 30000.0
+force_radial = 1.0
+force_north = 0.0
+force_east = 0.0
+discretization = "normalized_delta"
+
+[receiver]
+latitude_deg = 15.0
+longitude_deg = 25.0
+depth_m = 0.0
+
+[boundary]
+top = "free_surface"
+
+[solver]
+mass_factorization = "schur_sqrt"
+stress_pullback_mode = "fused"
+enable_fixture_exports = false
+omp_threads = 0
