+// axis_kernel_mode="fixed": apply the precomposed khat through the
+// compile-time-shaped kernels (src/axis_kernels_fixed.h) instead of LibSci
+// dgemm. Same shape semantics and counter accounting as
+// apply_matrix_{x,y,z}_into; only the FP summation order differs (gated at
+// rel <= 1e-9 against the precomposed path, G0 evidence ~2e-16).
+void apply_fixed_axis_into(Axis3D axis,
+                           const PrecomposedAxisKernel1D& kernel,
+                           const Array3D& in,
+                           Array3D& out) {
+    const ElasticMatrix& op = kernel.khat;
+    assert(in.data() != out.data());
+    switch (axis) {
+    case Axis3D::X: {
+        if (op.cols() != in.nx()) {
+            throw std::runtime_error("apply_fixed_axis_into: X operator/input shape mismatch");
+        }
+        ensure_array_shape(out, op.rows(), in.ny(), in.nz());
+        record_dense_axis_kernel(Axis3D::X, in, out);
+        kernel.fns.xline(op.data(), in.data(), out.data(), in.ny() * in.nz());
+        return;
+    }
+    case Axis3D::Y: {
+        if (op.cols() != in.ny()) {
+            throw std::runtime_error("apply_fixed_axis_into: Y operator/input shape mismatch");
+        }
+        ensure_array_shape(out, in.nx(), op.rows(), in.nz());
+        record_dense_axis_kernel(Axis3D::Y, in, out);
+        const auto bundle_fn = (use_fixed_bundle_pair_t() && kernel.fns.bundle_pairt != nullptr)
+            ? kernel.fns.bundle_pairt
+            : kernel.fns.bundle;
+        bundle_fn(op.data(), in.data(), out.data(),
+                  in.nx(), in.nx(), in.nx(), in.nz(),
+                  in.nx() * op.cols(), in.nx() * op.rows());
+        return;
+    }
+    case Axis3D::Z: {
+        if (op.cols() != in.nz()) {
+            throw std::runtime_error("apply_fixed_axis_into: Z operator/input shape mismatch");
+        }
+        ensure_array_shape(out, in.nx(), in.ny(), op.rows());
+        record_dense_axis_kernel(Axis3D::Z, in, out);
+        const auto bundle_fn = (use_fixed_bundle_pair_t() && kernel.fns.bundle_pairt != nullptr)
+            ? kernel.fns.bundle_pairt
+            : kernel.fns.bundle;
+        bundle_fn(op.data(), in.data(), out.data(),
+                  in.nx() * in.ny(), in.nx() * in.ny(), in.nx() * in.ny(),
+                  1, 0, 0);
+        return;
+    }
+    }
+    throw std::runtime_error("Unknown axis in apply_fixed_axis_into");
+}
