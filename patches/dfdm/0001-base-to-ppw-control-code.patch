+        *neighbor_ops.x, grid_basis_digit(neighbor_tag, Axis3D::X));
+    const std::vector<double>& src_y = hatpoints_for_family(
+        *neighbor_ops.y, grid_basis_digit(neighbor_tag, Axis3D::Y));
