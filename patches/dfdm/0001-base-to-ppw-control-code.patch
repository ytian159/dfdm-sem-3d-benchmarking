+    for (size_t axis = 0; axis < 3; ++axis) {
+        const R2NullFilterAxis3D& fa = domain.r2_filter.axes[axis];
+        const int E = chain_counts[axis];
+        require_true(fa.chain_elements == E, "r2 filter chain element count mismatch");
+        require_true(static_cast<int>(fa.basis.cols()) == E - 1,
+                     "r2 filter basis must have one parasitic mode per interior interface");
+        require_true(fa.basis.rows()
+                         == static_cast<size_t>(E) * static_cast<size_t>(fa.line_points),
+                     "r2 filter basis row count mismatch");
+        require_true(fa.max_chain_residual < 1.0e-10,
+                     "r2 filter basis must lie in the chain null space");
+        require_true(fa.max_constant_overlap < 1.0e-12,
+                     "r2 filter basis must be orthogonal to the constant");
+        for (size_t a = 0; a < fa.basis.cols(); ++a) {
+            for (size_t b = 0; b < fa.basis.cols(); ++b) {
+                double dot = 0.0;
+                for (size_t t = 0; t < fa.basis.rows(); ++t) {
+                    dot += fa.basis(t, a) * fa.basis(t, b);
+                }
+                const double expected = (a == b) ? 1.0 : 0.0;
+                require_true(std::abs(dot - expected) < 1.0e-12,
+                             "r2 filter basis must be orthonormal");
+            }
+        }
+    }
+
+    // A globally constant displacement state must pass through unchanged.
+    for (ElasticState3D& element : domain.elements) {
+        for (GridTag tag : kDisplacementGridTags) {
+            const Array3D constant_hat = make_constant_physical_hat_field(
+                tag, domain.x_ops, domain.y_ops, domain.z_ops);
+            element.ux.at(tag) = constant_hat;
+            element.uy.at(tag) = constant_hat;
+            element.uz.at(tag) = constant_hat;
+            element.ux_1.at(tag) = constant_hat;
+            element.uy_1.at(tag) = constant_hat;
+            element.uz_1.at(tag) = constant_hat;
+        }
+    }
+    apply_r2_null_filter_pass(domain);
+    double max_constant_change = 0.0;
+    for (ElasticState3D& element : domain.elements) {
+        for (GridTag tag : kDisplacementGridTags) {
+            const Array3D constant_hat = make_constant_physical_hat_field(
+                tag, domain.x_ops, domain.y_ops, domain.z_ops);
+            const Array3D& filtered = element.ux.at(tag);
+            const Array3D& filtered_hist = element.ux_1.at(tag);
+            for (size_t idx = 0; idx < filtered.size(); ++idx) {
+                max_constant_change = std::max(
+                    max_constant_change,
+                    std::abs(filtered.data()[idx] - constant_hat.data()[idx]));
+                max_constant_change = std::max(
+                    max_constant_change,
+                    std::abs(filtered_hist.data()[idx] - constant_hat.data()[idx]));
+            }
+        }
+    }
+    require_true(max_constant_change < 1.0e-11,
+                 "r2 filter must leave a constant displacement state unchanged");
+
+    // Exact projector: applying the pass twice must match applying it once.
+    size_t element_counter = 0;
+    for (ElasticState3D& element : domain.elements) {
+        for (GridTag tag : kDisplacementGridTags) {
+            Array3D& field = element.ux.at(tag);
+            for (size_t idx = 0; idx < field.size(); ++idx) {
+                field.data()[idx] = std::sin(0.13 * static_cast<double>(idx + 1)
+                                             + 0.71 * static_cast<double>(element_counter));
+            }
+            element.ux_1.at(tag) = field;
+            element.uy.at(tag) = field;
+            element.uy_1.at(tag) = field;
+            element.uz.at(tag) = field;
+            element.uz_1.at(tag) = field;
+        }
+        ++element_counter;
+    }
+    apply_r2_null_filter_pass(domain);
+    std::vector<Array3D> once;
+    for (ElasticState3D& element : domain.elements) {
+        for (GridTag tag : kDisplacementGridTags) {
+            once.push_back(element.ux.at(tag));
+        }
+    }
+    apply_r2_null_filter_pass(domain);
+    double max_idempotency_change = 0.0;
+    double max_value = 0.0;
+    size_t cursor = 0;
+    for (ElasticState3D& element : domain.elements) {
+        for (GridTag tag : kDisplacementGridTags) {
+            const Array3D& twice = element.ux.at(tag);
+            const Array3D& first = once[cursor++];
+            for (size_t idx = 0; idx < twice.size(); ++idx) {
+                max_idempotency_change = std::max(
+                    max_idempotency_change,
+                    std::abs(twice.data()[idx] - first.data()[idx]));
+                max_value = std::max(max_value, std::abs(first.data()[idx]));
+            }
+        }
+    }
+    require_true(max_idempotency_change < 1.0e-12 * std::max(max_value, 1.0),
+                 "r2 filter projection must be idempotent");
+
+    out << "  r2 null filter: chains/orthonormality/constant/idempotency OK\n";
+}
