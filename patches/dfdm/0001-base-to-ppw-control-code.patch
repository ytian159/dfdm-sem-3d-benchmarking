+    if (same_point_grid(src_x, dst_x) && same_point_grid(src_y, dst_y)) {
+        if (scale == 1.0) {
+            std::copy(neighbor_face.data(), neighbor_face.data() + neighbor_face.size(), out.data());
+        } else {
