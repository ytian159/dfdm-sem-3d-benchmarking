+
+// Linear-index offset of a chunk's first element. Valid because the only
+// chunk whose element count can differ (the full-Earth central cube) is the
+// LAST chunk, so every preceding chunk contributes elements_per_chunk(cfg).
+size_t chunk_element_offset(const Solver3DConfig& cfg, int chunk) {
+    return static_cast<size_t>(chunk) * elements_per_chunk(cfg);
+}
+
+size_t total_element_count(const Solver3DConfig& cfg) {
+    const int chunks = active_chunk_count(cfg);
+    return chunk_element_offset(cfg, chunks - 1) + elements_in_chunk(cfg, chunks - 1);
