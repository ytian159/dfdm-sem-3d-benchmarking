+std::vector<std::vector<double>> lagrange_interp_weights(
+    const std::vector<double>& source_points,
+    const std::vector<double>& target_points) {
+    require_true(!source_points.empty(), "Empty source interpolation grid");
+    std::vector<std::vector<double>> weights(
+        target_points.size(), std::vector<double>(source_points.size(), 0.0));
+    for (size_t t = 0; t < target_points.size(); ++t) {
+        const double x = target_points[t];
+        bool matched = false;
+        for (size_t s = 0; s < source_points.size(); ++s) {
+            if (std::abs(x - source_points[s]) <= 1.0e-14) {
+                weights[t][s] = 1.0;
+                matched = true;
+                break;
+            }
+        }
+        if (matched) {
+            continue;
+        }
+        for (size_t s = 0; s < source_points.size(); ++s) {
+            double w = 1.0;
+            for (size_t m = 0; m < source_points.size(); ++m) {
+                if (m == s) {
+                    continue;
+                }
+                w *= (x - source_points[m]) / (source_points[s] - source_points[m]);
+            }
+            weights[t][s] = w;
+        }
+    }
+    return weights;
+}
