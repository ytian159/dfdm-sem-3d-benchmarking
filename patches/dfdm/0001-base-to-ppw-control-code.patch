+R2NullFilterAxis3D build_r2_null_filter_axis(const Solver3DConfig& cfg,
+                                             Axis3D axis,
+                                             const AxisOperators1D& ops) {
+    R2NullFilterAxis3D out;
+    const ElasticMatrix chain = build_r2_family1_chain_matrix(cfg, axis, ops);
+    const int n_src = ops.n1;
+    const int E = static_cast<int>(chain.cols()) / n_src;
+    out.chain_elements = E;
+    out.line_points = n_src;
+    const size_t len = chain.cols();
+
+    // SVD of the chain; null space = rows of VT with vanishing singular value
+    // plus the trailing rows beyond min(m, n).
+    const lapack_int m = static_cast<lapack_int>(chain.rows());
+    const lapack_int n = static_cast<lapack_int>(chain.cols());
+    ElasticMatrix a_copy = chain;
+    std::vector<double> sv(static_cast<size_t>(std::min(m, n)));
+    ElasticMatrix vt(len, len);
+    std::vector<double> superb(static_cast<size_t>(std::min(m, n)));
+    const lapack_int info = LAPACKE_dgesvd(LAPACK_COL_MAJOR, 'N', 'A', m, n,
+                                           a_copy.data(), m, sv.data(), nullptr, 1,
+                                           vt.data(), n, superb.data());
+    require_true(info == 0, "r2 filter: dgesvd failed");
+    const double sigma_max = sv.empty() ? 0.0 : sv[0];
+    const double tol = 1.0e-10 * sigma_max;
+    std::vector<size_t> null_rows;
+    for (size_t i = 0; i < sv.size(); ++i) {
+        if (sv[i] < tol) {
+            null_rows.push_back(i);
+        }
+    }
+    for (size_t i = sv.size(); i < len; ++i) {
+        null_rows.push_back(i);
+    }
+    // Bounded family-1 chain: one parasitic mode per element plus the
+    // constant (operator audit: dim null = E for production boundaries).
+    require_true(static_cast<int>(null_rows.size()) == E,
+                 "r2 filter: unexpected family-1 chain null dimension");
+
+    // Unit constant-hat direction over the chain (hat of the constant
+    // function: l11_t * ones per element, replicated).
+    std::vector<double> ones(static_cast<size_t>(n_src), 1.0);
+    std::vector<double> hat1(static_cast<size_t>(n_src), 0.0);
+    const ElasticMatrix& l11_t = ops.l11_t;
+    for (size_t j = 0; j < l11_t.cols(); ++j) {
+        for (size_t i = 0; i < l11_t.rows(); ++i) {
+            hat1[i] += l11_t(i, j) * ones[j];
+        }
+    }
+    std::vector<double> chat(len, 0.0);
+    for (int e = 0; e < E; ++e) {
+        for (int i = 0; i < n_src; ++i) {
+            chat[static_cast<size_t>(e) * static_cast<size_t>(n_src)
+                 + static_cast<size_t>(i)] = hat1[static_cast<size_t>(i)];
+        }
+    }
+    double cnorm = 0.0;
+    for (double v : chat) {
+        cnorm += v * v;
+    }
+    cnorm = std::sqrt(cnorm);
+    require_true(cnorm > 0.0, "r2 filter: constant hat vector is zero");
+    for (double& v : chat) {
+        v /= cnorm;
+    }
+
+    // Deflate the constant direction out of the null basis, then
+    // orthonormalize by modified Gram-Schmidt; exactly one column (the
+    // constant itself) must drop.
+    std::vector<std::vector<double>> kept;
+    kept.reserve(null_rows.size());
+    for (size_t r : null_rows) {
+        std::vector<double> v(len, 0.0);
+        for (size_t j = 0; j < len; ++j) {
+            v[j] = vt(r, j);
+        }
+        double dot_c = 0.0;
+        for (size_t j = 0; j < len; ++j) {
+            dot_c += v[j] * chat[j];
+        }
+        for (size_t j = 0; j < len; ++j) {
+            v[j] -= dot_c * chat[j];
+        }
+        for (const std::vector<double>& u : kept) {
+            double dot_u = 0.0;
+            for (size_t j = 0; j < len; ++j) {
+                dot_u += v[j] * u[j];
+            }
+            for (size_t j = 0; j < len; ++j) {
+                v[j] -= dot_u * u[j];
+            }
+        }
+        double vnorm = 0.0;
+        for (size_t j = 0; j < len; ++j) {
+            vnorm += v[j] * v[j];
+        }
+        vnorm = std::sqrt(vnorm);
+        if (vnorm < 1.0e-8) {
+            continue;
+        }
+        for (size_t j = 0; j < len; ++j) {
+            v[j] /= vnorm;
+        }
+        kept.push_back(std::move(v));
+    }
+    require_true(static_cast<int>(kept.size()) == E - 1,
+                 "r2 filter: constant deflation must drop exactly one null direction");
+
+    out.basis = ElasticMatrix(len, kept.size());
+    for (size_t c = 0; c < kept.size(); ++c) {
+        for (size_t j = 0; j < len; ++j) {
+            out.basis(j, c) = kept[c][j];
+        }
+    }
+
+    // Diagnostics: residual of the basis under the chain operator (relative
+    // to sigma_max) and residual constant overlap; both must be ~machine
+    // level for an exact projector.
+    for (size_t c = 0; c < kept.size(); ++c) {
+        double max_row = 0.0;
+        for (size_t i = 0; i < chain.rows(); ++i) {
+            double acc = 0.0;
+            for (size_t j = 0; j < len; ++j) {
+                acc += chain(i, j) * kept[c][j];
+            }
+            max_row = std::max(max_row, std::abs(acc));
+        }
+        out.max_chain_residual =
+            std::max(out.max_chain_residual, max_row / std::max(sigma_max, 1.0e-300));
+        double dot_c = 0.0;
+        for (size_t j = 0; j < len; ++j) {
+            dot_c += kept[c][j] * chat[j];
+        }
+        out.max_constant_overlap = std::max(out.max_constant_overlap, std::abs(dot_c));
+    }
+    return out;
+}
