+void add_array_in_place(Array3D& target, const Array3D& increment) {
+    require_true(target.size() == increment.size(),
+                 "Array3D size mismatch in add_array_in_place");
+    double* target_ptr = target.data();
+    const double* increment_ptr = increment.data();
+    for (size_t idx = 0; idx < target.size(); ++idx) {
