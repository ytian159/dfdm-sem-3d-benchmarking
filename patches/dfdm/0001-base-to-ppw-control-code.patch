+void compute_reference_derivative_hat_triplet_into(Axis3D axis,
+                                                   GridTag source_tag,
+                                                   const AxisOperators1D& axis_ops,
+                                                   const Array3D& source0,
+                                                   const SatFaceData3D& sat0,
+                                                   Array3D& out0,
+                                                   const Array3D& source1,
+                                                   const SatFaceData3D& sat1,
+                                                   Array3D& out1,
+                                                   const Array3D& source2,
+                                                   const SatFaceData3D& sat2,
+                                                   Array3D& out2,
+                                                   SatBlendMode3D blend_mode,
+                                                   Array3D& filtered_scratch,
+                                                   Array3D& derivative_scratch) {
+    if (!axis_ops.use_precomposed) {
+        compute_reference_derivative_hat_into(
+            axis, source_tag, axis_ops, source0, sat0, blend_mode,
+            filtered_scratch, derivative_scratch, out0);
+        compute_reference_derivative_hat_into(
+            axis, source_tag, axis_ops, source1, sat1, blend_mode,
+            filtered_scratch, derivative_scratch, out1);
+        compute_reference_derivative_hat_into(
+            axis, source_tag, axis_ops, source2, sat2, blend_mode,
+            filtered_scratch, derivative_scratch, out2);
+        return;
+    }
+    const int source_family = grid_basis_digit(source_tag, axis);
+    const PrecomposedAxisKernel1D& kernel =
+        axis_ops.precomposed[static_cast<size_t>(source_family - 1)];
+    if (!fixed_axis_triplet_available(axis, kernel, false)) {
+        compute_reference_derivative_hat_into(
+            axis, source_tag, axis_ops, source0, sat0, blend_mode,
+            filtered_scratch, derivative_scratch, out0);
+        compute_reference_derivative_hat_into(
+            axis, source_tag, axis_ops, source1, sat1, blend_mode,
+            filtered_scratch, derivative_scratch, out1);
+        compute_reference_derivative_hat_into(
+            axis, source_tag, axis_ops, source2, sat2, blend_mode,
+            filtered_scratch, derivative_scratch, out2);
+        return;
+    }
+    if (use_fused_fixed_sat_correction()) {
+        apply_fixed_axis_triplet_with_sat_into(
+            axis, kernel,
+            source0, sat0, out0,
+            source1, sat1, out1,
+            source2, sat2, out2,
+            blend_mode, false);
+        return;
+    }
+    apply_fixed_axis_triplet_into(axis, kernel, source0, source1, source2, out0, out1, out2);
+    apply_precomposed_face_correction_triplet(
+        out0, out1, out2, source0, source1, source2, axis, false,
+        kernel.src_row_minus, kernel.src_row_plus,
+        kernel.tgt_col_minus, kernel.tgt_col_plus,
+        sat0.minus_outer, sat0.minus_alpha,
+        sat1.minus_outer, sat1.minus_alpha,
+        sat2.minus_outer, sat2.minus_alpha,
+        blend_mode, -1.0);
+    apply_precomposed_face_correction_triplet(
+        out0, out1, out2, source0, source1, source2, axis, true,
+        kernel.src_row_minus, kernel.src_row_plus,
+        kernel.tgt_col_minus, kernel.tgt_col_plus,
+        sat0.plus_outer, sat0.plus_alpha,
+        sat1.plus_outer, sat1.plus_alpha,
+        sat2.plus_outer, sat2.plus_alpha,
+        blend_mode, +1.0);
+}
