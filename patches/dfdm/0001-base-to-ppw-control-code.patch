+            sat.minus_outer, sat.minus_alpha, blend_mode, -1.0);
+        apply_precomposed_face_correction(
+            out, source_hat, axis, true,
+            kernel.src_row_minus, kernel.src_row_plus,
+            kernel.tgt_col_minus, kernel.tgt_col_plus,
+            sat.plus_outer, sat.plus_alpha, blend_mode, +1.0);
