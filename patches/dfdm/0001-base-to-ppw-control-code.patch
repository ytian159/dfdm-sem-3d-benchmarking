+// Boundary-face dot forms (SAT face extraction probes / future face cache).
+// X face: per line, a single ascending-s scalar dot (a reduction is never
+// vectorized internally).
+template <int NS>
+void extract_face_xdot(const double* __restrict row,
+                       const double* __restrict in,
+                       double* __restrict out,
+                       std::size_t n_lines) {
+    for (std::size_t l = 0; l < n_lines; ++l) {
+        const double* __restrict s = in + l * static_cast<std::size_t>(NS);
+        double acc = row[0] * s[0];
+        for (int c = 1; c < NS; ++c) {
+            acc += row[c] * s[c];
+        }
+        out[l] = acc;
+    }
+}
+
+// Y/Z face: independent outputs across the contiguous bundle.
+//   out[i + z*out_ss] = sum_s row[s] * in[i + s*in_cs + z*in_ss]
+template <int NS>
+void extract_face_bundle(const double* __restrict row,
+                         const double* __restrict in,
+                         double* __restrict out,
+                         std::size_t bundle,
+                         std::size_t in_cs,
+                         std::size_t n_slices,
+                         std::size_t in_ss,
+                         std::size_t out_ss) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict ins = in + z * in_ss;
+        double* __restrict d = out + z * out_ss;
+        const double r0 = row[0];
+        #pragma omp simd
+        for (std::size_t i = 0; i < bundle; ++i) {
+            d[i] = r0 * ins[i];
+        }
+        for (int s = 1; s < NS; ++s) {
+            const double rv = row[s];
+            const double* __restrict src = ins + static_cast<std::size_t>(s) * in_cs;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d[i] += rv * src[i];
+            }
+        }
+    }
+}
