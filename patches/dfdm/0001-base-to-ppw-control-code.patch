+const TaggedFields3D* mpi_displacement_fields_for_global(
+    const MpiPhase1Domain3D& domain,
+    int global,
+    DisplacementMember3D member,
+    const std::unordered_map<int, ElasticState3D>& ghosts) {
+    if (global < 0) {
+        return nullptr;
+    }
+    const int local = domain.global_to_local[static_cast<size_t>(global)];
+    if (local >= 0) {
+        return &(domain.elements[static_cast<size_t>(local)].*member);
+    }
+    const auto found = ghosts.find(global);
+    if (found == ghosts.end()) {
+        return nullptr;
+    }
+    return &(found->second.*member);
