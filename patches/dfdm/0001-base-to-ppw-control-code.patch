+                     && kernel.tgt_col_plus.size() == n_tgt,
+                 "Fused fixed SAT row/column shape mismatch");
+    require_true(static_cast<size_t>(op.cols()) == n_src
+                     && static_cast<size_t>(op.rows()) == n_tgt,
+                 "Fused fixed SAT operator shape mismatch");
+    require_true(oriented_array_dim_for_axis(source_hat, axis) == n_src,
+                 "Fused fixed SAT source length mismatch");
+    require_true(oriented_array_dim_for_axis(out, axis) == n_tgt,
+                 "Fused fixed SAT target length mismatch");
+    require_true(sat.minus_outer.size() == sat.minus_alpha.size()
+                     && sat.plus_outer.size() == sat.plus_alpha.size()
+                     && sat.minus_outer.size() == sat.plus_outer.size()
+                     && sat.minus_outer.size() * n_src == source_hat.size(),
+                 "Fused fixed SAT face shape mismatch");
+    require_true(n_tgt <= 16, "Fused fixed SAT target line too long");
+
+    if (kernel.fns.xline_sat != nullptr && kernel.fns.bundle_sat != nullptr) {
+        const bool outer_weighted = blend_mode == SatBlendMode3D::DisplacementOuterWeighted;
+        switch (axis) {
+        case Axis3D::X:
+            kernel.fns.xline_sat(
+                op.data(), kernel.src_row_minus.data(), kernel.src_row_plus.data(),
+                kernel.tgt_col_minus.data(), kernel.tgt_col_plus.data(),
+                source_hat.data(),
+                sat.minus_outer.data(), sat.minus_alpha.data(),
+                sat.plus_outer.data(), sat.plus_alpha.data(),
+                out.data(), outer_weighted, additive,
+                source_hat.ny() * source_hat.nz());
+            return;
+        case Axis3D::Y:
+            require_true(source_hat.nx() <= axis_kernels_fixed::kMaxSatBundle,
+                         "Fused fixed SAT Y bundle too wide");
+            kernel.fns.bundle_sat(
+                op.data(), kernel.src_row_minus.data(), kernel.src_row_plus.data(),
+                kernel.tgt_col_minus.data(), kernel.tgt_col_plus.data(),
+                source_hat.data(),
+                sat.minus_outer.data(), sat.minus_alpha.data(),
+                sat.plus_outer.data(), sat.plus_alpha.data(),
+                out.data(), source_hat.nx(), source_hat.nx(), out.nx(), source_hat.nz(),
+                source_hat.nx() * n_src, out.nx() * n_tgt, source_hat.nx(),
+                outer_weighted, additive);
+            return;
+        case Axis3D::Z:
+            require_true(source_hat.nx() * source_hat.ny() <= axis_kernels_fixed::kMaxSatBundle,
+                         "Fused fixed SAT Z bundle too wide");
+            kernel.fns.bundle_sat(
+                op.data(), kernel.src_row_minus.data(), kernel.src_row_plus.data(),
+                kernel.tgt_col_minus.data(), kernel.tgt_col_plus.data(),
+                source_hat.data(),
+                sat.minus_outer.data(), sat.minus_alpha.data(),
+                sat.plus_outer.data(), sat.plus_alpha.data(),
+                out.data(), source_hat.nx() * source_hat.ny(),
+                source_hat.nx() * source_hat.ny(), out.nx() * out.ny(), 1, 0, 0, 0,
+                outer_weighted, additive);
+            return;
+        }
+    }
+
+    const bool outer_weighted = blend_mode == SatBlendMode3D::DisplacementOuterWeighted;
+    const AxisLineTraversal3D traversal = axis_line_traversal(axis, source_hat, out);
+    const double* source_data = source_hat.data();
+    const double* K = op.data();
+    const double* minus_outer = sat.minus_outer.data();
+    const double* minus_alpha = sat.minus_alpha.data();
+    const double* plus_outer = sat.plus_outer.data();
+    const double* plus_alpha = sat.plus_alpha.data();
+    double* out_data = out.data();
+
+    for (size_t line = 0; line < traversal.line_count; ++line) {
+        size_t src_base = 0;
+        size_t tgt_base = 0;
+        axis_line_bases(axis, traversal, line, n_src, n_tgt, src_base, tgt_base);
+        const double* src_line = source_data + src_base;
+        double acc[16];
+        const double v0 = src_line[0];
+        double inner_minus = kernel.src_row_minus[0] * v0;
+        double inner_plus = kernel.src_row_plus[0] * v0;
+        #pragma omp simd
+        for (size_t t = 0; t < n_tgt; ++t) {
+            acc[t] = K[t] * v0;
+        }
+        for (size_t ss = 1; ss < n_src; ++ss) {
+            const double value = src_line[ss * traversal.src_stride];
+            inner_minus += kernel.src_row_minus[ss] * value;
+            inner_plus += kernel.src_row_plus[ss] * value;
+            #pragma omp simd
+            for (size_t t = 0; t < n_tgt; ++t) {
+                acc[t] += K[t + ss * n_tgt] * value;
+            }
+        }
+        const double scaled_minus = -blended_sat_value(inner_minus, minus_outer[line],
+                                                       minus_alpha[line], outer_weighted);
+        const double scaled_plus = blended_sat_value(inner_plus, plus_outer[line],
+                                                     plus_alpha[line], outer_weighted);
+        double* tgt_line = out_data + tgt_base;
+        if (additive) {
+            for (size_t t = 0; t < n_tgt; ++t) {
+                double& target = tgt_line[t * traversal.tgt_stride];
+                target += acc[t];
+                target += kernel.tgt_col_minus[t] * scaled_minus;
+                target += kernel.tgt_col_plus[t] * scaled_plus;
+            }
+        } else {
+            for (size_t t = 0; t < n_tgt; ++t) {
+                double value = acc[t];
+                value += kernel.tgt_col_minus[t] * scaled_minus;
+                value += kernel.tgt_col_plus[t] * scaled_plus;
+                tgt_line[t * traversal.tgt_stride] = value;
+            }
+        }
+    }
+}
+
+void apply_fixed_axis_triplet_with_sat_into(Axis3D axis,
+                                            const PrecomposedAxisKernel1D& kernel,
+                                            const Array3D& source0,
+                                            const SatFaceData3D& sat0,
+                                            Array3D& out0,
+                                            const Array3D& source1,
+                                            const SatFaceData3D& sat1,
+                                            Array3D& out1,
+                                            const Array3D& source2,
+                                            const SatFaceData3D& sat2,
+                                            Array3D& out2,
+                                            SatBlendMode3D blend_mode,
+                                            bool additive) {
+    const ElasticMatrix& op = kernel.khat;
+    require_triplet_axis_shapes(source0, source1, source2,
+                                "Fused fixed triplet SAT source shape mismatch");
+    assert(source0.data() != out0.data());
+    assert(source1.data() != out1.data());
+    assert(source2.data() != out2.data());
+    prepare_fixed_axis_output(axis, op, source0, out0,
+                              additive ? "apply_fixed_axis_triplet_with_sat_add_into"
+                                       : "apply_fixed_axis_triplet_with_sat_into");
+    prepare_fixed_axis_output(axis, op, source1, out1,
+                              additive ? "apply_fixed_axis_triplet_with_sat_add_into"
+                                       : "apply_fixed_axis_triplet_with_sat_into");
+    prepare_fixed_axis_output(axis, op, source2, out2,
+                              additive ? "apply_fixed_axis_triplet_with_sat_add_into"
+                                       : "apply_fixed_axis_triplet_with_sat_into");
+    require_triplet_axis_shapes(out0, out1, out2,
+                                "Fused fixed triplet SAT target shape mismatch");
+    const size_t n_src = kernel.src_row_minus.size();
+    const size_t n_tgt = kernel.tgt_col_minus.size();
+    require_true(kernel.src_row_plus.size() == n_src
+                     && kernel.tgt_col_plus.size() == n_tgt,
+                 "Fused fixed triplet SAT row/column shape mismatch");
+    require_true(static_cast<size_t>(op.cols()) == n_src
+                     && static_cast<size_t>(op.rows()) == n_tgt,
+                 "Fused fixed triplet SAT operator shape mismatch");
+    require_true(oriented_array_dim_for_axis(source0, axis) == n_src,
+                 "Fused fixed triplet SAT source length mismatch");
+    require_true(oriented_array_dim_for_axis(out0, axis) == n_tgt,
+                 "Fused fixed triplet SAT target length mismatch");
+    require_true(sat0.minus_outer.size() == sat0.minus_alpha.size()
+                     && sat0.plus_outer.size() == sat0.plus_alpha.size()
+                     && sat1.minus_outer.size() == sat1.minus_alpha.size()
+                     && sat1.plus_outer.size() == sat1.plus_alpha.size()
+                     && sat2.minus_outer.size() == sat2.minus_alpha.size()
+                     && sat2.plus_outer.size() == sat2.plus_alpha.size()
+                     && sat0.minus_outer.size() == sat0.plus_outer.size()
+                     && sat0.minus_outer.size() == sat1.minus_outer.size()
+                     && sat0.minus_outer.size() == sat2.minus_outer.size()
+                     && sat0.minus_outer.size() * n_src == source0.size(),
+                 "Fused fixed triplet SAT face shape mismatch");
+    require_true(n_tgt <= 16, "Fused fixed triplet SAT target line too long");
+
+    if (kernel.fns.xline_triplet_sat != nullptr && kernel.fns.bundle_triplet_sat != nullptr) {
+        const bool outer_weighted = blend_mode == SatBlendMode3D::DisplacementOuterWeighted;
+        const double* inputs[3] = {source0.data(), source1.data(), source2.data()};
+        const double* minus_outers[3] = {
+            sat0.minus_outer.data(), sat1.minus_outer.data(), sat2.minus_outer.data()};
+        const double* minus_alphas[3] = {
+            sat0.minus_alpha.data(), sat1.minus_alpha.data(), sat2.minus_alpha.data()};
+        const double* plus_outers[3] = {
+            sat0.plus_outer.data(), sat1.plus_outer.data(), sat2.plus_outer.data()};
+        const double* plus_alphas[3] = {
+            sat0.plus_alpha.data(), sat1.plus_alpha.data(), sat2.plus_alpha.data()};
+        double* outputs[3] = {out0.data(), out1.data(), out2.data()};
+        switch (axis) {
+        case Axis3D::X:
+            kernel.fns.xline_triplet_sat(
+                op.data(), kernel.src_row_minus.data(), kernel.src_row_plus.data(),
+                kernel.tgt_col_minus.data(), kernel.tgt_col_plus.data(),
+                inputs, minus_outers, minus_alphas, plus_outers, plus_alphas, outputs,
+                outer_weighted, additive, source0.ny() * source0.nz());
+            return;
+        case Axis3D::Y:
+            require_true(source0.nx() <= axis_kernels_fixed::kMaxSatBundle,
+                         "Fused fixed triplet SAT Y bundle too wide");
+            kernel.fns.bundle_triplet_sat(
+                op.data(), kernel.src_row_minus.data(), kernel.src_row_plus.data(),
+                kernel.tgt_col_minus.data(), kernel.tgt_col_plus.data(),
+                inputs, minus_outers, minus_alphas, plus_outers, plus_alphas, outputs,
+                source0.nx(), source0.nx(), out0.nx(), source0.nz(),
+                source0.nx() * n_src, out0.nx() * n_tgt, source0.nx(),
+                outer_weighted, additive);
+            return;
+        case Axis3D::Z:
+            require_true(source0.nx() * source0.ny() <= axis_kernels_fixed::kMaxSatBundle,
+                         "Fused fixed triplet SAT Z bundle too wide");
+            kernel.fns.bundle_triplet_sat(
+                op.data(), kernel.src_row_minus.data(), kernel.src_row_plus.data(),
+                kernel.tgt_col_minus.data(), kernel.tgt_col_plus.data(),
+                inputs, minus_outers, minus_alphas, plus_outers, plus_alphas, outputs,
+                source0.nx() * source0.ny(), source0.nx() * source0.ny(),
+                out0.nx() * out0.ny(), 1, 0, 0, 0,
+                outer_weighted, additive);
+            return;
+        }
+    }
+
+    const bool outer_weighted = blend_mode == SatBlendMode3D::DisplacementOuterWeighted;
+    const AxisLineTraversal3D traversal = axis_line_traversal(axis, source0, out0);
+    const double* K = op.data();
+    const double* source0_data = source0.data();
+    const double* source1_data = source1.data();
+    const double* source2_data = source2.data();
+    double* out0_data = out0.data();
+    double* out1_data = out1.data();
+    double* out2_data = out2.data();
+    const double* sat0_minus_outer = sat0.minus_outer.data();
+    const double* sat0_minus_alpha = sat0.minus_alpha.data();
+    const double* sat0_plus_outer = sat0.plus_outer.data();
+    const double* sat0_plus_alpha = sat0.plus_alpha.data();
+    const double* sat1_minus_outer = sat1.minus_outer.data();
+    const double* sat1_minus_alpha = sat1.minus_alpha.data();
+    const double* sat1_plus_outer = sat1.plus_outer.data();
+    const double* sat1_plus_alpha = sat1.plus_alpha.data();
+    const double* sat2_minus_outer = sat2.minus_outer.data();
+    const double* sat2_minus_alpha = sat2.minus_alpha.data();
+    const double* sat2_plus_outer = sat2.plus_outer.data();
+    const double* sat2_plus_alpha = sat2.plus_alpha.data();
+
+    for (size_t line = 0; line < traversal.line_count; ++line) {
+        size_t src_base = 0;
+        size_t tgt_base = 0;
+        axis_line_bases(axis, traversal, line, n_src, n_tgt, src_base, tgt_base);
+        const double* src0_line = source0_data + src_base;
+        const double* src1_line = source1_data + src_base;
+        const double* src2_line = source2_data + src_base;
+        double acc0[16];
+        double acc1[16];
+        double acc2[16];
+        const double v00 = src0_line[0];
+        const double v10 = src1_line[0];
+        const double v20 = src2_line[0];
+        double inner_minus0 = kernel.src_row_minus[0] * v00;
+        double inner_minus1 = kernel.src_row_minus[0] * v10;
+        double inner_minus2 = kernel.src_row_minus[0] * v20;
+        double inner_plus0 = kernel.src_row_plus[0] * v00;
+        double inner_plus1 = kernel.src_row_plus[0] * v10;
+        double inner_plus2 = kernel.src_row_plus[0] * v20;
+        #pragma omp simd
+        for (size_t t = 0; t < n_tgt; ++t) {
+            const double kt = K[t];
+            acc0[t] = kt * v00;
+            acc1[t] = kt * v10;
+            acc2[t] = kt * v20;
+        }
+        for (size_t ss = 1; ss < n_src; ++ss) {
+            const double value0 = src0_line[ss * traversal.src_stride];
+            const double value1 = src1_line[ss * traversal.src_stride];
+            const double value2 = src2_line[ss * traversal.src_stride];
+            const double row_minus = kernel.src_row_minus[ss];
+            const double row_plus = kernel.src_row_plus[ss];
+            inner_minus0 += row_minus * value0;
+            inner_minus1 += row_minus * value1;
+            inner_minus2 += row_minus * value2;
+            inner_plus0 += row_plus * value0;
+            inner_plus1 += row_plus * value1;
+            inner_plus2 += row_plus * value2;
+            #pragma omp simd
+            for (size_t t = 0; t < n_tgt; ++t) {
+                const double kt = K[t + ss * n_tgt];
+                acc0[t] += kt * value0;
+                acc1[t] += kt * value1;
+                acc2[t] += kt * value2;
+            }
+        }
+
+        const double scaled_minus0 =
+            -blended_sat_value(inner_minus0, sat0_minus_outer[line],
+                               sat0_minus_alpha[line], outer_weighted);
+        const double scaled_minus1 =
+            -blended_sat_value(inner_minus1, sat1_minus_outer[line],
+                               sat1_minus_alpha[line], outer_weighted);
+        const double scaled_minus2 =
+            -blended_sat_value(inner_minus2, sat2_minus_outer[line],
+                               sat2_minus_alpha[line], outer_weighted);
+        const double scaled_plus0 =
+            blended_sat_value(inner_plus0, sat0_plus_outer[line],
+                              sat0_plus_alpha[line], outer_weighted);
+        const double scaled_plus1 =
+            blended_sat_value(inner_plus1, sat1_plus_outer[line],
+                              sat1_plus_alpha[line], outer_weighted);
+        const double scaled_plus2 =
+            blended_sat_value(inner_plus2, sat2_plus_outer[line],
+                              sat2_plus_alpha[line], outer_weighted);
+
+        double* tgt0_line = out0_data + tgt_base;
+        double* tgt1_line = out1_data + tgt_base;
+        double* tgt2_line = out2_data + tgt_base;
+        if (additive) {
+            for (size_t t = 0; t < n_tgt; ++t) {
+                const size_t index = t * traversal.tgt_stride;
+                tgt0_line[index] += acc0[t];
+                tgt1_line[index] += acc1[t];
+                tgt2_line[index] += acc2[t];
+                const double weight_minus = kernel.tgt_col_minus[t];
+                tgt0_line[index] += weight_minus * scaled_minus0;
+                tgt1_line[index] += weight_minus * scaled_minus1;
+                tgt2_line[index] += weight_minus * scaled_minus2;
+                const double weight_plus = kernel.tgt_col_plus[t];
+                tgt0_line[index] += weight_plus * scaled_plus0;
+                tgt1_line[index] += weight_plus * scaled_plus1;
+                tgt2_line[index] += weight_plus * scaled_plus2;
+            }
+        } else {
+            for (size_t t = 0; t < n_tgt; ++t) {
+                const size_t index = t * traversal.tgt_stride;
+                const double weight_minus = kernel.tgt_col_minus[t];
+                const double weight_plus = kernel.tgt_col_plus[t];
+                double value0 = acc0[t];
+                double value1 = acc1[t];
+                double value2 = acc2[t];
+                value0 += weight_minus * scaled_minus0;
+                value1 += weight_minus * scaled_minus1;
+                value2 += weight_minus * scaled_minus2;
+                value0 += weight_plus * scaled_plus0;
+                value1 += weight_plus * scaled_plus1;
+                value2 += weight_plus * scaled_plus2;
+                tgt0_line[index] = value0;
+                tgt1_line[index] = value1;
+                tgt2_line[index] = value2;
+            }
+        }
+    }
+}
+
+void apply_precomposed_face_correction_pair(Array3D& out,
+                                            const Array3D& source_hat,
+                                            Axis3D axis,
+                                            const std::vector<double>& src_row_minus,
+                                            const std::vector<double>& src_row_plus,
+                                            const std::vector<double>& tgt_col_minus,
+                                            const std::vector<double>& tgt_col_plus,
+                                            const Array3D& minus_outer,
+                                            const Array3D& minus_alpha,
+                                            const Array3D& plus_outer,
+                                            const Array3D& plus_alpha,
+                                            SatBlendMode3D mode) {
+    const size_t n_src = src_row_minus.size();
+    const size_t n_tgt = tgt_col_minus.size();
+    require_true(src_row_plus.size() == n_src && tgt_col_plus.size() == n_tgt,
+                 "Precomposed paired SAT row/column shape mismatch");
+    require_true(oriented_array_dim_for_axis(source_hat, axis) == n_src,
+                 "Precomposed paired SAT source length mismatch");
+    require_true(oriented_array_dim_for_axis(out, axis) == n_tgt,
+                 "Precomposed paired SAT target length mismatch");
+    require_true(minus_outer.size() == minus_alpha.size()
+                     && plus_outer.size() == plus_alpha.size()
+                     && minus_outer.size() == plus_outer.size()
+                     && minus_outer.size() * n_src == source_hat.size(),
+                 "Precomposed paired SAT face shape mismatch");
+
+    const bool outer_weighted = mode == SatBlendMode3D::DisplacementOuterWeighted;
+    const double* minus_outer_data = minus_outer.data();
+    const double* minus_alpha_data = minus_alpha.data();
+    const double* plus_outer_data = plus_outer.data();
+    const double* plus_alpha_data = plus_alpha.data();
+    const double* source_data = source_hat.data();
+    double* out_data = out.data();
+
+    size_t line_count = 0;
+    size_t src_stride = 0;
+    size_t tgt_stride = 0;
+    size_t src_block = 0;
+    size_t tgt_block = 0;
+    size_t block_lines = 0;
+    switch (axis) {
+    case Axis3D::X:
+        line_count = source_hat.ny() * source_hat.nz();
+        src_stride = 1;
+        tgt_stride = 1;
+        block_lines = line_count;
+        src_block = 0;
+        tgt_block = 0;
+        break;
+    case Axis3D::Y:
+        line_count = source_hat.nx() * source_hat.nz();
+        src_stride = source_hat.nx();
+        tgt_stride = out.nx();
+        block_lines = source_hat.nx();
+        src_block = source_hat.nx() * source_hat.ny();
+        tgt_block = out.nx() * out.ny();
+        break;
+    case Axis3D::Z:
+        line_count = source_hat.nx() * source_hat.ny();
+        src_stride = source_hat.nx() * source_hat.ny();
+        tgt_stride = out.nx() * out.ny();
+        block_lines = line_count;
+        src_block = 0;
+        tgt_block = 0;
+        break;
+    }
+
+    for (size_t line = 0; line < line_count; ++line) {
+        size_t src_base = line;
+        size_t tgt_base = line;
+        if (axis == Axis3D::X) {
+            src_base = line * n_src;
+            tgt_base = line * n_tgt;
+        } else if (axis == Axis3D::Y) {
+            const size_t slice = line / block_lines;
+            const size_t inner_index = line % block_lines;
+            src_base = slice * src_block + inner_index;
+            tgt_base = slice * tgt_block + inner_index;
+        }
+        const double* src_line = source_data + src_base;
+        double inner_minus = 0.0;
+        double inner_plus = 0.0;
+        for (size_t s = 0; s < n_src; ++s) {
+            const double value = src_line[s * src_stride];
+            inner_minus += src_row_minus[s] * value;
+            inner_plus += src_row_plus[s] * value;
+        }
+        const double am = minus_alpha_data[line];
+        const double ap = plus_alpha_data[line];
+        const double blended_minus = outer_weighted
+            ? (1.0 - am) * inner_minus + am * minus_outer_data[line]
+            : am * inner_minus + (1.0 - am) * minus_outer_data[line];
+        const double blended_plus = outer_weighted
+            ? (1.0 - ap) * inner_plus + ap * plus_outer_data[line]
+            : ap * inner_plus + (1.0 - ap) * plus_outer_data[line];
+        const double scaled_minus = -blended_minus;
+        const double scaled_plus = blended_plus;
+        double* tgt_line = out_data + tgt_base;
+        for (size_t t = 0; t < n_tgt; ++t) {
+            tgt_line[t * tgt_stride] += tgt_col_minus[t] * scaled_minus;
+            tgt_line[t * tgt_stride] += tgt_col_plus[t] * scaled_plus;
+        }
+    }
+}
+
+
+void apply_precomposed_face_correction_triplet(Array3D& out0,
+                                               Array3D& out1,
+                                               Array3D& out2,
+                                               const Array3D& source0,
+                                               const Array3D& source1,
+                                               const Array3D& source2,
+                                               Axis3D axis,
+                                               bool plus_face,
+                                               const std::vector<double>& src_row_minus,
+                                               const std::vector<double>& src_row_plus,
+                                               const std::vector<double>& tgt_col_minus,
+                                               const std::vector<double>& tgt_col_plus,
+                                               const Array3D& outer0,
+                                               const Array3D& alpha0,
+                                               const Array3D& outer1,
+                                               const Array3D& alpha1,
+                                               const Array3D& outer2,
+                                               const Array3D& alpha2,
+                                               SatBlendMode3D mode,
+                                               double sign) {
+    require_triplet_axis_shapes(source0, source1, source2,
+                                "Triplet SAT source shape mismatch");
+    require_triplet_axis_shapes(out0, out1, out2,
+                                "Triplet SAT target shape mismatch");
+    const std::vector<double>& src_row = plus_face ? src_row_plus : src_row_minus;
+    const std::vector<double>& tgt_col = plus_face ? tgt_col_plus : tgt_col_minus;
+    const size_t n_src = src_row.size();
+    const size_t n_tgt = tgt_col.size();
+    require_true(oriented_array_dim_for_axis(source0, axis) == n_src,
+                 "Triplet precomposed SAT source length mismatch");
+    require_true(oriented_array_dim_for_axis(out0, axis) == n_tgt,
+                 "Triplet precomposed SAT target length mismatch");
+    require_true(outer0.size() == alpha0.size() && outer1.size() == alpha1.size()
+                     && outer2.size() == alpha2.size()
+                     && outer0.size() == outer1.size() && outer0.size() == outer2.size()
+                     && outer0.size() * n_src == source0.size(),
+                 "Triplet precomposed SAT face shape mismatch");
+
+    const bool outer_weighted = mode == SatBlendMode3D::DisplacementOuterWeighted;
+    const double* outer0_data = outer0.data();
+    const double* outer1_data = outer1.data();
+    const double* outer2_data = outer2.data();
+    const double* alpha0_data = alpha0.data();
+    const double* alpha1_data = alpha1.data();
+    const double* alpha2_data = alpha2.data();
+    const double* source0_data = source0.data();
+    const double* source1_data = source1.data();
+    const double* source2_data = source2.data();
+    double* out0_data = out0.data();
+    double* out1_data = out1.data();
+    double* out2_data = out2.data();
+
+    size_t line_count = 0;
+    size_t src_stride = 0;
+    size_t tgt_stride = 0;
+    size_t src_block = 0;
+    size_t tgt_block = 0;
+    size_t block_lines = 0;
+    switch (axis) {
+    case Axis3D::X:
+        line_count = source0.ny() * source0.nz();
+        src_stride = 1;
+        tgt_stride = 1;
+        block_lines = line_count;
+        src_block = 0;
+        tgt_block = 0;
+        break;
+    case Axis3D::Y:
+        line_count = source0.nx() * source0.nz();
+        src_stride = source0.nx();
+        tgt_stride = out0.nx();
+        block_lines = source0.nx();
+        src_block = source0.nx() * source0.ny();
+        tgt_block = out0.nx() * out0.ny();
+        break;
+    case Axis3D::Z:
+        line_count = source0.nx() * source0.ny();
+        src_stride = source0.nx() * source0.ny();
+        tgt_stride = out0.nx() * out0.ny();
+        block_lines = line_count;
+        src_block = 0;
+        tgt_block = 0;
+        break;
+    }
+
+    for (size_t line = 0; line < line_count; ++line) {
+        size_t src_base = line;
+        size_t tgt_base = line;
+        if (axis == Axis3D::X) {
+            src_base = line * n_src;
+            tgt_base = line * n_tgt;
+        } else if (axis == Axis3D::Y) {
+            const size_t slice = line / block_lines;
+            const size_t inner_index = line % block_lines;
+            src_base = slice * src_block + inner_index;
+            tgt_base = slice * tgt_block + inner_index;
+        }
+        const double* src0_line = source0_data + src_base;
+        const double* src1_line = source1_data + src_base;
+        const double* src2_line = source2_data + src_base;
+        double inner0 = 0.0;
+        double inner1 = 0.0;
+        double inner2 = 0.0;
+        for (size_t s = 0; s < n_src; ++s) {
+            const double weight = src_row[s];
+            inner0 += weight * src0_line[s * src_stride];
+            inner1 += weight * src1_line[s * src_stride];
+            inner2 += weight * src2_line[s * src_stride];
+        }
+        const double a0 = alpha0_data[line];
+        const double a1 = alpha1_data[line];
+        const double a2 = alpha2_data[line];
+        const double blended0 = outer_weighted
+            ? (1.0 - a0) * inner0 + a0 * outer0_data[line]
+            : a0 * inner0 + (1.0 - a0) * outer0_data[line];
+        const double blended1 = outer_weighted
+            ? (1.0 - a1) * inner1 + a1 * outer1_data[line]
+            : a1 * inner1 + (1.0 - a1) * outer1_data[line];
+        const double blended2 = outer_weighted
+            ? (1.0 - a2) * inner2 + a2 * outer2_data[line]
+            : a2 * inner2 + (1.0 - a2) * outer2_data[line];
+        const double scaled0 = sign * blended0;
+        const double scaled1 = sign * blended1;
+        const double scaled2 = sign * blended2;
+        double* tgt0_line = out0_data + tgt_base;
+        double* tgt1_line = out1_data + tgt_base;
+        double* tgt2_line = out2_data + tgt_base;
+        for (size_t t = 0; t < n_tgt; ++t) {
+            const double weight = tgt_col[t];
+            tgt0_line[t * tgt_stride] += weight * scaled0;
+            tgt1_line[t * tgt_stride] += weight * scaled1;
+            tgt2_line[t * tgt_stride] += weight * scaled2;
+        }
+    }
+}
