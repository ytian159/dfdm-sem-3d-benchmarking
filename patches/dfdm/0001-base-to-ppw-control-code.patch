+            comp_sum = {"onset_t": onset}
+            for name in COPY_NAMES:
+                rel = r["spread"][name]["rel_spread_t"]
+                comp_sum[name] = {
+                    "early_rel_spread": float(np.median(rel[early & active])) if (early & active).any() else None,
+                    "late_rel_spread": float(np.median(rel[late])) if late.any() else None,
+                    "global_rel": r["spread"][name]["global_rel"],
+                }
+            summary[rec][comp] = comp_sum
+        if rep is None:
+            rep = (rec, res)
+
+    out_json = os.path.join(case, "copy_splitting_timeanalysis.json")
+    with open(out_json, "w") as f:
+        json.dump(summary, f, indent=1)
+    print(f"wrote {out_json}")
+
+    # text table
+    print(f"\n{'rec':5s} {'cmp':3s} {'onset':>7s} | median relative spread per copy (early window -> late window)")
+    for rec in sorted(summary):
+        for comp in COMP_NAMES:
+            if comp not in summary[rec]:
+                continue
+            s = summary[rec][comp]
+            cells = []
+            for name in COPY_NAMES:
+                e = s[name]["early_rel_spread"]
+                l = s[name]["late_rel_spread"]
+                cells.append(f"{name} {e if e is not None else float('nan'):.3f}->{l if l is not None else float('nan'):.3f}")
+            print(f"{rec:5s} {comp:3s} {s['onset_t']:7.1f} | " + "  ".join(cells))
+
+    # representative figure
+    try:
+        import matplotlib
+
+        matplotlib.use("Agg")
+        import matplotlib.pyplot as plt
+
+        rec, res = rep
+        fig, axes = plt.subplots(3, 1, figsize=(13, 10), sharex=True)
+        r = res["Z"]
+        t = r["t"]
+        for k, name in enumerate(COPY_NAMES):
+            axes[0].plot(t, r["copies"][:, k], lw=0.7, label=name)
+        axes[0].plot(t, r["mean"], "k--", lw=0.9, label="mean4")
+        axes[0].set_ylabel("Uz")
+        axes[0].legend(ncol=5, fontsize=8)
+        axes[0].set_title(f"{rec}: four staggered displacement copies (Z), surface receiver")
+        for k, name in enumerate(COPY_NAMES):
+            axes[1].plot(t, r["copies"][:, k] - r["mean"], lw=0.7, label=name)
+        axes[1].set_ylabel("copy - mean4")
+        axes[1].legend(ncol=4, fontsize=8)
+        for k, name in enumerate(COPY_NAMES):
+            axes[2].plot(t, r["spread"][name]["rel_spread_t"], lw=0.9, label=name)
+        axes[2].set_ylabel("rel. spread (windowed)")
+        axes[2].set_xlabel("time (s)")
+        axes[2].set_ylim(0, 1.5)
+        axes[2].axhline(0.05, color="gray", ls=":")
+        axes[2].legend(ncol=4, fontsize=8)
+        fig.tight_layout()
+        out_png = os.path.join(case, "copy_splitting_timeanalysis.png")
+        fig.savefig(out_png, dpi=130)
+        print(f"wrote {out_png}")
+    except Exception as exc:  # matplotlib optional
+        print(f"figure skipped: {exc}")
+
+
+if __name__ == "__main__":
+    main()
