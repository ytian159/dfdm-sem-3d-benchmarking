+void compute_reference_derivative_hat_into(Axis3D axis,
+                                           GridTag source_tag,
+                                           const AxisOperators1D& axis_ops,
+                                           const Array3D& source_hat,
+                                           const SatFaceData3D& sat,
+                                           SatBlendMode3D blend_mode,
+                                           Array3D& filtered_bspline,
+                                           Array3D& derivative,
+                                           Array3D& out) {
+    const int source_family = grid_basis_digit(source_tag, axis);
+    const int target_family = 3 - source_family;
+
+    if (axis_ops.use_precomposed) {
+        const PrecomposedAxisKernel1D& kernel =
+            axis_ops.precomposed[static_cast<size_t>(source_family - 1)];
+        if (kernel.fns.xline != nullptr) {
+            if (use_fused_fixed_sat_correction()) {
+                apply_fixed_axis_with_sat_into(
+                    axis, kernel, source_hat, sat, blend_mode, out, false);
+                return;
+            }
+            apply_fixed_axis_into(axis, kernel, source_hat, out);
+        } else {
+            apply_matrix_axis_into(axis, kernel.khat, source_hat, out);
+        }
+        if (use_precomposed_face_pair()) {
+            apply_precomposed_face_correction_pair(
+                out, source_hat, axis,
+                kernel.src_row_minus, kernel.src_row_plus,
+                kernel.tgt_col_minus, kernel.tgt_col_plus,
+                sat.minus_outer, sat.minus_alpha,
+                sat.plus_outer, sat.plus_alpha, blend_mode);
+        } else {
+            apply_precomposed_face_correction(
+                out, source_hat, axis, false,
+                kernel.src_row_minus, kernel.src_row_plus,
+                kernel.tgt_col_minus, kernel.tgt_col_plus,
+                sat.minus_outer, sat.minus_alpha, blend_mode, -1.0);
+            apply_precomposed_face_correction(
+                out, source_hat, axis, true,
+                kernel.src_row_minus, kernel.src_row_plus,
+                kernel.tgt_col_minus, kernel.tgt_col_plus,
+                sat.plus_outer, sat.plus_alpha, blend_mode, +1.0);
+        }
+        return;
+    }
+
+    apply_inverse_mass_axis_into(axis, axis_ops, source_family, true, source_hat, filtered_bspline);
+    apply_matrix_axis_into(axis, select_k_operator(axis_ops, source_family), filtered_bspline, derivative);
+    scale_in_place(derivative, -1.0);
+
+    apply_blended_face_correction_from_filtered(
+        derivative, filtered_bspline, axis, false,
+        sat.minus_outer, sat.minus_alpha, blend_mode, -1.0);
+    apply_blended_face_correction_from_filtered(
+        derivative, filtered_bspline, axis, true,
+        sat.plus_outer, sat.plus_alpha, blend_mode, +1.0);
+
+    apply_inverse_mass_axis_into(axis, axis_ops, target_family, false, derivative, out);
+}
