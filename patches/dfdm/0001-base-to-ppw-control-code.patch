+
+// Instantiated for the pairs that occur in production: |n_src - n_tgt| == 1
+// with both dims in [5, 12] (n1 = 6..12 covers porder-4 production, the
+// crust radial floor 9 and per-layer nz up to 12). Anything else returns
+// null fns (generic dgemm fallback).
+FixedAxisKernelFns lookup_fixed_axis_kernels(int n_src, int n_tgt);
+
+// Fixed-size khat plus SAT epilogue forms. These keep the same base dot order
+// as apply_{xline,bundle}{_triplet}, then apply minus-face and plus-face SAT
+// additions in that order for each output value. The bundle variants keep the
+// original vectorization across the contiguous bundle dimension.
+constexpr std::size_t kMaxSatBundle = 256;
+
+inline double sat_blend_value(double inner, double outer, double alpha, bool outer_weighted) {
+    return outer_weighted
+        ? (1.0 - alpha) * inner + alpha * outer
+        : alpha * inner + (1.0 - alpha) * outer;
+}
+
+template <int NS, int NT>
+void apply_xline_sat(const double* __restrict K,
+                     const double* __restrict row_minus,
+                     const double* __restrict row_plus,
+                     const double* __restrict col_minus,
+                     const double* __restrict col_plus,
+                     const double* __restrict in,
+                     const double* __restrict minus_outer,
+                     const double* __restrict minus_alpha,
+                     const double* __restrict plus_outer,
+                     const double* __restrict plus_alpha,
+                     double* __restrict out,
+                     bool outer_weighted,
+                     bool additive,
+                     std::size_t n_lines) {
+    for (std::size_t l = 0; l < n_lines; ++l) {
+        const double* __restrict s = in + l * static_cast<std::size_t>(NS);
+        double* __restrict d = out + l * static_cast<std::size_t>(NT);
+        double acc[NT];
+        const double s0 = s[0];
+        double inner_minus = row_minus[0] * s0;
+        double inner_plus = row_plus[0] * s0;
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            acc[t] = K[t] * s0;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double sv = s[c];
+            inner_minus += row_minus[c] * sv;
+            inner_plus += row_plus[c] * sv;
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                acc[t] += K[t + c * NT] * sv;
+            }
+        }
+        const double scaled_minus = -sat_blend_value(inner_minus, minus_outer[l], minus_alpha[l], outer_weighted);
+        const double scaled_plus = sat_blend_value(inner_plus, plus_outer[l], plus_alpha[l], outer_weighted);
+        if (additive) {
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                d[t] += acc[t];
+                d[t] += col_minus[t] * scaled_minus;
+                d[t] += col_plus[t] * scaled_plus;
+            }
+        } else {
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                double value = acc[t];
+                value += col_minus[t] * scaled_minus;
+                value += col_plus[t] * scaled_plus;
+                d[t] = value;
+            }
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_bundle_sat(const double* __restrict K,
+                      const double* __restrict row_minus,
+                      const double* __restrict row_plus,
+                      const double* __restrict col_minus,
+                      const double* __restrict col_plus,
+                      const double* __restrict in,
+                      const double* __restrict minus_outer,
+                      const double* __restrict minus_alpha,
+                      const double* __restrict plus_outer,
+                      const double* __restrict plus_alpha,
+                      double* __restrict out,
+                      std::size_t bundle,
+                      std::size_t in_cs,
+                      std::size_t out_cs,
+                      std::size_t n_slices,
+                      std::size_t in_ss,
+                      std::size_t out_ss,
+                      std::size_t face_ss,
+                      bool outer_weighted,
+                      bool additive) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict ins = in + z * in_ss;
+        double* __restrict outs = out + z * out_ss;
+        const double* __restrict mo = minus_outer + z * face_ss;
+        const double* __restrict ma = minus_alpha + z * face_ss;
+        const double* __restrict po = plus_outer + z * face_ss;
+        const double* __restrict pa = plus_alpha + z * face_ss;
+        double scaled_minus[kMaxSatBundle];
+        double scaled_plus[kMaxSatBundle];
+        const double rm0 = row_minus[0];
+        const double rp0 = row_plus[0];
+        #pragma omp simd
+        for (std::size_t i = 0; i < bundle; ++i) {
+            const double v = ins[i];
+            scaled_minus[i] = rm0 * v;
+            scaled_plus[i] = rp0 * v;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double rm = row_minus[c];
+            const double rp = row_plus[c];
+            const double* __restrict src = ins + static_cast<std::size_t>(c) * in_cs;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                const double v = src[i];
+                scaled_minus[i] += rm * v;
+                scaled_plus[i] += rp * v;
+            }
+        }
+        #pragma omp simd
+        for (std::size_t i = 0; i < bundle; ++i) {
+            scaled_minus[i] = -sat_blend_value(scaled_minus[i], mo[i], ma[i], outer_weighted);
+            scaled_plus[i] = sat_blend_value(scaled_plus[i], po[i], pa[i], outer_weighted);
+        }
+        for (int t = 0; t < NT; ++t) {
+            double* __restrict d = outs + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            const double* __restrict s0 = ins;
+            if (additive) {
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d[i] += k0 * s0[i];
+                }
+            } else {
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d[i] = k0 * s0[i];
+                }
+            }
+            for (int c = 1; c < NS; ++c) {
+                const double kv = K[t + c * NT];
+                const double* __restrict src = ins + static_cast<std::size_t>(c) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d[i] += kv * src[i];
+                }
+            }
+            const double wm = col_minus[t];
+            const double wp = col_plus[t];
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d[i] += wm * scaled_minus[i];
+            }
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d[i] += wp * scaled_plus[i];
+            }
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_xline_triplet_sat(const double* __restrict K,
+                             const double* __restrict row_minus,
+                             const double* __restrict row_plus,
+                             const double* __restrict col_minus,
+                             const double* __restrict col_plus,
+                             const double* const* in,
+                             const double* const* minus_outer,
+                             const double* const* minus_alpha,
+                             const double* const* plus_outer,
+                             const double* const* plus_alpha,
+                             double* const* out,
+                             bool outer_weighted,
+                             bool additive,
+                             std::size_t n_lines) {
+    for (std::size_t l = 0; l < n_lines; ++l) {
+        const double* __restrict s0 = in[0] + l * static_cast<std::size_t>(NS);
+        const double* __restrict s1 = in[1] + l * static_cast<std::size_t>(NS);
+        const double* __restrict s2 = in[2] + l * static_cast<std::size_t>(NS);
+        double* __restrict d0 = out[0] + l * static_cast<std::size_t>(NT);
+        double* __restrict d1 = out[1] + l * static_cast<std::size_t>(NT);
+        double* __restrict d2 = out[2] + l * static_cast<std::size_t>(NT);
+        double acc0[NT];
+        double acc1[NT];
+        double acc2[NT];
+        const double v00 = s0[0];
+        const double v10 = s1[0];
+        const double v20 = s2[0];
+        double inner_minus0 = row_minus[0] * v00;
+        double inner_minus1 = row_minus[0] * v10;
+        double inner_minus2 = row_minus[0] * v20;
+        double inner_plus0 = row_plus[0] * v00;
+        double inner_plus1 = row_plus[0] * v10;
+        double inner_plus2 = row_plus[0] * v20;
+        #pragma omp simd
+        for (int t = 0; t < NT; ++t) {
+            const double kt = K[t];
+            acc0[t] = kt * v00;
+            acc1[t] = kt * v10;
+            acc2[t] = kt * v20;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double v0 = s0[c];
+            const double v1 = s1[c];
+            const double v2 = s2[c];
+            const double rm = row_minus[c];
+            const double rp = row_plus[c];
+            inner_minus0 += rm * v0;
+            inner_minus1 += rm * v1;
+            inner_minus2 += rm * v2;
+            inner_plus0 += rp * v0;
+            inner_plus1 += rp * v1;
+            inner_plus2 += rp * v2;
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                const double kt = K[t + c * NT];
+                acc0[t] += kt * v0;
+                acc1[t] += kt * v1;
+                acc2[t] += kt * v2;
+            }
+        }
+        const double sm0 = -sat_blend_value(inner_minus0, minus_outer[0][l], minus_alpha[0][l], outer_weighted);
+        const double sm1 = -sat_blend_value(inner_minus1, minus_outer[1][l], minus_alpha[1][l], outer_weighted);
+        const double sm2 = -sat_blend_value(inner_minus2, minus_outer[2][l], minus_alpha[2][l], outer_weighted);
+        const double sp0 = sat_blend_value(inner_plus0, plus_outer[0][l], plus_alpha[0][l], outer_weighted);
+        const double sp1 = sat_blend_value(inner_plus1, plus_outer[1][l], plus_alpha[1][l], outer_weighted);
+        const double sp2 = sat_blend_value(inner_plus2, plus_outer[2][l], plus_alpha[2][l], outer_weighted);
+        if (additive) {
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                d0[t] += acc0[t];
+                d1[t] += acc1[t];
+                d2[t] += acc2[t];
+                const double wm = col_minus[t];
+                d0[t] += wm * sm0;
+                d1[t] += wm * sm1;
+                d2[t] += wm * sm2;
+                const double wp = col_plus[t];
+                d0[t] += wp * sp0;
+                d1[t] += wp * sp1;
+                d2[t] += wp * sp2;
+            }
+        } else {
+            #pragma omp simd
+            for (int t = 0; t < NT; ++t) {
+                const double wm = col_minus[t];
+                const double wp = col_plus[t];
+                double value0 = acc0[t];
+                double value1 = acc1[t];
+                double value2 = acc2[t];
+                value0 += wm * sm0;
+                value1 += wm * sm1;
+                value2 += wm * sm2;
+                value0 += wp * sp0;
+                value1 += wp * sp1;
+                value2 += wp * sp2;
+                d0[t] = value0;
+                d1[t] = value1;
+                d2[t] = value2;
+            }
+        }
+    }
+}
+
+template <int NS, int NT>
+void apply_bundle_triplet_sat(const double* __restrict K,
+                              const double* __restrict row_minus,
+                              const double* __restrict row_plus,
+                              const double* __restrict col_minus,
+                              const double* __restrict col_plus,
+                              const double* const* in,
+                              const double* const* minus_outer,
+                              const double* const* minus_alpha,
+                              const double* const* plus_outer,
+                              const double* const* plus_alpha,
+                              double* const* out,
+                              std::size_t bundle,
+                              std::size_t in_cs,
+                              std::size_t out_cs,
+                              std::size_t n_slices,
+                              std::size_t in_ss,
+                              std::size_t out_ss,
+                              std::size_t face_ss,
+                              bool outer_weighted,
+                              bool additive) {
+    for (std::size_t z = 0; z < n_slices; ++z) {
+        const double* __restrict in0s = in[0] + z * in_ss;
+        const double* __restrict in1s = in[1] + z * in_ss;
+        const double* __restrict in2s = in[2] + z * in_ss;
+        double* __restrict out0s = out[0] + z * out_ss;
+        double* __restrict out1s = out[1] + z * out_ss;
+        double* __restrict out2s = out[2] + z * out_ss;
+        const double* __restrict mo0 = minus_outer[0] + z * face_ss;
+        const double* __restrict ma0 = minus_alpha[0] + z * face_ss;
+        const double* __restrict po0 = plus_outer[0] + z * face_ss;
+        const double* __restrict pa0 = plus_alpha[0] + z * face_ss;
+        const double* __restrict mo1 = minus_outer[1] + z * face_ss;
+        const double* __restrict ma1 = minus_alpha[1] + z * face_ss;
+        const double* __restrict po1 = plus_outer[1] + z * face_ss;
+        const double* __restrict pa1 = plus_alpha[1] + z * face_ss;
+        const double* __restrict mo2 = minus_outer[2] + z * face_ss;
+        const double* __restrict ma2 = minus_alpha[2] + z * face_ss;
+        const double* __restrict po2 = plus_outer[2] + z * face_ss;
+        const double* __restrict pa2 = plus_alpha[2] + z * face_ss;
+        double sm0[kMaxSatBundle];
+        double sm1[kMaxSatBundle];
+        double sm2[kMaxSatBundle];
+        double sp0[kMaxSatBundle];
+        double sp1[kMaxSatBundle];
+        double sp2[kMaxSatBundle];
+        const double rm0 = row_minus[0];
+        const double rp0 = row_plus[0];
+        #pragma omp simd
+        for (std::size_t i = 0; i < bundle; ++i) {
+            const double v0 = in0s[i];
+            const double v1 = in1s[i];
+            const double v2 = in2s[i];
+            sm0[i] = rm0 * v0;
+            sm1[i] = rm0 * v1;
+            sm2[i] = rm0 * v2;
+            sp0[i] = rp0 * v0;
+            sp1[i] = rp0 * v1;
+            sp2[i] = rp0 * v2;
+        }
+        for (int c = 1; c < NS; ++c) {
+            const double rm = row_minus[c];
+            const double rp = row_plus[c];
+            const double* __restrict src0 = in0s + static_cast<std::size_t>(c) * in_cs;
+            const double* __restrict src1 = in1s + static_cast<std::size_t>(c) * in_cs;
+            const double* __restrict src2 = in2s + static_cast<std::size_t>(c) * in_cs;
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                const double v0 = src0[i];
+                const double v1 = src1[i];
+                const double v2 = src2[i];
+                sm0[i] += rm * v0;
+                sm1[i] += rm * v1;
+                sm2[i] += rm * v2;
+                sp0[i] += rp * v0;
+                sp1[i] += rp * v1;
+                sp2[i] += rp * v2;
+            }
+        }
+        #pragma omp simd
+        for (std::size_t i = 0; i < bundle; ++i) {
+            sm0[i] = -sat_blend_value(sm0[i], mo0[i], ma0[i], outer_weighted);
+            sm1[i] = -sat_blend_value(sm1[i], mo1[i], ma1[i], outer_weighted);
+            sm2[i] = -sat_blend_value(sm2[i], mo2[i], ma2[i], outer_weighted);
+            sp0[i] = sat_blend_value(sp0[i], po0[i], pa0[i], outer_weighted);
+            sp1[i] = sat_blend_value(sp1[i], po1[i], pa1[i], outer_weighted);
+            sp2[i] = sat_blend_value(sp2[i], po2[i], pa2[i], outer_weighted);
+        }
+        for (int t = 0; t < NT; ++t) {
+            double* __restrict d0 = out0s + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d1 = out1s + static_cast<std::size_t>(t) * out_cs;
+            double* __restrict d2 = out2s + static_cast<std::size_t>(t) * out_cs;
+            const double k0 = K[t];
+            if (additive) {
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d0[i] += k0 * in0s[i];
+                    d1[i] += k0 * in1s[i];
+                    d2[i] += k0 * in2s[i];
+                }
+            } else {
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d0[i] = k0 * in0s[i];
+                    d1[i] = k0 * in1s[i];
+                    d2[i] = k0 * in2s[i];
+                }
+            }
+            for (int c = 1; c < NS; ++c) {
+                const double kv = K[t + c * NT];
+                const double* __restrict src0 = in0s + static_cast<std::size_t>(c) * in_cs;
+                const double* __restrict src1 = in1s + static_cast<std::size_t>(c) * in_cs;
+                const double* __restrict src2 = in2s + static_cast<std::size_t>(c) * in_cs;
+                #pragma omp simd
+                for (std::size_t i = 0; i < bundle; ++i) {
+                    d0[i] += kv * src0[i];
+                    d1[i] += kv * src1[i];
+                    d2[i] += kv * src2[i];
+                }
+            }
+            const double wm = col_minus[t];
+            const double wp = col_plus[t];
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d0[i] += wm * sm0[i];
+                d1[i] += wm * sm1[i];
+                d2[i] += wm * sm2[i];
+            }
+            #pragma omp simd
+            for (std::size_t i = 0; i < bundle; ++i) {
+                d0[i] += wp * sp0[i];
+                d1[i] += wp * sp1[i];
+                d2[i] += wp * sp2[i];
+            }
+        }
+    }
+}
