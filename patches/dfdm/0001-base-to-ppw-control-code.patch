+bool use_displacement_derivative_triplet() {
+    static const bool enabled = []() {
+        const char* mode = std::getenv("DFDM_DIRECT_DERIVATIVE_TRIPLET");
+        if (mode == nullptr || mode[0] == '\0') {
+            mode = std::getenv("DFDM_DISPLACEMENT_DERIVATIVE_TRIPLET");
+        }
+        if (mode == nullptr || mode[0] == '\0') {
+            return false;
+        }
+        return std::strcmp(mode, "separate") != 0
+            && std::strcmp(mode, "legacy") != 0
+            && std::strcmp(mode, "off") != 0
+            && std::strcmp(mode, "0") != 0
+            && std::strcmp(mode, "false") != 0;
+    }();
+    return enabled;
+}
