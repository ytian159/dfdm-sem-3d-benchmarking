+// field is preserved across the mixed-nz radial interface and both cube
+// seams, and that a zero-source run stays exactly zero.
+void test_full_earth_per_layer_nz(std::ostream& out) {
+    Solver3DConfig cfg;
+    cfg.geometry_kind = "earth";
+    cfg.earth_mode = "full";
+    cfg.material_model = "constant";
+    cfg.nx = 6;
+    cfg.ny = 6;
+    cfg.nz = 6;
+    cfg.nex = 3;
+    cfg.ney = 3;
+    cfg.nez = 2;
+    cfg.porder = 4;
+    cfg.full_shell_nez_decoupled = true;
+    cfg.nz_per_layer = {6, 8};
+    cfg.outer_radius_m = 6371000.0;
+    cfg.central_cube_radius_m = 950000.0;
+    cfg.inner_core_radius_m = 1221500.0;
+    cfg.outer_core_radius_m = 3480000.0;
+    cfg.source_geographic = true;
+    cfg.source_depth_m = 30000.0;
+    cfg.receiver_geographic = true;
+    cfg.receiver_lon_degree = 1.0;
+    cfg.finalize_defaults();
+
+    require_true(total_element_count(cfg) == 6 * 3 * 3 * 2 + 3 * 3 * 3,
+                 "per-layer-nz full Earth element count mismatch");
+    require_true(nz_for_element(cfg, 0, 1) == 6 && nz_for_element(cfg, 0, 2) == 8
+                     && nz_for_element(cfg, kCentralCubeChunk3D, 2) == 6,
+                 "per-layer nz lookup mismatch");
+
+    SerialPhase1Domain3D domain(cfg);
+    require_true(domain.z_ops_layers.size() == 1
+                     && domain.z_ops_layers.count(8) == 1,
+                 "per-layer z ops registry should hold exactly the nz=8 entry");
+    for (size_t index = 0; index < domain.elements.size(); ++index) {
+        const size_t expect_nz =
+            static_cast<size_t>(nz_for_global_element(cfg, index));
+        require_true(domain.elements[index].ux.at(GridTag::G211).nz() == expect_nz,
+                     "per-layer element state nz mismatch");
+        require_true(domain.z_ops_for_local(index).n1 == static_cast<int>(expect_nz),
+                     "per-layer element z ops mismatch");
+    }
+
+    for (size_t index = 0; index < domain.elements.size(); ++index) {
+        domain.elements[index].ux = make_constant_hat_fields(
+            kDisplacementGridTags, domain.x_ops, domain.y_ops,
+            domain.z_ops_for_local(index), 1.0);
+    }
+
+    auto assert_constant_sat_vanishes = [&](size_t index, Axis3D axis, const std::string& label) {
+        AxisSatSet3D sat = domain.ux_sat_work[index];
+        populate_displacement_sat_for_component(domain, index, &ElasticState3D::ux, sat);
+        const TaggedSatFaces3D& axis_faces =
+            axis == Axis3D::X ? sat.x : (axis == Axis3D::Y ? sat.y : sat.z);
+        const AxisOperators1D& ops =
+            axis == Axis3D::X ? domain.x_ops
+                              : (axis == Axis3D::Y ? domain.y_ops
+                                                   : domain.z_ops_for_local(index));
+        for (GridTag tag : kDisplacementGridTags) {
+            const ReferenceDerivativeStage3D stage = compute_displacement_reference_derivative(
+                axis, tag, ops, domain.elements[index].ux.at(tag), axis_faces.at(tag));
+            require_near(max_abs_diff(stage.derivative_post_sat,
+                                      Array3D(stage.derivative_post_sat.nx(),
+                                              stage.derivative_post_sat.ny(),
+                                              stage.derivative_post_sat.nz(), 0.0)),
+                         1.0e-10,
+                         "per-layer-nz constant-field SAT should vanish at " + label);
+        }
+    };
+
+    for (int chunk = 0; chunk < kSurfaceChunkCount3D; ++chunk) {
+        // Bottom layer (nz=6): cube seam below, mixed-nz interface above.
+        assert_constant_sat_vanishes(
+            element_linear_index(cfg, chunk, 2, 2, 1), Axis3D::Z,
+            "shell layer 1 (cube seam below, nz 6->8 interface above)");
+        // Top layer (nz=8): mixed-nz interface below, free surface above.
+        assert_constant_sat_vanishes(
+            element_linear_index(cfg, chunk, 2, 2, 2), Axis3D::Z,
+            "shell layer 2 (nz 8->6 interface below)");
+        // Lateral seams within the nz=8 layer.
+        assert_constant_sat_vanishes(
+            element_linear_index(cfg, chunk, 1, 2, 2), Axis3D::X,
+            "chunk seam in the nz=8 layer");
+    }
+    for (Axis3D axis : {Axis3D::X, Axis3D::Y, Axis3D::Z}) {
+        assert_constant_sat_vanishes(
+            element_linear_index(cfg, kCentralCubeChunk3D, 2, 2, 2), axis,
+            "central cube interior/seam");
+    }
+
+    cfg.nt = 3;
+    cfg.source_amplitude = 0.0;
+    cfg.finalize_defaults();
+    const std::vector<ReceiverRow3D> rows = run_phase1_serial_simulation(cfg, nullptr);
+    for (const auto& row : rows) {
+        for (size_t col = 1; col < row.size(); ++col) {
+            require_near(std::abs(row[col]), 1.0e-20,
+                         "per-layer-nz zero-source run should remain zero");
+        }
+    }
+
+    out << "  full_earth_per_layer_nz_small: ok\n";
+}
