+    // or beyond the last chunk's offset belongs to the last chunk (the
+    // full-Earth central cube may be larger or smaller than a shell chunk).
+    chunk = std::min(static_cast<int>(global_index / elements_per_chunk(cfg)),
+                     chunks - 1);
