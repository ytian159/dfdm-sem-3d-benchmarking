+
+bool use_block3d_mpi_partition_mode() {
+    const char* mode = std::getenv("DFDM_MPI_PARTITION_MODE");
+    return mode != nullptr && std::strcmp(mode, "block3d") == 0;
+}
+
+bool use_isotropic_block3d_grid_heuristic() {
+    const char* mode = std::getenv("DFDM_BLOCK3D_GRID_HEURISTIC");
+    return mode != nullptr
+        && (std::strcmp(mode, "isotropic") == 0
+            || std::strcmp(mode, "balanced") == 0);
+}
+
+int block_coord_for_element(int element_coord, int extent, int parts) {
+    require_true(parts > 0, "block partition parts must be positive");
+    require_true(element_coord >= 1 && element_coord <= extent,
+                 "block partition element coordinate out of range");
+    // Inverse of block_begin/end_for_coord, whose blocks are
+    // floor(extent*b/parts)+1 .. floor(extent*(b+1)/parts).
+    return std::min(((element_coord * parts) - 1) / extent, parts - 1);
+}
+
+int block_begin_for_coord(int extent, int block_coord, int parts) {
+    return (extent * block_coord) / parts + 1;
+}
+
+int block_end_for_coord(int extent, int block_coord, int parts) {
+    return (extent * (block_coord + 1)) / parts;
+}
+
+MpiBlockGrid3D choose_mpi_block_grid(int ranks, int nex, int ney, int nez) {
+    MpiBlockGrid3D best;
+    long long best_balance = std::numeric_limits<long long>::max();
+    long long best_max_block = std::numeric_limits<long long>::max();
+    long long best_block_spread = std::numeric_limits<long long>::max();
+    long long best_cut_faces = std::numeric_limits<long long>::max();
+    const bool isotropic_heuristic = use_isotropic_block3d_grid_heuristic();
+    bool found = false;
+    for (int px = 1; px <= ranks; ++px) {
+        if (ranks % px != 0 || px > nex) {
+            continue;
+        }
+        const int rem_xy = ranks / px;
+        for (int py = 1; py <= rem_xy; ++py) {
+            if (rem_xy % py != 0 || py > ney) {
+                continue;
+            }
+            const int pz = rem_xy / py;
+            if (pz > nez) {
+                continue;
+            }
+            const long long bx = (nex + px - 1) / px;
+            const long long by = (ney + py - 1) / py;
+            const long long bz = (nez + pz - 1) / pz;
+            const long long balance = bx * by * bz;
+            const long long max_block = std::max(bx, std::max(by, bz));
+            const long long min_block = std::min(bx, std::min(by, bz));
+            const long long block_spread = max_block - min_block;
+            const long long cut_faces = static_cast<long long>(px - 1) * ney * nez
+                                      + static_cast<long long>(py - 1) * nex * nez
+                                      + static_cast<long long>(pz - 1) * nex * ney;
+            bool better = false;
+            if (!found) {
+                better = true;
+            } else if (isotropic_heuristic) {
+                better = max_block < best_max_block
+                    || (max_block == best_max_block && block_spread < best_block_spread)
+                    || (max_block == best_max_block && block_spread == best_block_spread
+                        && cut_faces < best_cut_faces);
+            } else {
+                better = balance < best_balance
+                    || (balance == best_balance && cut_faces < best_cut_faces);
+            }
+            if (better) {
+                found = true;
+                best_balance = balance;
+                best_max_block = max_block;
+                best_block_spread = block_spread;
+                best_cut_faces = cut_faces;
+                best = {px, py, pz};
+            }
+        }
+    }
+    require_true(found, "No valid 3D MPI block grid for chunk rank count");
+    return best;
+}
