+    const std::array<size_t, 3> local_dims = {
+        local_face.nx(), local_face.ny(), local_face.nz(),
+    };
+    std::array<bool, 3> neighbor_axis_seen = {false, false, false};
+    for (int local_axis_index = 0; local_axis_index < 3; ++local_axis_index) {
+        const Axis3D neighbor_axis =
+            conn.local_to_neighbor_axis[static_cast<size_t>(local_axis_index)];
+        const int neighbor_axis_index = axis_index(neighbor_axis);
+        if (neighbor_axis_seen[static_cast<size_t>(neighbor_axis_index)]) {
+            return false;
+        }
+        neighbor_axis_seen[static_cast<size_t>(neighbor_axis_index)] = true;
+        if (local_dims[static_cast<size_t>(local_axis_index)]
+                != oriented_array_dim_for_axis(neighbor_face, neighbor_axis)) {
