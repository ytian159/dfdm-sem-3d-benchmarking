+
+size_t elements_in_chunk(const Solver3DConfig& cfg, int chunk) {
+    return static_cast<size_t>(cfg.nex)
+         * static_cast<size_t>(cfg.ney)
+         * static_cast<size_t>(chunk_nez(cfg, chunk));
