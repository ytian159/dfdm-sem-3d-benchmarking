+                             int equation,
+                             const FaceNeighbor3D& minus_conn,
+                             const FaceNeighbor3D& plus_conn,
+                             TaggedSatFaces3D& faces) {
+        const StressPullbackFields3D* minus_neighbor =
+            mpi_pullback_for_global(domain, minus_conn.index, pullback_ghosts);
+        const StressPullbackFields3D* plus_neighbor =
+            mpi_pullback_for_global(domain, plus_conn.index, pullback_ghosts);
+        populate_oriented_neighbor_pullback_outer_faces(
+            axis, equation, local_ops,
+            ops_for_neighbor(minus_conn.index),
+            ops_for_neighbor(plus_conn.index),
+            minus_neighbor, plus_neighbor, minus_conn, plus_conn, kStressGridTags, faces);
+    };
+
+    populate_axis(Axis3D::X, 1,
+                  neighbors.x_minus_conn, neighbors.x_plus_conn, sat.eq1.x);
+    populate_axis(Axis3D::Y, 1,
+                  neighbors.y_minus_conn, neighbors.y_plus_conn, sat.eq1.y);
+    populate_axis(Axis3D::Z, 1,
+                  neighbors.z_minus_conn, neighbors.z_plus_conn, sat.eq1.z);
+    populate_axis(Axis3D::X, 2,
+                  neighbors.x_minus_conn, neighbors.x_plus_conn, sat.eq2.x);
+    populate_axis(Axis3D::Y, 2,
+                  neighbors.y_minus_conn, neighbors.y_plus_conn, sat.eq2.y);
+    populate_axis(Axis3D::Z, 2,
+                  neighbors.z_minus_conn, neighbors.z_plus_conn, sat.eq2.z);
+    populate_axis(Axis3D::X, 3,
+                  neighbors.x_minus_conn, neighbors.x_plus_conn, sat.eq3.x);
+    populate_axis(Axis3D::Y, 3,
+                  neighbors.y_minus_conn, neighbors.y_plus_conn, sat.eq3.y);
+    populate_axis(Axis3D::Z, 3,
+                  neighbors.z_minus_conn, neighbors.z_plus_conn, sat.eq3.z);
+}
+
+// ---------------------------------------------------------------------------
+// Face-plane MPI halo exchange ("face" mode, the default).
+//
+// The SAT coupling consumes exactly one inverse-mass-filtered face plane per
+// (neighbor face, field, grid tag): see populate_oriented_neighbor_outer_faces
+// and populate_oriented_neighbor_pullback_outer_faces. Those planes are pure
+// functions of the owning element's data and the axis operators every rank
+// builds identically, so the owner can extract them and ship only the planes.
+// This is bitwise identical to the volume exchange while shrinking the payload
+// by roughly the element thickness (and, for the pullback, by the additional
+// 3x from sending only the connection-axis fields). It also replaces the
+// full-communicator Alltoallv collectives with point-to-point neighbor
+// messages into persistent buffers, so no per-step allocation remains.
+//
+// Entry layout per exported face, in doubles:
+//   displacement: [ux | uy | uz] x [kDisplacementGridTags in canonical order]
+//   pullback:     [eq1 | eq2 | eq3] x [kStressGridTags in canonical order],
+//                 where eqN is the owner's eqN_d_d{axis}p for the face axis.
+// Both sides compute identical offsets from (global, axis, plus) keys sorted
+// the same way, so no index metadata is exchanged after the setup handshake.
+// ---------------------------------------------------------------------------
+
+size_t face_plane_value_count_for_counts(GridTag tag,
+                                         Axis3D axis,
+                                         const ElementBasisCounts3D& counts) {
+    const GridShape3D grid = shape_for_grid(tag, counts.nx, counts.ny, counts.nz);
+    const GridShape3D face = face_shape_for_axis(axis, grid);
+    return static_cast<size_t>(face.nx) * static_cast<size_t>(face.ny)
+         * static_cast<size_t>(face.nz);
+}
+
+size_t face_plane_value_count(const Solver3DConfig& cfg, GridTag tag, Axis3D axis,
+                              int nz_points = 0) {
+    const ElementBasisCounts3D counts = {
+        cfg.nx,
+        cfg.ny,
+        nz_points > 0 ? nz_points : cfg.nz,
+    };
+    return face_plane_value_count_for_counts(tag, axis, counts);
+}
+
+size_t face_tag_set_value_count_for_counts(const std::array<GridTag, 4>& tags,
+                                           Axis3D axis,
+                                           const ElementBasisCounts3D& counts) {
+    size_t total = 0;
+    for (GridTag tag : tags) {
+        total += face_plane_value_count_for_counts(tag, axis, counts);
+    }
+    return total;
+}
+
+size_t face_tag_set_value_count(const Solver3DConfig& cfg,
+                                const std::array<GridTag, 4>& tags,
+                                Axis3D axis,
+                                int nz_points = 0) {
+    const ElementBasisCounts3D counts = {
+        cfg.nx,
+        cfg.ny,
+        nz_points > 0 ? nz_points : cfg.nz,
+    };
+    return face_tag_set_value_count_for_counts(tags, axis, counts);
+}
+
+struct MpiFaceHaloEntry3D {
+    int global = -1;  // owning element's global index
+    int axis = 0;     // face axis in the owner's frame
+    int plus = 0;     // 1 = owner's plus face, 0 = owner's minus face
+    int local = -1;   // owner-rank local element index (export entries only)
+    size_t displacement_offset = 0;  // offsets in doubles into the rank buffers
+    size_t pullback_offset = 0;
+};
+
+struct MpiFaceHaloPlan3D {
+    std::vector<int> neighbor_ranks;
+    std::vector<std::vector<MpiFaceHaloEntry3D>> exports;
+    std::vector<std::vector<MpiFaceHaloEntry3D>> imports;
+    std::vector<std::vector<double>> displacement_send;
+    std::vector<std::vector<double>> displacement_recv;
+    std::vector<std::vector<double>> pullback_send;
+    std::vector<std::vector<double>> pullback_recv;
+    std::vector<std::pair<size_t, size_t>> flat_exports;  // (rank slot, entry)
+    // Per local element and face slot (axis * 2 + plus): base pointer of the
+    // matching import entry in the recv buffer, or nullptr when the neighbor
+    // is local or absent.
+    std::vector<std::array<const double*, 6>> displacement_ghost_faces;
+    std::vector<std::array<const double*, 6>> pullback_ghost_faces;
+    // Elements with no remote neighbor can be computed while halo messages
+    // are in flight; boundary elements wait for the receive completion.
+    std::vector<int> interior_locals;
+    std::vector<int> boundary_locals;
+    std::vector<MPI_Request> requests;  // in-flight requests of the current phase
+};
+
+bool use_face_halo_debug() {
+    static const bool enabled = []() {
+        const char* mode = std::getenv("DFDM_FACE_HALO_DEBUG");
+        if (mode == nullptr || mode[0] == '\0') {
+            return false;
+        }
+        return std::strcmp(mode, "off") != 0
+            && std::strcmp(mode, "0") != 0
+            && std::strcmp(mode, "false") != 0;
+    }();
+    return enabled;
+}
+
+void verify_face_halo_plan_symmetry(const MpiFaceHaloPlan3D& plan, MPI_Comm comm) {
+    int comm_rank = 0;
+    int comm_size = 1;
+    MPI_Comm_rank(comm, &comm_rank);
+    MPI_Comm_size(comm, &comm_size);
+    std::vector<int> send_counts(static_cast<size_t>(comm_size), 0);
+    std::vector<int> send_displacements(static_cast<size_t>(comm_size), 0);
+    std::vector<int> recv_counts(static_cast<size_t>(comm_size), 0);
+    std::vector<int> recv_displacements(static_cast<size_t>(comm_size), 0);
+    std::vector<int> send_flat;
+    for (size_t ri = 0; ri < plan.neighbor_ranks.size(); ++ri) {
+        send_counts[static_cast<size_t>(plan.neighbor_ranks[ri])] =
+            static_cast<int>(3 * plan.exports[ri].size());
+    }
+    int offset = 0;
+    for (int rank = 0; rank < comm_size; ++rank) {
+        send_displacements[static_cast<size_t>(rank)] = offset;
+        offset += send_counts[static_cast<size_t>(rank)];
+    }
+    send_flat.assign(static_cast<size_t>(offset), 0);
+    for (size_t ri = 0; ri < plan.neighbor_ranks.size(); ++ri) {
+        int* out = send_flat.data()
+                 + send_displacements[static_cast<size_t>(plan.neighbor_ranks[ri])];
+        for (const MpiFaceHaloEntry3D& entry : plan.exports[ri]) {
+            *out++ = entry.global;
+            *out++ = entry.axis;
+            *out++ = entry.plus;
+        }
+    }
+    MPI_Alltoall(send_counts.data(), 1, MPI_INT, recv_counts.data(), 1, MPI_INT, comm);
+    offset = 0;
+    for (int rank = 0; rank < comm_size; ++rank) {
+        recv_displacements[static_cast<size_t>(rank)] = offset;
+        offset += recv_counts[static_cast<size_t>(rank)];
+    }
+    std::vector<int> recv_flat(static_cast<size_t>(offset), 0);
+    MPI_Alltoallv(send_flat.data(), send_counts.data(), send_displacements.data(), MPI_INT,
+                  recv_flat.data(), recv_counts.data(), recv_displacements.data(), MPI_INT,
+                  comm);
+    for (size_t ri = 0; ri < plan.neighbor_ranks.size(); ++ri) {
+        const int rank = plan.neighbor_ranks[ri];
+        const int received_count = recv_counts[static_cast<size_t>(rank)];
+        const int expected_count = static_cast<int>(3 * plan.imports[ri].size());
+        if (received_count != expected_count && use_face_halo_debug()) {
+            std::cerr << "DFDM_FACE_HALO_DEBUG rank=" << comm_rank
+                      << " peer=" << rank
+                      << " received_triplets=" << (received_count / 3)
+                      << " expected_triplets=" << (expected_count / 3)
+                      << " exports_to_peer=" << plan.exports[ri].size()
+                      << " imports_from_peer=" << plan.imports[ri].size() << "\n";
+            const int* received = recv_flat.data() + recv_displacements[static_cast<size_t>(rank)];
+            const int received_triplets = received_count / 3;
+            const int show_received = std::min(received_triplets, 8);
+            for (int i = 0; i < show_received; ++i) {
+                std::cerr << "  received[" << i << "] global=" << received[3 * i]
+                          << " axis=" << received[3 * i + 1]
+                          << " plus=" << received[3 * i + 2] << "\n";
+            }
+            const int show_expected = std::min(static_cast<int>(plan.imports[ri].size()), 8);
+            for (int i = 0; i < show_expected; ++i) {
+                const MpiFaceHaloEntry3D& entry = plan.imports[ri][static_cast<size_t>(i)];
+                std::cerr << "  expected[" << i << "] global=" << entry.global
+                          << " axis=" << entry.axis
+                          << " plus=" << entry.plus << "\n";
+            }
+        }
+        require_true(received_count == expected_count,
+                     "MPI face halo import/export count mismatch");
+        const int* in = recv_flat.data() + recv_displacements[static_cast<size_t>(rank)];
+        for (const MpiFaceHaloEntry3D& entry : plan.imports[ri]) {
+            if (!(in[0] == entry.global && in[1] == entry.axis && in[2] == entry.plus)
+                && use_face_halo_debug()) {
+                std::cerr << "DFDM_FACE_HALO_DEBUG key_mismatch rank=" << comm_rank
+                          << " peer=" << rank
+                          << " received global=" << in[0]
+                          << " axis=" << in[1]
+                          << " plus=" << in[2]
+                          << " expected global=" << entry.global
+                          << " axis=" << entry.axis
+                          << " plus=" << entry.plus << "\n";
+            }
+            require_true(in[0] == entry.global && in[1] == entry.axis && in[2] == entry.plus,
+                         "MPI face halo import/export key mismatch");
+            in += 3;
+        }
+    }
+}
+
+MpiFaceHaloPlan3D build_mpi_face_halo_plan(const MpiPhase1Domain3D& domain, MPI_Comm comm) {
+    const Solver3DConfig& cfg = domain.cfg;
+    MpiFaceHaloPlan3D plan;
+
+    // Entry sizes depend on the OWNING element's full per-layer basis counts.
+    // Both sides compute them from the entry's global index, so offsets stay
+    // symmetric across ranks without exchanging shape metadata.
+    auto displacement_entry_size = [&](int global, int axis) {
+        const ElementBasisCounts3D counts =
+            basis_counts_for_global_element(cfg, static_cast<size_t>(global));
+        return 3 * face_tag_set_value_count_for_counts(
+            kDisplacementGridTags, axis_from_index(axis), counts);
+    };
+    auto pullback_entry_size = [&](int global, int axis) {
+        const ElementBasisCounts3D counts =
+            basis_counts_for_global_element(cfg, static_cast<size_t>(global));
+        return 3 * face_tag_set_value_count_for_counts(
+            kStressGridTags, axis_from_index(axis), counts);
+    };
+
+    using FaceKey = std::array<int, 3>;  // (global, axis, plus)
+    std::map<int, std::map<FaceKey, MpiFaceHaloEntry3D>> exports_by_rank;
+    std::map<int, std::map<FaceKey, std::vector<std::pair<size_t, size_t>>>> imports_by_rank;
+
+    const size_t local_count = domain.elements.size();
+    const std::array<const double*, 6> null_faces = {
+        nullptr, nullptr, nullptr, nullptr, nullptr, nullptr,
+    };
+    plan.displacement_ghost_faces.assign(local_count, null_faces);
+    plan.pullback_ghost_faces.assign(local_count, null_faces);
+
+    for (size_t local = 0; local < local_count; ++local) {
+        const SerialElementNeighbors3D& neighbors = domain.neighbors[local];
+        const std::array<const FaceNeighbor3D*, 6> conns = {
+            &neighbors.x_minus_conn, &neighbors.x_plus_conn,
+            &neighbors.y_minus_conn, &neighbors.y_plus_conn,
+            &neighbors.z_minus_conn, &neighbors.z_plus_conn,
+        };
+        for (size_t slot = 0; slot < conns.size(); ++slot) {
+            const FaceNeighbor3D& conn = *conns[slot];
+            if (conn.index < 0) {
+                continue;
+            }
+            const int owner = mpi_owner_for_global_index(
+                domain.partition, cfg, static_cast<size_t>(conn.index),
+                domain.global_element_count, domain.size);
+            if (owner == domain.rank) {
+                continue;
+            }
+            // Import: the neighbor's face plane, keyed in the neighbor's frame.
+            const FaceKey import_key = {
+                conn.index,
+                axis_index(conn.neighbor_axis),
+                conn.neighbor_plus_face ? 1 : 0,
+            };
+            imports_by_rank[owner][import_key].push_back({local, slot});
+            // Export: our own face that touches that remote element. By the
+            // symmetry of the connection tables, the remote rank generates the
+            // matching import key for exactly this face.
+            const FaceKey export_key = {
+                static_cast<int>(domain.local_to_global[local]),
+                static_cast<int>(slot / 2),
+                (slot % 2 == 1) ? 1 : 0,
+            };
+            MpiFaceHaloEntry3D entry;
+            entry.global = export_key[0];
+            entry.axis = export_key[1];
+            entry.plus = export_key[2];
+            entry.local = static_cast<int>(local);
+            exports_by_rank[owner].emplace(export_key, entry);
+        }
+    }
+
+    require_true(exports_by_rank.size() == imports_by_rank.size(),
+                 "MPI face halo neighbor rank set mismatch");
+    for (const auto& rank_and_exports : exports_by_rank) {
+        require_true(imports_by_rank.count(rank_and_exports.first) == 1,
+                     "MPI face halo neighbor rank set mismatch");
+        plan.neighbor_ranks.push_back(rank_and_exports.first);
+    }
+
+    const size_t rank_count = plan.neighbor_ranks.size();
+    plan.exports.resize(rank_count);
+    plan.imports.resize(rank_count);
+    plan.displacement_send.resize(rank_count);
+    plan.displacement_recv.resize(rank_count);
+    plan.pullback_send.resize(rank_count);
+    plan.pullback_recv.resize(rank_count);
+
+    std::vector<std::vector<std::vector<std::pair<size_t, size_t>>>> import_consumers(rank_count);
+    for (size_t ri = 0; ri < rank_count; ++ri) {
+        const int rank = plan.neighbor_ranks[ri];
+        size_t displacement_offset = 0;
+        size_t pullback_offset = 0;
+        for (const auto& key_and_entry : exports_by_rank.at(rank)) {
+            MpiFaceHaloEntry3D entry = key_and_entry.second;
+            entry.displacement_offset = displacement_offset;
+            entry.pullback_offset = pullback_offset;
+            displacement_offset += displacement_entry_size(entry.global, entry.axis);
+            pullback_offset += pullback_entry_size(entry.global, entry.axis);
+            plan.exports[ri].push_back(entry);
+        }
+        plan.displacement_send[ri].assign(displacement_offset, 0.0);
+        plan.pullback_send[ri].assign(pullback_offset, 0.0);
+
+        displacement_offset = 0;
+        pullback_offset = 0;
+        for (const auto& key_and_consumers : imports_by_rank.at(rank)) {
+            MpiFaceHaloEntry3D entry;
+            entry.global = key_and_consumers.first[0];
+            entry.axis = key_and_consumers.first[1];
+            entry.plus = key_and_consumers.first[2];
+            entry.displacement_offset = displacement_offset;
+            entry.pullback_offset = pullback_offset;
+            displacement_offset += displacement_entry_size(entry.global, entry.axis);
+            pullback_offset += pullback_entry_size(entry.global, entry.axis);
+            plan.imports[ri].push_back(entry);
+            import_consumers[ri].push_back(key_and_consumers.second);
+        }
+        plan.displacement_recv[ri].assign(displacement_offset, 0.0);
+        plan.pullback_recv[ri].assign(pullback_offset, 0.0);
+    }
+
+    // Buffers are fully sized now, so the consumer pointers stay stable.
+    for (size_t ri = 0; ri < rank_count; ++ri) {
+        for (size_t ei = 0; ei < plan.imports[ri].size(); ++ei) {
+            const MpiFaceHaloEntry3D& entry = plan.imports[ri][ei];
+            for (const std::pair<size_t, size_t>& consumer : import_consumers[ri][ei]) {
+                plan.displacement_ghost_faces[consumer.first][consumer.second] =
+                    plan.displacement_recv[ri].data() + entry.displacement_offset;
+                plan.pullback_ghost_faces[consumer.first][consumer.second] =
+                    plan.pullback_recv[ri].data() + entry.pullback_offset;
+            }
+        }
+        for (size_t ei = 0; ei < plan.exports[ri].size(); ++ei) {
+            plan.flat_exports.push_back({ri, ei});
+        }
+    }
+
+    for (size_t local = 0; local < local_count; ++local) {
+        const std::array<const double*, 6>& faces = plan.displacement_ghost_faces[local];
+        const bool has_remote_neighbor =
+            std::any_of(faces.begin(), faces.end(),
+                        [](const double* face) { return face != nullptr; });
+        if (has_remote_neighbor) {
+            plan.boundary_locals.push_back(static_cast<int>(local));
+        } else {
+            plan.interior_locals.push_back(static_cast<int>(local));
+        }
+    }
+    plan.requests.reserve(2 * rank_count);
+
+    verify_face_halo_plan_symmetry(plan, comm);
+    return plan;
+}
+
+const AxisOperators1D& axis_ops_for_index(const MpiPhase1Domain3D& domain, int axis) {
+    switch (axis_from_index(axis)) {
+    case Axis3D::X: return domain.x_ops;
+    case Axis3D::Y: return domain.y_ops;
+    case Axis3D::Z: return domain.z_ops;
+    }
+    throw std::runtime_error("Unknown axis in axis_ops_for_index");
+}
+
+// MPI variants of the per-element face-cache fill (sat_face_cache="on").
+void fill_displacement_face_cache_mpi(MpiPhase1Domain3D& domain, size_t local_index) {
+    fill_displacement_face_cache_for_element(
+        domain.elements[local_index], domain.neighbors[local_index],
+        domain.x_ops_for_local(local_index),
+        domain.y_ops_for_local(local_index),
+        domain.z_ops_for_local(local_index),
+        domain.displacement_face_cache[local_index]);
+}
+
+void fill_stress_face_cache_mpi(MpiPhase1Domain3D& domain, size_t local_index) {
+    fill_stress_face_cache_for_element(
+        domain.worksets[local_index].pullback, domain.neighbors[local_index],
+        domain.x_ops_for_local(local_index),
+        domain.y_ops_for_local(local_index),
+        domain.z_ops_for_local(local_index),
+        domain.stress_face_cache[local_index]);
+}
+
+// Team variant: orphaned worksharing, callable from inside an existing
+// parallel region (distributes over the team; implied barrier at loop end).
+void pack_face_displacement_halos_team(const MpiPhase1Domain3D& domain,
+                                       MpiFaceHaloPlan3D& plan) {
+    const long long flat_count = static_cast<long long>(plan.flat_exports.size());
+    #pragma omp for schedule(static)
+    for (long long fi = 0; fi < flat_count; ++fi) {
+        const std::pair<size_t, size_t>& slot = plan.flat_exports[static_cast<size_t>(fi)];
+        const MpiFaceHaloEntry3D& entry = plan.exports[slot.first][slot.second];
+        const Axis3D axis = axis_from_index(entry.axis);
+        const size_t owner_local = static_cast<size_t>(entry.local);
+        const AxisOperators1D& ops = axis_ops_from_ptrs(
+            {&domain.x_ops_for_local(owner_local),
+             &domain.y_ops_for_local(owner_local),
+             &domain.z_ops_for_local(owner_local)},
+            axis);
+        const ElasticState3D& state = domain.elements[owner_local];
+        double* out = plan.displacement_send[slot.first].data() + entry.displacement_offset;
+        if (domain.use_sat_face_cache) {
+            const ElementFaceCache3D& cache =
+                domain.displacement_face_cache[static_cast<size_t>(entry.local)];
+            for (size_t member = 0; member < 3; ++member) {
+                for (size_t tag_slot = 0; tag_slot < kDisplacementGridTags.size(); ++tag_slot) {
+                    const Array3D& face = cache.faces[ElementFaceCache3D::slot(
+                        axis, entry.plus != 0, member, tag_slot)];
+                    std::copy(face.data(), face.data() + face.size(), out);
+                    out += face.size();
+                }
+            }
+            continue;
+        }
+        const std::array<const TaggedFields3D*, 3> members = {
+            &state.ux, &state.uy, &state.uz,
+        };
+        for (const TaggedFields3D* member : members) {
+            for (GridTag tag : kDisplacementGridTags) {
+                const int family = grid_basis_digit(tag, axis);
+                const Array3D face = extract_inverse_mass_face(
+                    axis, ops, family, member->at(tag), entry.plus != 0, true);
+                std::copy(face.data(), face.data() + face.size(), out);
+                out += face.size();
+            }
+        }
+    }
+}
+
+void pack_face_displacement_halos(const MpiPhase1Domain3D& domain,
+                                  MpiFaceHaloPlan3D& plan,
+                                  bool use_openmp) {
+    #pragma omp parallel if(use_openmp)
+    {
+        pack_face_displacement_halos_team(domain, plan);
+    }
+}
+
+void pack_face_pullback_halos_team(const MpiPhase1Domain3D& domain,
+                                   MpiFaceHaloPlan3D& plan) {
+    const long long flat_count = static_cast<long long>(plan.flat_exports.size());
+    #pragma omp for schedule(static)
+    for (long long fi = 0; fi < flat_count; ++fi) {
+        const std::pair<size_t, size_t>& slot = plan.flat_exports[static_cast<size_t>(fi)];
+        const MpiFaceHaloEntry3D& entry = plan.exports[slot.first][slot.second];
+        const Axis3D axis = axis_from_index(entry.axis);
+        const size_t owner_local = static_cast<size_t>(entry.local);
+        const AxisOperators1D& ops = axis_ops_from_ptrs(
+            {&domain.x_ops_for_local(owner_local),
+             &domain.y_ops_for_local(owner_local),
