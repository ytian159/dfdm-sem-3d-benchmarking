+MpiPartition3D build_mpi_partition_3d(const Solver3DConfig& cfg, int mpi_size) {
+    MpiPartition3D partition;
+    const int chunks = active_chunk_count(cfg);
+    partition.chunk_rank_begin.assign(static_cast<size_t>(chunks), 0);
+    partition.chunk_rank_count.assign(static_cast<size_t>(chunks), 0);
+    partition.chunk_grids.assign(static_cast<size_t>(chunks), {});
+    if (!use_block3d_mpi_partition_mode() || mpi_size < chunks) {
+        return partition;
+    }
+    partition.block3d = true;
+    const int base = mpi_size / chunks;
+    const int rem = mpi_size % chunks;
+    int begin = 0;
+    for (int chunk = 0; chunk < chunks; ++chunk) {
+        const int ranks = base + (chunk < rem ? 1 : 0);
+        partition.chunk_rank_begin[static_cast<size_t>(chunk)] = begin;
+        partition.chunk_rank_count[static_cast<size_t>(chunk)] = ranks;
+        partition.chunk_grids[static_cast<size_t>(chunk)] =
+            choose_mpi_block_grid(ranks, cfg.nex, cfg.ney, chunk_nez(cfg, chunk));
+        begin += ranks;
+    }
+    return partition;
+}
+
+int mpi_owner_for_global_index(const MpiPartition3D& partition,
+                               const Solver3DConfig& cfg,
+                               size_t global_index,
+                               size_t global_count,
+                               int mpi_size) {
+    if (!partition.block3d) {
+        return mpi_owner_for_global_index(global_index, global_count, mpi_size);
+    }
+    int chunk = 0;
+    int element_x = 1;
+    int element_y = 1;
+    int element_z = 1;
+    decode_element_global_index(cfg, global_index, chunk, element_x, element_y, element_z);
+    const MpiBlockGrid3D grid = partition.chunk_grids[static_cast<size_t>(chunk)];
+    const int bx = block_coord_for_element(element_x, cfg.nex, grid.px);
+    const int by = block_coord_for_element(element_y, cfg.ney, grid.py);
+    const int bz = block_coord_for_element(element_z, chunk_nez(cfg, chunk), grid.pz);
+    const int local_rank = bx + grid.px * (by + grid.py * bz);
+    return partition.chunk_rank_begin[static_cast<size_t>(chunk)] + local_rank;
+}
+
+std::vector<size_t> enumerate_mpi_rank_globals(const Solver3DConfig& cfg,
+                                               const MpiPartition3D& partition,
+                                               int rank,
+                                               int mpi_size,
+                                               size_t global_count) {
+    std::vector<size_t> globals;
+    if (!partition.block3d) {
+        const size_t begin = mpi_rank_begin(global_count, rank, mpi_size);
+        const size_t end = mpi_rank_end(global_count, rank, mpi_size);
+        globals.reserve(end - begin);
+        for (size_t global = begin; global < end; ++global) {
+            globals.push_back(global);
+        }
+        return globals;
+    }
+    const int chunks = active_chunk_count(cfg);
+    int owned_chunk = -1;
+    int local_rank = -1;
+    for (int chunk = 0; chunk < chunks; ++chunk) {
+        const int begin = partition.chunk_rank_begin[static_cast<size_t>(chunk)];
+        const int count = partition.chunk_rank_count[static_cast<size_t>(chunk)];
+        if (rank >= begin && rank < begin + count) {
+            owned_chunk = chunk;
+            local_rank = rank - begin;
+            break;
+        }
+    }
+    require_true(owned_chunk >= 0, "MPI block partition rank has no chunk");
+    const MpiBlockGrid3D grid = partition.chunk_grids[static_cast<size_t>(owned_chunk)];
+    const int bx = local_rank % grid.px;
+    const int by = (local_rank / grid.px) % grid.py;
+    const int bz = local_rank / (grid.px * grid.py);
+    const int x_begin = block_begin_for_coord(cfg.nex, bx, grid.px);
+    const int x_end = block_end_for_coord(cfg.nex, bx, grid.px);
+    const int y_begin = block_begin_for_coord(cfg.ney, by, grid.py);
+    const int y_end = block_end_for_coord(cfg.ney, by, grid.py);
+    const int z_begin = block_begin_for_coord(chunk_nez(cfg, owned_chunk), bz, grid.pz);
+    const int z_end = block_end_for_coord(chunk_nez(cfg, owned_chunk), bz, grid.pz);
+    globals.reserve(static_cast<size_t>(x_end - x_begin + 1)
+                    * static_cast<size_t>(y_end - y_begin + 1)
+                    * static_cast<size_t>(z_end - z_begin + 1));
+    for (int element_z = z_begin; element_z <= z_end; ++element_z) {
+        for (int element_y = y_begin; element_y <= y_end; ++element_y) {
+            for (int element_x = x_begin; element_x <= x_end; ++element_x) {
+                globals.push_back(element_linear_index(cfg, owned_chunk, element_x, element_y, element_z));
+            }
+        }
+    }
+    return globals;
+}
