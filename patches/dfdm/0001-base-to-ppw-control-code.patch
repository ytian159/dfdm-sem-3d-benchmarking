+// Assemble the family-1 displacement-stage chain matrix along one axis over
+// the full bounded element chain, with the production SAT closure (alpha_in =
+// 0.5 interior, alpha_bd = 0.0 at domain boundaries). Mirrors the audit's
+// build_periodic_stage_matrix (src/tools/audit_axis_dispersion.cpp) with
+// bounded ends instead of periodic wrap. Output: (E*n_tgt) x (E*n_src).
+ElasticMatrix build_r2_family1_chain_matrix(const Solver3DConfig& cfg,
+                                            Axis3D axis,
+                                            const AxisOperators1D& ops) {
+    // Any displacement tag with digit 1 on `axis`; the 1D chain operator is
+    // identical for every such tag (verified blend/operator symmetric).
+    const GridTag src_tag = (axis == Axis3D::X) ? GridTag::G121 : GridTag::G211;
+    require_true(grid_basis_digit(src_tag, axis) == 1,
+                 "r2 filter: chain source tag must be family-1 on the chain axis");
+    const GridTag tgt_tag = toggle_grid_tag(src_tag, axis);
+    const GridShape3D sshape = shape_for_grid(src_tag, cfg.nx, cfg.ny, cfg.nz);
+    const GridShape3D tshape = shape_for_grid(tgt_tag, cfg.nx, cfg.ny, cfg.nz);
+
+    int E = 0;
+    int n_src = 0;
+    int n_tgt = 0;
+    switch (axis) {
+    case Axis3D::X:
+        E = cfg.nex; n_src = sshape.nx; n_tgt = tshape.nx;
+        break;
+    case Axis3D::Y:
+        E = cfg.ney; n_src = sshape.ny; n_tgt = tshape.ny;
+        break;
+    case Axis3D::Z:
+        E = cfg.nez; n_src = sshape.nz; n_tgt = tshape.nz;
+        break;
+    }
+    require_true(E >= 3, "r2 filter requires at least 3 elements per axis");
+
+    std::vector<TaggedFields3D> fields(static_cast<size_t>(E));
+    for (int e = 0; e < E; ++e) {
+        fields[static_cast<size_t>(e)].at(src_tag).resize(
+            static_cast<size_t>(sshape.nx), static_cast<size_t>(sshape.ny),
+            static_cast<size_t>(sshape.nz));
+    }
+
+    // Production boundary closure per chain position; only the driven axis's
+    // SAT faces are consumed, the transverse coordinates are placeholders.
+    std::vector<AxisSatSet3D> sat_pos(static_cast<size_t>(E));
+    for (int e = 0; e < E; ++e) {
+        const int ex = (axis == Axis3D::X) ? e + 1 : 1;
+        const int ey = (axis == Axis3D::Y) ? e + 1 : 1;
+        const int ez = (axis == Axis3D::Z) ? e + 1 : 1;
+        sat_pos[static_cast<size_t>(e)] =
+            build_domain_zero_outer_sat_faces(cfg, ex, ey, ez, 0.5, 0.0);
+    }
+
+    const std::array<GridTag, 4> tags4 = {src_tag, src_tag, src_tag, src_tag};
+    auto set_line_value = [&](Array3D& f, int line_index, double value) {
+        switch (axis) {
+        case Axis3D::X:
+            for (size_t k = 0; k < f.nz(); ++k)
+                for (size_t j = 0; j < f.ny(); ++j)
+                    f(static_cast<size_t>(line_index), j, k) = value;
+            break;
+        case Axis3D::Y:
+            for (size_t k = 0; k < f.nz(); ++k)
+                for (size_t i = 0; i < f.nx(); ++i)
+                    f(i, static_cast<size_t>(line_index), k) = value;
+            break;
+        case Axis3D::Z:
+            for (size_t j = 0; j < f.ny(); ++j)
+                for (size_t i = 0; i < f.nx(); ++i)
+                    f(i, j, static_cast<size_t>(line_index)) = value;
+            break;
+        }
+    };
+    auto read_line_value = [&](const Array3D& f, int line_index) {
+        switch (axis) {
+        case Axis3D::X: return f(static_cast<size_t>(line_index), 0, 0);
+        case Axis3D::Y: return f(0, static_cast<size_t>(line_index), 0);
+        case Axis3D::Z: return f(0, 0, static_cast<size_t>(line_index));
+        }
+        return 0.0;
+    };
+
+    ElasticMatrix chain(static_cast<size_t>(E) * static_cast<size_t>(n_tgt),
+                        static_cast<size_t>(E) * static_cast<size_t>(n_src));
+    for (int es = 0; es < E; ++es) {
+        Array3D& f = fields[static_cast<size_t>(es)].at(src_tag);
+        for (int i = 0; i < n_src; ++i) {
+            f.fill(0.0);
+            set_line_value(f, i, 1.0);
+            for (int dm = -1; dm <= 1; ++dm) {
+                const int em = es + dm;
+                if (em < 0 || em >= E) {
+                    continue;
+                }
+                const TaggedFields3D* minus_neighbor =
+                    (em - 1 >= 0) ? &fields[static_cast<size_t>(em - 1)] : nullptr;
+                const TaggedFields3D* plus_neighbor =
+                    (em + 1 < E) ? &fields[static_cast<size_t>(em + 1)] : nullptr;
+                AxisSatSet3D& sat = sat_pos[static_cast<size_t>(em)];
+                TaggedSatFaces3D& sat_axis =
+                    (axis == Axis3D::X) ? sat.x : (axis == Axis3D::Y) ? sat.y : sat.z;
+                populate_serial_neighbor_outer_faces(
+                    axis, ops, minus_neighbor, plus_neighbor, tags4, sat_axis);
+                const ReferenceDerivativeStage3D stage =
+                    compute_displacement_reference_derivative(
+                        axis, src_tag, ops,
+                        fields[static_cast<size_t>(em)].at(src_tag),
+                        sat_axis.at(src_tag));
+                for (int t = 0; t < n_tgt; ++t) {
+                    chain(static_cast<size_t>(em) * static_cast<size_t>(n_tgt)
+                              + static_cast<size_t>(t),
+                          static_cast<size_t>(es) * static_cast<size_t>(n_src)
+                              + static_cast<size_t>(i)) =
+                        read_line_value(stage.derivative_hat, t);
+                }
+            }
+        }
+        f.fill(0.0);
+    }
+    return chain;
+}
