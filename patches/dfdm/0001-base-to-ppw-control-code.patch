+            populate_one(minus_conn, false, face_data, source_tag);
+            populate_one(plus_conn, true, face_data, source_tag);
+        }
+    };
+
+    populate_axis(neighbors.x_minus_conn, neighbors.x_plus_conn, sat.x);
+    populate_axis(neighbors.y_minus_conn, neighbors.y_plus_conn, sat.y);
+    populate_axis(neighbors.z_minus_conn, neighbors.z_plus_conn, sat.z);
+}
+
+void populate_stress_sat_from_cache(const SerialPhase1Domain3D& domain,
+                                    size_t index,
+                                    StressDivergenceSat3D& sat) {
+    const SerialElementNeighbors3D& neighbors = domain.neighbors[index];
+    const AxisOpsPtr3D local_ops = {
+        domain.element_x_ops[index],
+        domain.element_y_ops[index],
+        domain.element_z_ops[index],
+    };
+    auto ops_for_neighbor = [&](int neighbor_index) -> AxisOpsPtr3D {
+        if (neighbor_index < 0) {
+            return {&domain.x_ops, &domain.y_ops, &domain.z_ops};
+        }
+        const size_t n = static_cast<size_t>(neighbor_index);
+        return {domain.element_x_ops[n], domain.element_y_ops[n], domain.element_z_ops[n]};
+    };
+
+    auto populate_one = [&](const FaceNeighbor3D& conn,
+                            int equation,
+                            bool local_plus_face,
+                            SatFaceData3D& face_data,
+                            GridTag source_tag) {
+        Array3D& destination = local_plus_face ? face_data.plus_outer : face_data.minus_outer;
+        if (conn.index < 0) {
+            destination.fill(0.0);
+            return;
+        }
+        const GridTag neighbor_tag = map_grid_tag_to_neighbor_axes(source_tag, conn);
+        const Array3D& neighbor_face =
+            domain.stress_face_cache[static_cast<size_t>(conn.index)].faces[
+                ElementFaceCache3D::slot(conn.neighbor_axis, conn.neighbor_plus_face,
+                                         static_cast<size_t>(equation - 1),
+                                         stress_tag_slot(neighbor_tag))];
+        remap_or_project_neighbor_face_to_local_into(
+            neighbor_face, conn, ops_for_neighbor(conn.index), neighbor_tag,
+            local_ops, source_tag, destination,
+            oriented_pullback_flux_sign(local_plus_face, conn));
+    };
+
+    auto populate_axis = [&](int equation,
+                             const FaceNeighbor3D& minus_conn,
+                             const FaceNeighbor3D& plus_conn,
+                             TaggedSatFaces3D& faces) {
+        for (GridTag source_tag : kStressGridTags) {
+            SatFaceData3D& face_data = faces.at(source_tag);
+            populate_one(minus_conn, equation, false, face_data, source_tag);
+            populate_one(plus_conn, equation, true, face_data, source_tag);
+        }
+    };
+
+    populate_axis(1, neighbors.x_minus_conn, neighbors.x_plus_conn, sat.eq1.x);
+    populate_axis(1, neighbors.y_minus_conn, neighbors.y_plus_conn, sat.eq1.y);
+    populate_axis(1, neighbors.z_minus_conn, neighbors.z_plus_conn, sat.eq1.z);
+    populate_axis(2, neighbors.x_minus_conn, neighbors.x_plus_conn, sat.eq2.x);
+    populate_axis(2, neighbors.y_minus_conn, neighbors.y_plus_conn, sat.eq2.y);
+    populate_axis(2, neighbors.z_minus_conn, neighbors.z_plus_conn, sat.eq2.z);
+    populate_axis(3, neighbors.x_minus_conn, neighbors.x_plus_conn, sat.eq3.x);
+    populate_axis(3, neighbors.y_minus_conn, neighbors.y_plus_conn, sat.eq3.y);
+    populate_axis(3, neighbors.z_minus_conn, neighbors.z_plus_conn, sat.eq3.z);
+}
