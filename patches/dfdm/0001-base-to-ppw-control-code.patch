+// g0_fixed_kernel_gate.cpp
+//
+// K2 Phase 0 micro-gate (G0): compare the canonical fixed-size axis kernels
+// (src/axis_kernels_fixed.h) against LibSci cblas_dgemm with the EXACT call
+// shapes of apply_matrix_{x,y,z}_into and extract_filtered_face_from_hat,
+// per (NS,NT) shape pair and per loop form, on random data and on the real
+// production khat operators.
+//
+// Outputs, per (pair, form): max relative deviation and whether LibSci is
+// bitwise-matchable (max abs diff == 0). Decides whether gate G2
+// (fixed-vs-precomposed receivers) can be bitwise or must use the
+// rel<=1e-9 tolerance precedent (classic-vs-precomposed).
+//
+// Also: per-form microbenchmark at the production shape pairs (ns/app,
+// dgemm vs fixed), login-node single thread.
+
+#include <cblas.h>
+
+#include "axis_kernels_fixed.h"
+#include "elastic3d.h"
+
+#include <chrono>
+#include <cmath>
+#include <cstdio>
+#include <cstring>
+#include <random>
+#include <vector>
+
+namespace {
+
+using axis_kernels_fixed::apply_bundle;
+using axis_kernels_fixed::apply_xline;
+using axis_kernels_fixed::extract_face_bundle;
+using axis_kernels_fixed::extract_face_xdot;
+
+double now_s() {
+    return std::chrono::duration<double>(
+               std::chrono::steady_clock::now().time_since_epoch())
+        .count();
+}
+
+// dgemm replicas with the exact production call shapes -----------------------
+void dgemm_x(const double* K, int nt, int ns, const double* in, double* out, int nlines) {
+    cblas_dgemm(CblasColMajor, CblasNoTrans, CblasNoTrans,
+                nt, nlines, ns, 1.0, K, nt, in, ns, 0.0, out, nt);
+}
+void dgemm_y(const double* K, int nt, int ns, const double* in, double* out, int nx, int nz) {
+    for (int k = 0; k < nz; ++k) {
+        cblas_dgemm(CblasColMajor, CblasNoTrans, CblasTrans,
+                    nx, nt, ns, 1.0,
+                    in + static_cast<size_t>(k) * nx * ns, nx,
+                    K, nt, 0.0,
+                    out + static_cast<size_t>(k) * nx * nt, nx);
+    }
+}
+void dgemm_z(const double* K, int nt, int ns, const double* in, double* out, int nplane) {
+    cblas_dgemm(CblasColMajor, CblasNoTrans, CblasTrans,
+                nplane, nt, ns, 1.0, in, nplane, K, nt, 0.0, out, nplane);
+}
+// face extraction replicas (extract_filtered_face_from_hat shapes)
+void dgemm_face_x(const double* row, int ns, const double* in, double* out, int nlines) {
+    cblas_dgemm(CblasColMajor, CblasNoTrans, CblasNoTrans,
+                1, nlines, ns, 1.0, row, 1, in, ns, 0.0, out, 1);
+}
+void dgemm_face_y(const double* row, int ns, const double* in, double* out, int nx, int nz) {
+    for (int k = 0; k < nz; ++k) {
+        cblas_dgemm(CblasColMajor, CblasNoTrans, CblasTrans,
+                    nx, 1, ns, 1.0,
+                    in + static_cast<size_t>(k) * nx * ns, nx,
+                    row, 1, 0.0,
+                    out + static_cast<size_t>(k) * nx, nx);
+    }
+}
+void dgemm_face_z(const double* row, int ns, const double* in, double* out, int nplane) {
+    cblas_dgemm(CblasColMajor, CblasNoTrans, CblasTrans,
+                nplane, 1, ns, 1.0, in, nplane, row, 1, 0.0, out, nplane);
+}
+
+struct DevStat {
+    double max_rel = 0.0;
+    double max_abs = 0.0;
+    void merge(const std::vector<double>& ref, const std::vector<double>& got) {
+        double ref_max = 0.0;
+        for (double v : ref) ref_max = std::max(ref_max, std::abs(v));
+        for (size_t i = 0; i < ref.size(); ++i) {
+            const double d = std::abs(ref[i] - got[i]);
+            max_abs = std::max(max_abs, d);
+            if (ref_max > 0.0) max_rel = std::max(max_rel, d / ref_max);
+        }
+    }
+};
+
+std::vector<double> random_vec(size_t n, std::mt19937& rng) {
+    std::uniform_real_distribution<double> u(-1.0, 1.0);
+    std::vector<double> v(n);
+    for (double& x : v) x = u(rng);
+    return v;
+}
+
+// Per-pair correctness over the three forms; K = production khat (and one
+// extra random K so the verdict does not depend on khat's value structure).
+template <int NS, int NT>
+void check_pair(const double* khat, std::mt19937& rng,
+                DevStat& khat_stat, DevStat& face_stat,
+                bool* bitwise_khat, bool* bitwise_face) {
+    const int transverse[3] = {25, 30, 36};
+    std::vector<double> kr = random_vec(static_cast<size_t>(NS) * NT, rng);
+    for (int pass = 0; pass < 2; ++pass) {
+        const double* K = pass == 0 ? khat : kr.data();
+        DevStat st;
+        for (int lines : transverse) {
+            // X form
+            std::vector<double> in = random_vec(static_cast<size_t>(NS) * lines, rng);
+            std::vector<double> ref(static_cast<size_t>(NT) * lines), got(ref.size());
+            dgemm_x(K, NT, NS, in.data(), ref.data(), lines);
+            apply_xline<NS, NT>(K, in.data(), got.data(), static_cast<size_t>(lines));
+            st.merge(ref, got);
+        }
+        for (int nx : {5, 6}) {
+            for (int nz : {5, 6}) {
+                // Y form
+                std::vector<double> in = random_vec(static_cast<size_t>(nx) * NS * nz, rng);
+                std::vector<double> ref(static_cast<size_t>(nx) * NT * nz), got(ref.size());
+                dgemm_y(K, NT, NS, in.data(), ref.data(), nx, nz);
+                apply_bundle<NS, NT>(K, in.data(), got.data(),
+                                     static_cast<size_t>(nx), static_cast<size_t>(nx),
+                                     static_cast<size_t>(nx), static_cast<size_t>(nz),
+                                     static_cast<size_t>(nx) * NS,
+                                     static_cast<size_t>(nx) * NT);
+                st.merge(ref, got);
+                // Z form
+                const int plane = nx * nz;
+                std::vector<double> inz = random_vec(static_cast<size_t>(plane) * NS, rng);
+                std::vector<double> refz(static_cast<size_t>(plane) * NT), gotz(refz.size());
+                dgemm_z(K, NT, NS, inz.data(), refz.data(), plane);
+                apply_bundle<NS, NT>(K, inz.data(), gotz.data(),
+                                     static_cast<size_t>(plane), static_cast<size_t>(plane),
+                                     static_cast<size_t>(plane), 1, 0, 0);
+                st.merge(refz, gotz);
+            }
+        }
+        khat_stat.max_rel = std::max(khat_stat.max_rel, st.max_rel);
+        khat_stat.max_abs = std::max(khat_stat.max_abs, st.max_abs);
+        if (st.max_abs != 0.0) *bitwise_khat = false;
+    }
+
+    // Face-extraction dot forms (length-NS boundary-row dots).
+    {
+        std::vector<double> row = random_vec(NS, rng);
+        DevStat st;
+        const int lines = 36;
+        std::vector<double> in = random_vec(static_cast<size_t>(NS) * lines, rng);
+        std::vector<double> ref(lines), got(lines);
+        dgemm_face_x(row.data(), NS, in.data(), ref.data(), lines);
+        extract_face_xdot<NS>(row.data(), in.data(), got.data(), lines);
+        st.merge(ref, got);
+
+        const int nx = 6, nz = 6;
+        std::vector<double> iny = random_vec(static_cast<size_t>(nx) * NS * nz, rng);
+        std::vector<double> refy(static_cast<size_t>(nx) * nz), goty(refy.size());
+        dgemm_face_y(row.data(), NS, iny.data(), refy.data(), nx, nz);
+        extract_face_bundle<NS>(row.data(), iny.data(), goty.data(),
+                                nx, nx, nz, static_cast<size_t>(nx) * NS, nx);
+        st.merge(refy, goty);
+
+        const int plane = 36;
+        std::vector<double> inz = random_vec(static_cast<size_t>(plane) * NS, rng);
+        std::vector<double> refz(plane), gotz(plane);
+        dgemm_face_z(row.data(), NS, inz.data(), refz.data(), plane);
+        extract_face_bundle<NS>(row.data(), inz.data(), gotz.data(),
+                                plane, plane, 1, 0, 0);
+        st.merge(refz, gotz);
+
+        face_stat.max_rel = std::max(face_stat.max_rel, st.max_rel);
+        face_stat.max_abs = std::max(face_stat.max_abs, st.max_abs);
+        if (st.max_abs != 0.0) *bitwise_face = false;
+    }
+}
+
+template <int N1>
+void check_n1(std::mt19937& rng, DevStat& khat_stat, DevStat& face_stat,
+              bool* bitwise_khat, bool* bitwise_face) {
+    const AxisOperators1D ops =
+        build_axis_operators(N1, 4, 0.5, "schur_sqrt", "precomposed");
+    // family 1: khat (N1-1) x N1  -> NS=N1, NT=N1-1
+    check_pair<N1, N1 - 1>(ops.precomposed[0].khat.data(), rng,
+                           khat_stat, face_stat, bitwise_khat, bitwise_face);
+    // family 2: khat N1 x (N1-1) -> NS=N1-1, NT=N1
+    check_pair<N1 - 1, N1>(ops.precomposed[1].khat.data(), rng,
+                           khat_stat, face_stat, bitwise_khat, bitwise_face);
+    std::printf("  n1=%2d pairs (%d,%d)+(%d,%d): khat max_rel=%.3e max_abs=%.3e | "
+                "face max_rel=%.3e max_abs=%.3e\n",
+                N1, N1, N1 - 1, N1 - 1, N1,
+                khat_stat.max_rel, khat_stat.max_abs,
+                face_stat.max_rel, face_stat.max_abs);
+}
+
+// --------------------------------------------------------------------------
+// Microbenchmark at the production pairs (n1=6 component sweep, HOT).
+struct AppShape {
+    const char* name;
+    int axis;        // 0=x 1=y 2=z
+    int family;      // 1 or 2 (source family)
+    int sx, sy, sz;
+    int tx, ty, tz;
+};
+constexpr AppShape kSweep[12] = {
+    {"G211.x 6x5@36", 0, 2, 5, 6, 6, 6, 6, 6},
+    {"G211.y 5x6@30", 1, 1, 5, 6, 6, 5, 5, 6},
+    {"G211.z 5x6@30", 2, 1, 5, 6, 6, 5, 6, 5},
+    {"G121.x 5x6@30", 0, 1, 6, 5, 6, 5, 5, 6},
+    {"G121.y 6x5@36", 1, 2, 6, 5, 6, 6, 6, 6},
+    {"G121.z 5x6@30", 2, 1, 6, 5, 6, 6, 5, 5},
+    {"G112.x 5x6@30", 0, 1, 6, 6, 5, 5, 6, 5},
+    {"G112.y 5x6@30", 1, 1, 6, 6, 5, 6, 5, 5},
+    {"G112.z 6x5@36", 2, 2, 6, 6, 5, 6, 6, 6},
+    {"G222.x 6x5@25", 0, 2, 5, 5, 5, 6, 5, 5},
+    {"G222.y 6x5@25", 1, 2, 5, 5, 5, 5, 6, 5},
+    {"G222.z 6x5@25", 2, 2, 5, 5, 5, 5, 5, 6},
+};
+int nsrc_of(const AppShape& s) { return s.axis == 0 ? s.sx : (s.axis == 1 ? s.sy : s.sz); }
+int ntgt_of(const AppShape& s) { return s.axis == 0 ? s.tx : (s.axis == 1 ? s.ty : s.tz); }
+int lines_of(const AppShape& s) {
+    if (s.axis == 0) return s.sy * s.sz;
+    if (s.axis == 1) return s.sx * s.sz;
+    return s.sx * s.sy;
+}
+
+void fixed_apply(const AppShape& s, const double* K, const double* in, double* out) {
+    const size_t nx = static_cast<size_t>(s.sx);
+    if (s.family == 1) {  // NS=6, NT=5 at n1=6
+        if (s.axis == 0) apply_xline<6, 5>(K, in, out, static_cast<size_t>(lines_of(s)));
+        else if (s.axis == 1) apply_bundle<6, 5>(K, in, out, nx, nx, nx,
+                                                 static_cast<size_t>(s.sz), nx * 6, nx * 5);
+        else apply_bundle<6, 5>(K, in, out, nx * s.sy, nx * s.sy, nx * s.sy, 1, 0, 0);
+    } else {  // NS=5, NT=6
+        if (s.axis == 0) apply_xline<5, 6>(K, in, out, static_cast<size_t>(lines_of(s)));
+        else if (s.axis == 1) apply_bundle<5, 6>(K, in, out, nx, nx, nx,
+                                                 static_cast<size_t>(s.sz), nx * 5, nx * 6);
+        else apply_bundle<5, 6>(K, in, out, nx * s.sy, nx * s.sy, nx * s.sy, 1, 0, 0);
+    }
+}
+void dgemm_apply(const AppShape& s, const double* K, const double* in, double* out) {
+    const int nt = ntgt_of(s), ns = nsrc_of(s);
+    if (s.axis == 0) dgemm_x(K, nt, ns, in, out, s.sy * s.sz);
+    else if (s.axis == 1) dgemm_y(K, nt, ns, in, out, s.sx, s.sz);
+    else dgemm_z(K, nt, ns, in, out, s.sx * s.sy);
+}
+
+}  // namespace
+
+int main() {
+    std::printf("=== G0 micro-gate: fixed kernels vs LibSci dgemm ===\n");
+    std::mt19937 rng(2026);
+    DevStat khat_stat, face_stat;
+    bool bitwise_khat = true, bitwise_face = true;
+    check_n1<6>(rng, khat_stat, face_stat, &bitwise_khat, &bitwise_face);
+    check_n1<7>(rng, khat_stat, face_stat, &bitwise_khat, &bitwise_face);
+    check_n1<8>(rng, khat_stat, face_stat, &bitwise_khat, &bitwise_face);
+    check_n1<9>(rng, khat_stat, face_stat, &bitwise_khat, &bitwise_face);
+    check_n1<10>(rng, khat_stat, face_stat, &bitwise_khat, &bitwise_face);
+    check_n1<11>(rng, khat_stat, face_stat, &bitwise_khat, &bitwise_face);
+    check_n1<12>(rng, khat_stat, face_stat, &bitwise_khat, &bitwise_face);
+
+    std::printf("\nG0 VERDICT:\n");
+    std::printf("  khat forms : bitwise=%s  max_rel=%.3e (tolerance gate threshold 1e-9)\n",
+                bitwise_khat ? "YES" : "NO", khat_stat.max_rel);
+    std::printf("  face dots  : bitwise=%s  max_rel=%.3e\n",
+                bitwise_face ? "YES" : "NO", face_stat.max_rel);
+
+    // ---- microbenchmark at the production pairs (HOT, single thread) ----
+    std::printf("\n=== per-form microbenchmark, production pairs (n1=6), HOT ===\n");
+    const AxisOperators1D ops = build_axis_operators(6, 4, 0.5, "schur_sqrt", "precomposed");
+    const double* khat_by_family[2] = {
+        ops.precomposed[0].khat.data(), ops.precomposed[1].khat.data(),
+    };
+    std::mt19937 rng2(7);
+    double sum_dgemm = 0.0, sum_fixed = 0.0;
+    for (const AppShape& s : kSweep) {
+        const std::vector<double> in =
+            random_vec(static_cast<size_t>(s.sx) * s.sy * s.sz, rng2);
+        std::vector<double> out(static_cast<size_t>(s.tx) * s.ty * s.tz, 0.0);
+        const double* K = khat_by_family[s.family - 1];
+        const int iters = 200000;
+        volatile double sink = 0.0;
+        double tg = 1e30, tf = 1e30;
+        for (int r = 0; r < 3; ++r) {
+            double t0 = now_s();
+            for (int i = 0; i < iters; ++i) dgemm_apply(s, K, in.data(), out.data());
+            double t1 = now_s();
+            tg = std::min(tg, (t1 - t0) / iters);
+            t0 = now_s();
+            for (int i = 0; i < iters; ++i) fixed_apply(s, K, in.data(), out.data());
+            t1 = now_s();
+            tf = std::min(tf, (t1 - t0) / iters);
+            sink = out[0];
+        }
+        (void)sink;
+        sum_dgemm += tg;
+        sum_fixed += tf;
+        const double fl = 2.0 * ntgt_of(s) * nsrc_of(s) * lines_of(s);
+        std::printf("  %-14s dgemm %7.1f ns (%5.2f GF/s)   fixed %6.1f ns (%5.2f GF/s)   %5.1fx\n",
+                    s.name, tg * 1e9, fl / tg * 1e-9, tf * 1e9, fl / tf * 1e-9, tg / tf);
+    }
+    std::printf("  12-app sweep: dgemm %.1f ns  fixed %.1f ns  ratio %.1fx\n",
+                sum_dgemm * 1e9, sum_fixed * 1e9, sum_dgemm / sum_fixed);
+    return 0;
+}
