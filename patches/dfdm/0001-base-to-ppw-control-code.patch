+#!/usr/bin/env python3
+"""Time-resolved staggered-copy splitting analysis from per-contribution receiver files.
+
+Plain receiver file layout (13 cols): time, ux[G211,G121,G112,G222], uy[...], uz[...]
+Questions answered per receiver/component:
+  1. When does the inter-copy spread first become significant relative to the signal?
+  2. Is the spread phase-dependent (body-wave window vs surface-wave window)?
+  3. Per-copy correlation/amplitude vs the 4-copy mean per window.
+"""
+from __future__ import annotations
+
+import glob
+import json
+import os
+import sys
+
+import numpy as np
+
+COPY_NAMES = ["G211", "G121", "G112", "G222"]
+COMP_NAMES = ["X", "Y", "Z"]
+
+
+def windowed_rms(x: np.ndarray, half: int) -> np.ndarray:
+    csum = np.cumsum(np.concatenate(([0.0], x * x)))
+    n = len(x)
+    out = np.empty(n)
+    for i in range(n):
+        lo = max(0, i - half)
+        hi = min(n, i + half + 1)
+        out[i] = np.sqrt((csum[hi] - csum[lo]) / (hi - lo))
+    return out
+
+
+def analyze_file(path: str, win_seconds: float = 100.0):
+    data = np.loadtxt(path)
+    t = data[:, 0]
+    dt = t[1] - t[0]
+    half = max(1, int(round(win_seconds / dt / 2)))
+    result = {}
+    for ic, comp in enumerate(COMP_NAMES):
+        copies = data[:, 1 + 4 * ic : 1 + 4 * (ic + 1)]  # (nt, 4)
+        mean = copies.mean(axis=1)
+        sig_rms_t = windowed_rms(mean, half)
+        sig_peak = np.abs(mean).max()
+        if sig_peak == 0.0:
+            continue
+        # signal onset: first time windowed rms exceeds 2% of global max
+        onset_idx = np.argmax(sig_rms_t > 0.02 * sig_peak)
+        onset_t = float(t[onset_idx]) if sig_rms_t[onset_idx] > 0 else None
+
+        spread = {}
+        for k, name in enumerate(COPY_NAMES):
+            d = copies[:, k] - mean
+            d_rms_t = windowed_rms(d, half)
+            # relative spread vs local signal level (guard low-signal zones)
+            mask = sig_rms_t > 0.05 * sig_peak
+            rel = np.zeros_like(d_rms_t)
+            rel[mask] = d_rms_t[mask] / sig_rms_t[mask]
+            spread[name] = {
+                "rel_spread_t": rel,
+                "global_rel": float(np.sqrt((d * d).sum() / max((mean * mean).sum(), 1e-300))),
+            }
+        result[comp] = {
+            "t": t,
+            "mean": mean,
+            "copies": copies,
+            "onset_t": onset_t,
+            "sig_rms_t": sig_rms_t,
+            "sig_peak": float(sig_peak),
+            "spread": spread,
+        }
+    return result
+
+
+def main():
+    case = sys.argv[1] if len(sys.argv) > 1 else "bench/correctness/sweep_ak135_ref128"
+    files = sorted(glob.glob(os.path.join(case, "DFDM_OUTPUT", "Uxyz_dfdm3d_[A-Z]*_nex*_N*.txt")))
+    files = [f for f in files if "_avg_" not in f and "_geo_" not in f]
+    if not files:
+        print("no plain per-contribution files found", file=sys.stderr)
+        sys.exit(1)
+
+    summary = {}
+    rep = None
+    for path in files:
+        rec = os.path.basename(path).split("_")[2]
+        res = analyze_file(path)
+        summary[rec] = {}
+        for comp, r in res.items():
+            t = r["t"]
+            # early window: onset .. onset+300 s ; late window: last third of active signal
+            onset = r["onset_t"] or t[0]
+            early = (t >= onset) & (t <= onset + 300.0)
+            active = r["sig_rms_t"] > 0.05 * r["sig_peak"]
+            act_idx = np.where(active)[0]
+            late = np.zeros_like(active)
+            if len(act_idx):
+                lo = act_idx[0] + 2 * (act_idx[-1] - act_idx[0]) // 3
