+// Registry -------------------------------------------------------------------
+// Function-pointer pair for one (n_src, n_tgt) shape. Null pointers mean "no
+// fixed kernel for this shape" and callers fall back to the dgemm path.
+struct FixedAxisKernelFns {
+    using XlineFn = void (*)(const double* K, const double* in, double* out,
+                             std::size_t n_lines);
+    using BundleFn = void (*)(const double* K, const double* in, double* out,
+                              std::size_t bundle, std::size_t in_cs,
+                              std::size_t out_cs, std::size_t n_slices,
+                              std::size_t in_ss, std::size_t out_ss);
+    using XlineTripletFn = void (*)(const double* K,
+                                    const double* in0, const double* in1, const double* in2,
+                                    double* out0, double* out1, double* out2,
+                                    std::size_t n_lines);
+    using BundleTripletFn = void (*)(const double* K,
+                                     const double* in0, const double* in1, const double* in2,
+                                     double* out0, double* out1, double* out2,
+                                     std::size_t bundle, std::size_t in_cs,
+                                     std::size_t out_cs, std::size_t n_slices,
+                                     std::size_t in_ss, std::size_t out_ss);
+    using XlineSatFn = void (*)(const double* K,
+                                const double* row_minus, const double* row_plus,
+                                const double* col_minus, const double* col_plus,
+                                const double* in,
+                                const double* minus_outer, const double* minus_alpha,
+                                const double* plus_outer, const double* plus_alpha,
+                                double* out, bool outer_weighted, bool additive,
+                                std::size_t n_lines);
+    using BundleSatFn = void (*)(const double* K,
+                                 const double* row_minus, const double* row_plus,
+                                 const double* col_minus, const double* col_plus,
+                                 const double* in,
+                                 const double* minus_outer, const double* minus_alpha,
+                                 const double* plus_outer, const double* plus_alpha,
+                                 double* out,
+                                 std::size_t bundle, std::size_t in_cs,
+                                 std::size_t out_cs, std::size_t n_slices,
+                                 std::size_t in_ss, std::size_t out_ss,
+                                 std::size_t face_ss,
+                                 bool outer_weighted, bool additive);
+    using XlineTripletSatFn = void (*)(const double* K,
+                                       const double* row_minus, const double* row_plus,
+                                       const double* col_minus, const double* col_plus,
+                                       const double* const* in,
+                                       const double* const* minus_outer,
+                                       const double* const* minus_alpha,
+                                       const double* const* plus_outer,
+                                       const double* const* plus_alpha,
+                                       double* const* out,
+                                       bool outer_weighted, bool additive,
+                                       std::size_t n_lines);
+    using BundleTripletSatFn = void (*)(const double* K,
+                                        const double* row_minus, const double* row_plus,
+                                        const double* col_minus, const double* col_plus,
+                                        const double* const* in,
+                                        const double* const* minus_outer,
+                                        const double* const* minus_alpha,
+                                        const double* const* plus_outer,
+                                        const double* const* plus_alpha,
+                                        double* const* out,
+                                        std::size_t bundle, std::size_t in_cs,
+                                        std::size_t out_cs, std::size_t n_slices,
+                                        std::size_t in_ss, std::size_t out_ss,
+                                        std::size_t face_ss,
+                                        bool outer_weighted, bool additive);
+    XlineFn xline = nullptr;
+    BundleFn bundle = nullptr;
+    XlineFn xline_add = nullptr;
+    BundleFn bundle_add = nullptr;
+    BundleFn bundle_pairt = nullptr;
+    BundleFn bundle_add_pairt = nullptr;
+    XlineTripletFn xline_triplet = nullptr;
+    BundleTripletFn bundle_triplet = nullptr;
+    XlineTripletFn xline_triplet_add = nullptr;
+    BundleTripletFn bundle_triplet_add = nullptr;
+    XlineSatFn xline_sat = nullptr;
