+// Per-element operator pointer tables in global element order. The pointers
+// reference base operators and layer map entries, both of which must outlive
+// the table (they are domain members; std::map nodes are address-stable).
+std::vector<const AxisOperators1D*> build_element_x_ops_table(
+    const Solver3DConfig& cfg,
+    const AxisOperators1D& base_x_ops,
+    const std::map<int, AxisOperators1D>& layer_ops) {
+    const size_t count = total_element_count(cfg);
+    std::vector<const AxisOperators1D*> table(count, &base_x_ops);
+    if (!cfg.nx_per_layer.empty()) {
+        for (size_t global = 0; global < count; ++global) {
+            table[global] = &select_layer_x_ops_for_global(cfg, base_x_ops, layer_ops, global);
+        }
+    }
+    return table;
