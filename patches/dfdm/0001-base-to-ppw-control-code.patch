+R2NullFilter3D build_r2_null_filter(const Solver3DConfig& cfg,
+                                    const AxisOperators1D& x_ops,
+                                    const AxisOperators1D& y_ops,
+                                    const AxisOperators1D& z_ops) {
+    R2NullFilter3D filter;
+    if (cfg.r2_null_filter == "off") {
+        return filter;
+    }
+    require_true(cfg.r2_null_filter == "step",
+                 "solver.r2_null_filter must be \"off\" or \"step\"");
+    require_true(cfg.geometry_kind == "cartesian",
+                 "solver.r2_null_filter=\"step\" currently supports only the cartesian topology");
+    require_true(cfg.r2_null_filter_interval >= 1,
+                 "solver.r2_null_filter_interval must be >= 1");
+    filter.enabled = true;
+    filter.interval = cfg.r2_null_filter_interval;
+    filter.axes[static_cast<size_t>(Axis3D::X)] =
+        build_r2_null_filter_axis(cfg, Axis3D::X, x_ops);
+    filter.axes[static_cast<size_t>(Axis3D::Y)] =
+        build_r2_null_filter_axis(cfg, Axis3D::Y, y_ops);
+    filter.axes[static_cast<size_t>(Axis3D::Z)] =
+        build_r2_null_filter_axis(cfg, Axis3D::Z, z_ops);
+    for (const R2NullFilterAxis3D& axis_filter : filter.axes) {
+        require_true(axis_filter.max_chain_residual < 1.0e-8,
+                     "r2 filter: null-basis chain residual exceeds tolerance");
+        require_true(axis_filter.max_constant_overlap < 1.0e-10,
+                     "r2 filter: null basis is not orthogonal to the constant");
+    }
+    return filter;
+}
