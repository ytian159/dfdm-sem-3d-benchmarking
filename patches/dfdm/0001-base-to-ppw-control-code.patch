+// counts must satisfy nex == ney == nez_cube; nex is the canonical value.
+// With mesh3d.full_shell_nez_decoupled=false (legacy) nex == nez is enforced,
+// so this equals cfg.nez and all chunk helpers below reduce to the uniform
+// per-chunk layout.
+int central_cube_nez(const Solver3DConfig& cfg) {
+    return cfg.nex;
+}
+
+// Per-chunk radial element count: shell chunks carry cfg.nez layers, the
+// full-Earth central cube carries central_cube_nez(cfg).
+int chunk_nez(const Solver3DConfig& cfg, int chunk) {
+    return is_full_earth_central_cube_chunk(cfg, chunk) ? central_cube_nez(cfg)
