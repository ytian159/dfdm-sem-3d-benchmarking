diff --git a/validate/plot_distance_record_section.py b/validate/plot_distance_record_section.py
new file mode 100644
index 0000000..031cccb
--- /dev/null
+++ b/validate/plot_distance_record_section.py
@@ -0,0 +1,86 @@
+#!/usr/bin/env python3
+"""Distance record section: DFDM (geometry recovery) vs SPECFEM, one azimuth line.
+
+Reuses the comparator's loaders/rotation so time alignment and ENZ conventions
+are identical to the published metrics.
+"""
+from __future__ import annotations
+
+import argparse
+import json
+import sys
+from pathlib import Path
+from types import SimpleNamespace
+
+import numpy as np
+
+sys.path.insert(0, str(Path(__file__).resolve().parent))
+from compare_specfem_globe_azimuth_sweep import evaluate_recovery  # noqa: E402
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--case-dir", required=True, type=Path)
+    parser.add_argument("--component", default="z", choices=["e", "n", "z"])
+    parser.add_argument("--recovery", default="geometry")
+    parser.add_argument("--out", type=Path)
+    cli = parser.parse_args()
+
+    case_dir = cli.case_dir.resolve()
+    manifest = json.loads((case_dir / "azimuth_sweep_manifest.json").read_text())
+    f0 = float(manifest["source"]["frequency_hz"])
+    args = SimpleNamespace(
+        network="DF", window_start=None, window_end=None,
+        noise_floor=1.0e-30, relative_arrival_threshold=1.0e-3,
+        active_component_relative_floor=5.0e-2, max_lag=50.0,
+    )
+    results, _ = evaluate_recovery(
+        args, manifest, case_dir / "DFDM_OUTPUT",
+        case_dir / "specfem_case" / "OUTPUT_FILES", 1.2 / f0, cli.recovery,
+    )
+
+    import matplotlib
+    matplotlib.use("Agg")
+    import matplotlib.pyplot as plt
+
+    results = sorted(results, key=lambda r: float(r["receiver_distance_deg"]))
+    dists = [float(r["receiver_distance_deg"]) for r in results]
+    span = max(dists) - min(dists)
+    gain = span / len(results) * 1.6  # trace half-height in degrees
+
+    fig, ax = plt.subplots(figsize=(13, 11))
+    comp = cli.component
+    for r in results:
+        d = float(r["receiver_distance_deg"])
+        ts, xs = r["spec"]["time"], r["spec"][comp]
+        td, xd = r["dfdm_local"]["time"], r["dfdm_local"][comp]
+        norm = max(np.abs(xs).max(), 1e-30)
+        ax.plot(ts, d + gain * xs / norm, "k", lw=0.8)
+        ax.plot(td, d + gain * xd / norm, "r", lw=0.8, alpha=0.75)
+        m = r["metrics"][comp]
+        label = (f"{r['station']}  corr={m.get('normalized_correlation', float('nan')):.3f} "
+                 f"lag={m.get('best_lag_seconds_specfem_after_dfdm', float('nan')):+.1f}s")
+        ax.text(ts[-1], d + 0.25 * gain, label, fontsize=7, va="bottom", ha="right")
+    ax.set_xlabel("time (s)")
+    ax.set_ylabel("epicentral distance (deg)")
+    ax.set_title(
+        f"{case_dir.name}: {comp.upper()}-component record section "
+        f"(black=SPECFEM, red=DFDM {cli.recovery}; f0={f0} Hz, fmax~{2.5*f0:.4f} Hz)"
+    )
+    ax.grid(alpha=0.25)
+    out = cli.out or case_dir / f"distance_record_section_{comp.upper()}_{cli.recovery}.png"
+    fig.tight_layout()
+    fig.savefig(out, dpi=140)
+    print(f"wrote {out}")
+
+    print(f"\n{'sta':6s} {'dist':>6s} | corr      lag(s)   amp_ratio (component {comp.upper()})")
+    for r in results:
+        m = r["metrics"][comp]
+        print(f"{r['station']:6s} {float(r['receiver_distance_deg']):6.1f} | "
+              f"{m.get('normalized_correlation', float('nan')):8.4f} "
+              f"{m.get('best_lag_seconds_specfem_after_dfdm', float('nan')):+8.2f} "
+              f"{m.get('peak_amplitude_ratio_dfdm_over_specfem', float('nan')):9.4f}")
+
+
+if __name__ == "__main__":
+    main()
