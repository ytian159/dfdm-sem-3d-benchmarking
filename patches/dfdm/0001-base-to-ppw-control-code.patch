+void scale_acceleration_tag_by_inverse_mass_unchecked(const Array3D& inv_rho_jac,
+                                                      Array3D& ax,
+                                                      Array3D& ay,
+                                                      Array3D& az) {
+    const double* inv_ptr = inv_rho_jac.data();
+    double* ax_ptr = ax.data();
+    double* ay_ptr = ay.data();
+    double* az_ptr = az.data();
+    #pragma omp simd
+    for (size_t idx = 0; idx < ax.size(); ++idx) {
+        const double inv_mass = inv_ptr[idx];
+        ax_ptr[idx] *= inv_mass;
+        ay_ptr[idx] *= inv_mass;
+        az_ptr[idx] *= inv_mass;
+    }
+}
