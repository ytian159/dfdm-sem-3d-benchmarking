+void test_nonmatching_radial_hat_projection(std::ostream& out) {
+    const AxisOperators1D coarse = build_axis_operators(6, 4, 0.5);
+    const AxisOperators1D fine = build_axis_operators(8, 4, 0.5);
+
+    for (int family : {1, 2}) {
+        const ElasticMatrix& coarse_to_fine =
+            hat_l2_projection_matrix(coarse, family, fine, family);
+        const ElasticMatrix& fine_to_coarse =
+            hat_l2_projection_matrix(fine, family, coarse, family);
+        require_true(coarse_to_fine.rows() == fine_to_coarse.cols()
+                         && coarse_to_fine.cols() == fine_to_coarse.rows(),
+                     "nonmatching hat projection transpose shape mismatch");
+        double max_transpose_error = 0.0;
+        for (size_t i = 0; i < coarse_to_fine.rows(); ++i) {
+            for (size_t j = 0; j < coarse_to_fine.cols(); ++j) {
+                max_transpose_error = std::max(
+                    max_transpose_error,
+                    std::abs(coarse_to_fine(i, j) - fine_to_coarse(j, i)));
+            }
+        }
+        require_near(max_transpose_error, 5.0e-12,
+                     "nonmatching hat projection must be adjoint-paired");
+    }
+
+    const ElasticMatrix& p68 = hat_l2_projection_matrix(coarse, 1, fine, 1);
+    const ElasticMatrix& p86 = hat_l2_projection_matrix(fine, 1, coarse, 1);
+    Array3D coarse_face(coarse.n1, coarse.n1, 1);
+    Array3D fine_test(fine.n1, fine.n1, 1);
+    for (size_t j = 0; j < coarse_face.ny(); ++j) {
+        for (size_t i = 0; i < coarse_face.nx(); ++i) {
+            coarse_face(i, j, 0) = std::sin(0.17 * static_cast<double>(i + 1))
+                                 + std::cos(0.23 * static_cast<double>(j + 2));
+        }
+    }
+    for (size_t j = 0; j < fine_test.ny(); ++j) {
+        for (size_t i = 0; i < fine_test.nx(); ++i) {
+            fine_test(i, j, 0) = std::cos(0.11 * static_cast<double>(i + 3))
+                               - std::sin(0.19 * static_cast<double>(j + 1));
+        }
+    }
+
+    Array3D projected_to_fine(fine.n1, fine.n1, 1);
+    Array3D projected_to_coarse(coarse.n1, coarse.n1, 1);
+    apply_hat_face_projection_xy_into(coarse_face, p68, p68, projected_to_fine, 1.0);
+    apply_hat_face_projection_xy_into(fine_test, p86, p86, projected_to_coarse, 1.0);
+
+    double lhs = 0.0;
+    for (size_t j = 0; j < fine_test.ny(); ++j) {
+        for (size_t i = 0; i < fine_test.nx(); ++i) {
+            lhs += projected_to_fine(i, j, 0) * fine_test(i, j, 0);
+        }
+    }
+    double rhs = 0.0;
+    for (size_t j = 0; j < coarse_face.ny(); ++j) {
+        for (size_t i = 0; i < coarse_face.nx(); ++i) {
+            rhs += coarse_face(i, j, 0) * projected_to_coarse(i, j, 0);
+        }
+    }
+    require_near(std::abs(lhs - rhs), 1.0e-10,
+                 "nonmatching 2D hat face projection adjoint mismatch");
+
+    out << "  nonmatching_radial_hat_projection: ok\n";
+}
