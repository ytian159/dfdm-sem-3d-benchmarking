+void fill_stress_export_face_cache_mpi_team(MpiPhase1Domain3D& domain,
+                                            const MpiFaceHaloPlan3D& plan) {
+    const long long flat_count = static_cast<long long>(plan.flat_exports.size());
+    #pragma omp for schedule(static)
+    for (long long fi = 0; fi < flat_count; ++fi) {
+        const std::pair<size_t, size_t>& slot = plan.flat_exports[static_cast<size_t>(fi)];
+        const MpiFaceHaloEntry3D& entry = plan.exports[slot.first][slot.second];
+        const Axis3D axis = axis_from_index(entry.axis);
+        const size_t owner_local = static_cast<size_t>(entry.local);
+        const AxisOperators1D& ops = axis_ops_from_ptrs(
+            {&domain.x_ops_for_local(owner_local),
+             &domain.y_ops_for_local(owner_local),
+             &domain.z_ops_for_local(owner_local)},
+            axis);
+        fill_stress_face_cache_side(
+            domain.worksets[owner_local].pullback, axis, ops, entry.plus != 0,
+            domain.stress_face_cache[owner_local]);
+    }
+}
