+const BasisParameters& basis_for_family(const AxisOperators1D& ops, int family) {
+    if (family == 1) {
+        return ops.b1;
+    }
+    if (family == 2) {
+        return ops.b2;
+    }
+    throw std::runtime_error("Unknown staggered basis family");
+}
+
+const ElasticMatrix& hat_l2_projection_matrix(const AxisOperators1D& source_ops,
+                                              int source_family,
+                                              const AxisOperators1D& target_ops,
+                                              int target_family) {
+    const std::array<int, 8> key = {
+        source_ops.n1,
+        source_family,
+        source_ops.p,
+        source_ops.use_cholesky ? 1 : 0,
+        target_ops.n1,
+        target_family,
+        target_ops.p,
+        target_ops.use_cholesky ? 1 : 0,
+    };
+    thread_local std::map<std::array<int, 8>, ElasticMatrix> cache;
+    const auto found = cache.find(key);
+    if (found != cache.end()) {
+        return found->second;
+    }
+
+    BasisParameters target_basis = basis_for_family(target_ops, target_family);
+    BasisParameters source_basis = basis_for_family(source_ops, source_family);
+    const ElasticMatrix cross_mass =
+        cds_to_dense(inner_product(target_basis, 0, source_basis, 0));
+    const ElasticMatrix right = matmul(cross_mass, select_invl_t(source_ops, source_family));
+    ElasticMatrix projection = matmul(select_invl(target_ops, target_family), right);
+
+    const auto inserted = cache.emplace(key, std::move(projection));
+    return inserted.first->second;
+}
+
+void apply_hat_face_projection_xy_into(const Array3D& source,
+                                       const ElasticMatrix& px,
+                                       const ElasticMatrix& py,
+                                       Array3D& out,
+                                       double scale) {
+    require_true(source.nz() == 1 && out.nz() == 1,
+                 "Hat face projection expects Z-face planes");
+    require_true(px.cols() == source.nx() && px.rows() == out.nx()
+                     && py.cols() == source.ny() && py.rows() == out.ny(),
+                 "Hat face projection matrix/plane shape mismatch");
+
+    thread_local std::vector<double> tmp;
+    tmp.assign(px.rows() * source.ny(), 0.0);
+
+    for (size_t js = 0; js < source.ny(); ++js) {
+        for (size_t it = 0; it < px.rows(); ++it) {
+            double value = 0.0;
+            for (size_t is = 0; is < source.nx(); ++is) {
+                value += px(it, is) * source(is, js, 0);
+            }
+            tmp[it + js * px.rows()] = value;
+        }
+    }
+
+    for (size_t jt = 0; jt < out.ny(); ++jt) {
+        for (size_t it = 0; it < out.nx(); ++it) {
+            double value = 0.0;
+            for (size_t js = 0; js < source.ny(); ++js) {
+                value += tmp[it + js * px.rows()] * py(jt, js);
+            }
+            out(it, jt, 0) = scale * value;
+        }
+    }
+}
